# --- .NET build output ---
bin/
obj/
*.user

# --- Local config that may hold secrets - NEVER commit ---
appsettings.Development.json
appsettings.*.Development.json
local.settings.json
*.local.json
# custom integration config (e.g. config/sessionize.eldk27.custom.json) holds
# the real per-edition Sessionize endpoint id (ordinary operator config, not a
# secret) -- kept out of git so the real id never reaches the public mirror. The
# committed *.custom.sample.json files are the safe placeholder templates.
*.custom.json

# --- Azure / deploy artifacts ---
*.publishsettings
*.pubxml.user

# --- IDE ---
.vs/
.vscode/
.idea/

# --- OS ---
.DS_Store
Thumbs.db

# --- Logs ---
*.log

# timestamped deploy artifacts kept for rollback (deploy-app.ps1)
deploy-artifacts/

# local publish staging (dotnet publish output; never ship via git)
# NB: these dirs contain a COPY of config/*.eldk*.json (live event data) + build
# DLLs — they must never be tracked or mirrored to the public repo.
publish-deploy/
publish-deploy.zip
publish-out/
publish-out.zip
publish-jobs-out/
publish-jobs-out.zip
publish/
publish-dev/
publish-prod/
publish-prod-deploy/
publish-*/
publish-*.zip
