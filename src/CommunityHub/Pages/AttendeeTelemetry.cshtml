@page "/attendee-telemetry"
@model CommunityHub.Pages.AttendeeTelemetryModel
@{
    Layout = "_PublicLayout";   // anonymous, no internal chrome (§27)
    ViewData["Title"] = "Attendee telemetry — Experts Live Denmark";
}

@* §55: the ranked tables + controls live in the shared _AttendeeTelemetryPanel
   partial, reused IDENTICALLY by the sponsor (/Sponsor/Telemetry) and organizer
   (/Organizer/Telemetry) in-area pages. This public page keeps its standalone
   anonymous layout + heading and just hosts the panel. *@
<div class="card tl-wrap">
    <h2 style="text-align:center;">Who's coming to Experts Live Denmark</h2>

    <partial name="_AttendeeTelemetryPanel"
             model="new CommunityHub.Pages.Shared.AttendeeTelemetryPanelModel(Model.Data, Model.Segments)" />
</div>
