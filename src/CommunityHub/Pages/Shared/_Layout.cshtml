@inject CommunityHub.Branding.ActiveEventNameProvider ActiveEvent
@inject CommunityHub.Auth.ICurrentParticipantAccessor CurrentParticipant
@inject System.TimeProvider Clock
@inject CommunityHub.Core.Config.EventEditionConfigLoader EventConfigLoader
@inject CommunityHub.Core.Config.EventConfigOptions EventConfigOptions
@inject CommunityHub.Core.Domain.VolunteerStructureService VolunteerStructure
@inject CommunityHub.Core.Settings.FeatureSettingsService FeatureSettings
@inject CommunityHub.Core.Settings.RingResolver RingResolver
@inject CommunityHub.Core.Data.CommunityHubDbContext Db
@{
    // Product / tool name shown in the graphics layout. This is the display
    // name only - the codebase, namespaces, and Azure resources stay
    // "CommunityHub" (a tool rename in code would be churn and "EventHub"
    // collides with the Azure Event Hubs service).
    const string ProductName = "Community Event Hub";
    const string ProductShortName = "CEH";

    // The community running this edition - data, from the active Event row,
    // cached via ActiveEventNameProvider. Pages may override via ViewData.
    var communityName = (ViewData["CommunityName"] as string)
                        ?? ActiveEvent.GetCommunityName();

    var me = CurrentParticipant.Current;
    var isLoggedIn = me is not null;
    var role = me?.Role;

    // i18n: the active UI culture drives both the <html lang> attribute and the
    // resource lookups behind @Localizer. It is negotiated per request from the
    // culture cookie / Accept-Language / the en default (Program.cs); the hub is
    // English-only, so this always resolves to "en".
    var uiCulture = System.Globalization.CultureInfo.CurrentUICulture;
    // BCP-47 tag for the lang attribute (e.g. "en").
    var langTag = uiCulture.Name;

    // Site-wide topbar ticket banner (REQUIREMENTS §10). Driven from the active
    // edition config (event.<edition>.json -> ticketSale) instead of the old
    // hardcoded Layout.TicketInfo resx literal, so the copy can't silently go
    // stale and auto-switches once the sale opens. Computed against the edition
    // timezone (dates.timezone) using the ambient TimeProvider so it's testable.
    // Defensive: a broken/missing config must never 500 the whole site, so any
    // failure falls back to the static literal.
    var ticketBanner = CommunityHub.Core.Config.TicketBannerBuilder.Fallback;
    try
    {
        var editionCfg = EventConfigLoader.Load(EventConfigOptions.EventConfigPath);
        ticketBanner = CommunityHub.Core.Config.TicketBannerBuilder.Build(
            editionCfg.TicketSale,
            editionCfg.Dates?.Timezone,
            Clock.GetUtcNow());
    }
    catch
    {
        // Keep the fallback — the static literal renders below.
    }
}
<!DOCTYPE html>
@* lang reflects the negotiated UI culture (en) so a screen reader announces the
   copy with the correct pronunciation rules (WCAG 3.1.1). The date PICKER stays
   dd/mm/yyyy (Monday-first) via flatpickr; the value posted is ISO regardless. *@
<html lang="@langTag">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - @communityName</title>
    <style>
        /* Experts Live brand palette:
             --el-darkblue #1D3380  -- header background, headings
             --el-blue     #008BD2  -- accent, buttons, links
             --el-grey     #E3E3E3  -- page background / dividers   */
        :root {
            color-scheme: light;
            --el-darkblue: #1D3380;
            --el-blue:     #008BD2;
            --el-grey:     #E3E3E3;
        }
        body {
            font-family: system-ui, -apple-system, "Segoe UI", sans-serif;
            margin: 0; background: var(--el-grey); color: #1a1a2e;
            line-height: 1.5;
        }
        /* Visible keyboard focus on every interactive element (WCAG 2.4.7).
           :focus-visible keeps the ring for keyboard users without drawing it
           on mouse clicks, so the existing look is untouched for pointer use. */
        a:focus-visible, button:focus-visible, input:focus-visible,
        select:focus-visible, textarea:focus-visible, summary:focus-visible,
        [tabindex]:focus-visible {
            outline: 3px solid var(--el-blue);
            outline-offset: 2px;
            border-radius: 4px;
        }
        /* Skip-to-content link: off-screen until focused, then pinned top-left
           so a keyboard/screen-reader user can jump past the header + nav. */
        .skip-link {
            position: absolute; left: 8px; top: -48px;
            background: var(--el-darkblue); color: #fff;
            padding: 10px 16px; border-radius: 0 0 8px 8px;
            text-decoration: none; font-weight: 600; z-index: 1000;
            transition: top .15s ease;
        }
        .skip-link:focus { top: 0; color: #fff; }
        /* Screen-reader-only text: present in the accessibility tree, not on screen. */
        .visually-hidden {
            position: absolute !important; width: 1px; height: 1px;
            padding: 0; margin: -1px; overflow: hidden; clip: rect(0 0 0 0);
            white-space: nowrap; border: 0;
        }
        header {
            background: var(--el-darkblue); color: #fff;
            padding: 14px 20px;
            display: flex; align-items: center; gap: 20px;
            flex-wrap: wrap;
            border-bottom: 4px solid var(--el-blue);
            justify-content: center;     /* center the logo pair */
            position: relative;          /* user-tools floats right via abs pos */
        }
        /* Thin announcement bar above the logo header -- ticket-sale info
           + event-site button, visible to everyone (anonymous + logged-in). */
        .topbar {
            background: var(--el-blue); color: #fff;
            padding: 8px 20px;
            font-size: 13px;
            display: flex; align-items: center; justify-content: center;
            gap: 16px; flex-wrap: wrap; text-align: center;
        }
        .topbar .ticket-info { font-weight: 600; }
        /* When the ticket banner is a link (sale open + ticketUrl set) it uses
           the same .ticket-info class but is an <a>: keep it readable on the
           blue bar (white, underlined) instead of inheriting default link blue.
           No fixed height — the bar already wraps on ~360px via flex-wrap. */
        .topbar a.ticket-info { color: #fff; text-decoration: underline; }
        .topbar a.ticket-info:hover { text-decoration: none; }
        .topbar a.eventsite-btn {
            display: inline-block;
            background: #fff; color: var(--el-darkblue);
            padding: 4px 14px; border-radius: 999px;
            font-weight: 700; font-size: 12.5px;
            text-decoration: none; white-space: nowrap;
        }
        .topbar a.eventsite-btn:hover { background: var(--el-grey); }
        header .brand img { height: 56px; display: block; }
        header .product-mark {
            font-size: 30px; font-weight: 700; letter-spacing: .01em;
            color: #fff; white-space: nowrap;
        }
        header .titles { flex: 1 1 220px; min-width: 0; display: flex;
            align-items: baseline; gap: 16px; }
        header h1 { margin: 0; font-size: 22px; font-weight: 600;
            opacity: 1; white-space: nowrap; overflow: hidden;
            text-overflow: ellipsis; }
        header .user-tools { display: flex; align-items: center; gap: 10px;
            font-size: 13px; flex: 0 0 auto;
            position: absolute; right: 16px; top: 50%; transform: translateY(-50%); }
        header .user-tools .who { opacity: .85; white-space: nowrap; }
        @@media (max-width: 700px) {
            header .user-tools { flex-basis: 100%; margin-left: 0;
                justify-content: flex-end; }
        }
        header .user-tools form { margin: 0; }
        header .user-tools button.signout {
            background: transparent; color: #fff;
            border: 1px solid rgba(255,255,255,.6);
            padding: 6px 12px; border-radius: 6px; font-size: 13px;
        }
        header .user-tools button.signout:hover {
            background: rgba(255,255,255,.12);
        }
        nav.primary {
            background: #fff; border-bottom: 1px solid #d6d8e0;
            padding: 6px 24px; display: flex; flex-wrap: wrap; gap: 4px;
        }
        nav.primary a {
            display: inline-block; padding: 8px 14px; border-radius: 6px;
            text-decoration: none; color: var(--el-darkblue);
            font-size: 14px; font-weight: 500;
        }
        nav.primary a:hover { background: var(--el-grey); }
        nav.primary a.active,
        nav.primary a[aria-current="page"] { background: var(--el-darkblue); color: #fff; }
        /* Participant-nav named section (e.g. the speaker "Speaker" group): a
           native <details>/<summary> disclosure inside the primary bar so the
           long speaker nav is grouped, not one flat list. No JS, keyboard-
           operable. On desktop the panel floats under the toggle (like the
           organizer menu); on phone it flows inline full-width. */
        details.nav-section { position: relative; display: inline-block; }
        details.nav-section > summary {
            list-style: none; cursor: pointer; user-select: none;
            display: inline-flex; align-items: center; gap: 6px;
            padding: 8px 14px; border-radius: 6px;
            color: var(--el-darkblue); font-size: 14px; font-weight: 600;
        }
        details.nav-section > summary::-webkit-details-marker { display: none; }
        details.nav-section > summary:hover { background: var(--el-grey); }
        details.nav-section[open] > summary { background: var(--el-grey); }
        .nav-section-caret { transition: transform .15s ease; font-size: 11px; opacity: .7; }
        details.nav-section[open] .nav-section-caret { transform: rotate(180deg); }
        .nav-section-items {
            display: flex; flex-direction: column; gap: 2px;
            position: absolute; left: 0; top: calc(100% + 4px); z-index: 50;
            min-width: 220px; max-height: 70vh; overflow-y: auto;
            background: #fff; border: 1px solid #c4c8d4; border-radius: 8px;
            padding: 6px; box-shadow: 0 6px 18px rgba(0,0,0,.14);
        }
        .nav-section-items a {
            display: block; padding: 8px 12px; border-radius: 6px;
            text-decoration: none; color: var(--el-darkblue);
            font-size: 14px; font-weight: 500; white-space: nowrap;
        }
        .nav-section-items a:hover { background: var(--el-grey); }
        .nav-section-items a[aria-current="page"] { background: var(--el-darkblue); color: #fff; }
        @@media (max-width: 700px) {
            details.nav-section { display: block; }
            details.nav-section > summary { display: flex; justify-content: space-between; }
            .nav-section-items {
                position: static; min-width: 0; width: 100%;
                box-shadow: none; margin-top: 4px; max-height: none;
            }
        }
        /* Second-level management bar: a distinct strip below the participant
           nav so organizer tools read as a separate group, not mixed in. */
        nav.manage-bar {
            background: #eef0f6; border-bottom: 1px solid #d6d8e0;
            padding: 6px 24px;
        }
        /* Organizer-area dropdown (native <details>/<summary> — no JS). */
        details.org-menu { position: relative; display: inline-block; }
        details.org-menu > summary {
            list-style: none; cursor: pointer; user-select: none;
            display: inline-flex; align-items: center; gap: 6px;
            padding: 7px 14px; border-radius: 6px;
            color: var(--el-darkblue); font-size: 14px; font-weight: 600;
            background: #fff; border: 1px solid #c4c8d4;
        }
        details.org-menu > summary::-webkit-details-marker { display: none; }
        details.org-menu > summary:hover { background: var(--el-grey); }
        details.org-menu[open] > summary {
            background: var(--el-darkblue); color: #fff; border-color: var(--el-darkblue);
        }
        .org-menu-caret { transition: transform .15s ease; font-size: 11px; }
        details.org-menu[open] .org-menu-caret { transform: rotate(180deg); }
        /* Desktop: float the items as a panel under the toggle. */
        .org-menu-items {
            display: flex; flex-direction: column; gap: 2px;
            position: absolute; left: 0; top: calc(100% + 4px); z-index: 50;
            min-width: 220px; max-height: 70vh; overflow-y: auto;
            background: #fff; border: 1px solid #c4c8d4; border-radius: 8px;
            padding: 6px; box-shadow: 0 6px 18px rgba(0,0,0,.14);
        }
        .org-menu-items a {
            display: block; padding: 8px 12px; border-radius: 6px;
            text-decoration: none; color: var(--el-darkblue);
            font-size: 14px; font-weight: 500; white-space: nowrap;
        }
        .org-menu-items a:hover { background: var(--el-grey); }
        .org-menu-items a[aria-current="page"] { background: var(--el-darkblue); color: #fff; }
        /* REQUIREMENTS §21 — nested, collapsible section sub-groups inside the
           organizer menu (People / Sessions / Comms / Sponsors / Volunteers /
           Logistics). Native <details>/<summary>: no JS, keyboard-operable, a
           labelled disclosure per group. The leading prominent links (Organizer
           home / Command center / Dashboard) render before the first section, so a
           thin divider above the first section separates them. */
        .org-section { display: block; }
        .org-section + .org-section { margin-top: 2px; }
        .org-menu-items > .org-section:first-of-type {
            margin-top: 6px; padding-top: 6px; border-top: 1px solid #e1e3ec;
        }
        .org-section > summary {
            list-style: none; cursor: pointer; user-select: none;
            display: flex; align-items: center; justify-content: space-between;
            gap: 8px; padding: 7px 12px; border-radius: 6px;
            color: var(--el-darkblue); font-size: 12.5px; font-weight: 700;
            text-transform: uppercase; letter-spacing: .03em;
        }
        .org-section > summary::-webkit-details-marker { display: none; }
        .org-section > summary:hover { background: var(--el-grey); }
        .org-section-caret { transition: transform .15s ease; font-size: 10px; opacity: .7; }
        .org-section[open] > summary > .org-section-caret { transform: rotate(180deg); }
        /* Section links sit slightly indented so they read as children of the
           group heading above them. */
        .org-section-items { display: flex; flex-direction: column; gap: 2px; padding-left: 8px; }
        .org-section-items a {
            display: block; padding: 8px 12px; border-radius: 6px;
            text-decoration: none; color: var(--el-darkblue);
            font-size: 14px; font-weight: 500; white-space: nowrap;
        }
        .org-section-items a:hover { background: var(--el-grey); }
        .org-section-items a[aria-current="page"] { background: var(--el-darkblue); color: #fff; }
        /* Mobile (~360px): the toggle spans the bar and the panel flows inline
           (static, full width) so the long admin list scrolls with the page
           instead of overflowing a fixed dropdown off the small viewport. */
        @@media (max-width: 700px) {
            details.org-menu { display: block; }
            details.org-menu > summary { display: flex; justify-content: space-between; }
            .org-menu-items {
                position: static; min-width: 0; width: 100%;
                box-shadow: none; margin-top: 4px; max-height: none;
            }
        }
        main { max-width: 880px; margin: 24px auto; padding: 0 16px; }
        .card {
            background: #fff; border-radius: 10px;
            padding: 20px; margin-bottom: 16px;
            box-shadow: 0 1px 3px rgba(0,0,0,.08);
        }
        .card h2 { margin-top: 0; font-size: 22px; font-weight: 700; color: var(--el-darkblue); }
        /* Shared organizer hub button-grid (operator 2026-06-21): the hub landing
           pages fan out to their feature pages as a responsive grid of link-tiles,
           replacing the old one-per-feature card stacks. One definition, every hub. */
        .hub-grid { display: grid; grid-template-columns: 1fr; gap: 12px; margin: 4px 0 8px; }
        @@media (min-width: 560px) { .hub-grid { grid-template-columns: repeat(auto-fit, minmax(230px, 1fr)); } }
        a.hub-tile { display: flex; flex-direction: column; text-decoration: none; color: inherit;
            border: 1px solid #e6e8ee; background: #f7f8fa; border-radius: 10px; padding: 14px 16px;
            transition: box-shadow .12s ease, transform .12s ease, border-color .12s ease; }
        a.hub-tile:hover, a.hub-tile:focus-visible {
            box-shadow: 0 2px 10px rgba(0,0,0,.12); transform: translateY(-1px);
            border-color: var(--el-blue, #008BD2); outline: none; }
        a.hub-tile .hub-tile-title { font-size: 15.5px; font-weight: 700; color: var(--el-darkblue, #1D3380); }
        a.hub-tile .hub-tile-desc { font-size: 12.5px; color: #4b5563; margin-top: 4px; line-height: 1.4; }
        a.hub-tile .hub-tile-go { font-size: 12px; font-weight: 600; color: var(--el-blue, #008BD2); margin-top: 10px; }
        /* Ring badge — yellow "Ring N" pill next to a feature still in staged
           rollout (not yet Broad/GA). Promoted from /Organizer/Settings so nav +
           tiles render the identical marker. */
        .set-tag { display:inline-block; font-size:10.5px; line-height:1; padding:2px 6px;
            border-radius:999px; margin-left:6px; vertical-align:middle; }
        .set-tag.ring { background:#fef9c3; color:#854d0e; border:1px solid #fde047; font-weight:600; }
        .info { color: #0a6; }
        .error { color: #c0392b; }
        button, input[type=submit] {
            background: var(--el-blue); color: #fff; border: 0;
            padding: 9px 16px; border-radius: 7px;
            font-size: 15px; cursor: pointer;
        }
        button:hover, input[type=submit]:hover { background: var(--el-darkblue); }
        /* Secondary button is a darker grey than the page bg so it stays
           visible even on cards/pages that sit directly on the body. */
        button.secondary { background: #c4c8d4; color: var(--el-darkblue); }
        button.secondary:hover { background: #aab0c0; }
        input[type=email], input[type=text], input[type=number],
        input[type=date], input[type=tel], input[type=url],
        select, textarea {
            display: block; width: 100%; max-width: 360px;
            padding: 8px; margin: 6px 0 14px;
            border: 1px solid #c4c8d4; border-radius: 6px;
            font-size: 15px; box-sizing: border-box;
        }
        /* Each label sits on its own line so it labels the input BELOW it,
           not the input to the LEFT of it. Form-rows that want side-by-side
           (e.g. checkbox + text) override with their own display:flex.       */
        label { font-weight: 600; font-size: 14px;
            display: block; margin-top: 10px; }
        a { color: var(--el-blue); }
        a:hover { color: var(--el-darkblue); }
        /* URL / email auto-buttons rendered inside task descriptions.
           Sized to match the form action buttons (Mark complete, etc.) so
           the click target is the same and inline buttons read as primary
           actions rather than tiny inline pills. */
        a.task-link-btn {
            display: inline-block;
            background: var(--el-blue);
            color: #fff !important;
            padding: 8px 18px;
            border-radius: 6px;
            text-decoration: none;
            font-size: 14px;
            font-weight: 600;
            margin: 4px 4px;
            word-break: break-all;
            line-height: 1.2;
        }
        a.task-link-btn:hover {
            background: var(--el-darkblue);
            color: #fff !important;
        }
        footer { max-width: 880px; margin: 24px auto; padding: 0 16px;
            font-size: 12px; color: #6b7280; }
        /* Visually hidden but available to screen readers. */
        .sr-only { position: absolute; width: 1px; height: 1px; padding: 0;
            margin: -1px; overflow: hidden; clip: rect(0,0,0,0);
            white-space: nowrap; border: 0; }

        /* ============================================================
           SHARED UX COMPONENTS (REQUIREMENTS §21) — reusable repo-wide
           1. Flash toast  (_Flash.cshtml)
           2. Field validation  (asp-validation-for / .ceh-field-error)
           3. Confirmation modal  (_ConfirmModal.cshtml)
           ============================================================ */

        /* 1. Flash toast — success/error banner after a POST. Mobile-first:
              full-width, wraps at ~360px, large tap targets. */
        .ceh-flash {
            display: flex; align-items: flex-start; gap: 10px;
            padding: 12px 14px; border-radius: 8px; margin: 0 0 16px;
            font-size: 14.5px; line-height: 1.4; border: 1px solid transparent;
        }
        .ceh-flash--success {
            background: #e7f6ec; border-color: #b6e0c4; color: #1b5e34;
        }
        .ceh-flash--error {
            background: #fcebec; border-color: #f3c2c6; color: #8a1f28;
        }
        .ceh-flash--info {
            background: #eaf1fb; border-color: #c2d4f3; color: #1f3f6b;
        }
        .ceh-flash__icon { font-weight: 700; flex: 0 0 auto; font-size: 16px; line-height: 1.3; }
        .ceh-flash__text { flex: 1 1 auto; min-width: 0; }
        .ceh-flash__close {
            flex: 0 0 auto; background: transparent; color: inherit;
            border: 0; font-size: 22px; line-height: 1; cursor: pointer;
            padding: 0 4px; min-width: 32px; min-height: 32px; border-radius: 6px;
        }
        .ceh-flash__close:hover { background: rgba(0,0,0,.08); }

        /* 2. Inline form validation — field-level error message + an invalid
              field outline. Works with the tag helpers (asp-validation-for /
              asp-validation-summary) which emit .field-validation-error /
              .input-validation-error, and with manual .ceh-field-error spans. */
        .ceh-field-error,
        .field-validation-error {
            display: block;
            color: #8a1f28; font-size: 13px; font-weight: 600;
            margin: -8px 0 12px;
        }
        /* Show a field-error span ONLY when it actually carries an error. The static
           .ceh-field-error class is present on every field, so without this a fresh
           form rendered a stray "⚠" + reserved space under every input. MVC marks a
           valid span .field-validation-valid (and leaves it empty); a manual
           .ceh-field-error with no message is :empty -- hide both. */
        .ceh-field-error:empty,
        span.field-validation-valid { display: none; }
        .ceh-field-error::before,
        .field-validation-error::before { content: "⚠ "; }
        /* Red outline on the offending input (tag-helper adds the class). */
        input.input-validation-error, select.input-validation-error,
        textarea.input-validation-error, .ceh-input-invalid {
            border-color: #c0392b !important;
            outline-color: #c0392b;
        }
        /* Error summary box at the top of a form. */
        .ceh-validation-summary {
            background: #fcebec; border: 1px solid #f3c2c6; color: #8a1f28;
            padding: 10px 14px; border-radius: 8px; margin: 0 0 16px; font-size: 14px;
        }
        .ceh-validation-summary ul { margin: 6px 0 0; padding-left: 20px; }
        .ceh-validation-summary p { margin: 0; font-weight: 700; }
        /* Hide the summary when there is NOTHING to show. :empty alone is not enough --
           asp-validation-summary renders an empty inner <ul> when valid, so the div is
           never truly :empty and the red bar showed on a fresh form. MVC adds
           .validation-summary-valid when there are no errors -- key off that. */
        .ceh-validation-summary:empty,
        .ceh-validation-summary.validation-summary-valid { display: none; }

        /* 3. Confirmation modal — accessible dialog for destructive/bulk/send
              actions. Centred overlay, scrolls on small screens, focus-trapped
              by the shared JS. */
        .ceh-modal-backdrop {
            position: fixed; inset: 0; background: rgba(15,18,40,.55);
            display: none; align-items: center; justify-content: center;
            padding: 16px; z-index: 2000;
        }
        .ceh-modal-backdrop[data-open] { display: flex; }

        /* Page-level confirm/bulk dialogs (Participants grid etc.) mark their
           fixed-position backdrop with .modal-backdrop and toggle the [hidden]
           attribute to open/close. Those backdrops carry an inline display:flex,
           which on its own OVERRIDES the UA [hidden]{display:none} rule — so a
           "closed" backdrop stayed display:flex over the whole viewport and
           swallowed clicks behind it (it intercepted "Switch to user" on the
           ~360px iPhone SE layout). Force a hidden backdrop fully inert here so
           the fix is GLOBAL to every .modal-backdrop, not per-modal: !important
           beats the inline display, and pointer-events:none is a belt-and-braces
           guard. Desktop is unaffected — an OPEN modal has [hidden] removed. */
        .modal-backdrop[hidden] { display: none !important; pointer-events: none; }
        .ceh-modal {
            background: #fff; border-radius: 12px; max-width: 460px; width: 100%;
            max-height: calc(100vh - 32px); overflow-y: auto;
            box-shadow: 0 12px 40px rgba(0,0,0,.3); padding: 22px 22px 18px;
        }
        .ceh-modal h2 { margin: 0 0 10px; font-size: 19px; color: var(--el-darkblue); }
        .ceh-modal__body { font-size: 14.5px; line-height: 1.5; color: #1a1a2e; }
        .ceh-modal__count {
            display: inline-block; font-weight: 700; background: var(--el-grey);
            color: var(--el-darkblue); padding: 2px 10px; border-radius: 999px;
        }
        .ceh-modal__actions {
            display: flex; flex-wrap: wrap; gap: 10px; justify-content: flex-end;
            margin-top: 20px;
        }
        .ceh-modal__actions button { min-width: 110px; }
        .ceh-modal--danger .ceh-modal__confirm { background: #c0392b; }
        .ceh-modal--danger .ceh-modal__confirm:hover { background: #962d22; }
        @@media (max-width: 480px) {
            .ceh-modal__actions { flex-direction: column-reverse; }
            .ceh-modal__actions button { width: 100%; }
        }
        /* ---- Micro-polish (REQUIREMENTS §21 Participant [L]) -----------------
           Live character counter shown under a maxlength field; the "near limit"
           state warns before the cap is hit. A copy button's transient "copied"
           confirmation. A form whose submit is in flight dims + shows it is busy.
           Mobile-first: the counter is a small, wrapping block under the field. */
        .ceh-counter {
            display: block; margin-top: 4px; font-size: 12px; color: #6b7280;
            text-align: right;
        }
        .ceh-counter--near { color: #b45309; font-weight: 600; }
        .ceh-copied { color: #15803d; font-weight: 600; }
        form.ceh-submitting { opacity: .7; }
        button.ceh-busy, input.ceh-busy { cursor: progress; }

        /* ---- Breadcrumb (REQUIREMENTS §21 cross-cutting) --------------------
           The organizer back-office ancestor trail (Organizer area / Hub /
           Page). Sits at the top of the content area. Mobile-first: the list
           wraps at ~360px and the links keep a comfortable tap target. */
        .ceh-breadcrumb { margin: 0 0 14px; font-size: 13.5px; }
        .ceh-breadcrumb ol {
            list-style: none; margin: 0; padding: 0;
            display: flex; flex-wrap: wrap; align-items: center; gap: 2px 0;
        }
        .ceh-breadcrumb li { display: inline-flex; align-items: center; }
        .ceh-breadcrumb a {
            display: inline-block; padding: 3px 6px; border-radius: 5px;
            text-decoration: none; color: var(--el-blue);
        }
        .ceh-breadcrumb a:hover { background: #fff; color: var(--el-darkblue); }
        .ceh-breadcrumb__sep { color: #9aa0b0; padding: 0 4px; }
        .ceh-breadcrumb [aria-current="page"] {
            color: #4b5161; font-weight: 600; padding: 3px 6px;
        }

        /* ---- Grid loading skeleton (REQUIREMENTS §21 cross-cutting) ----------
           Async loading/skeleton states for the data-heavy organizer grids. When
           a grid's filter form submits, or a sort/page link inside the grid is
           followed, the whole-page GET takes a moment to come back. While that
           navigation is in flight the grid is given data-ceh-grid-busy: it dims
           the stale rows and lays an animated shimmer "skeleton" over them so the
           portal never looks frozen. Pure progressive enhancement — with JS off
           the page just navigates as before. Mobile-first: the overlay tracks the
           grid wrapper at any width and the shimmer bars are fluid. */
        .ceh-grid { position: relative; }
        .ceh-grid[data-ceh-grid-busy] > * { opacity: .45; transition: opacity .15s ease; }
        .ceh-grid__skeleton {
            position: absolute; inset: 0; display: none;
            padding: 8px; box-sizing: border-box;
            background: rgba(255, 255, 255, .55);
            z-index: 2; pointer-events: none;
        }
        .ceh-grid[data-ceh-grid-busy] .ceh-grid__skeleton { display: block; }
        .ceh-grid__bar {
            height: 18px; margin: 0 0 12px; border-radius: 6px;
            background: linear-gradient(90deg, #e9ecf2 25%, #f4f6fa 37%, #e9ecf2 63%);
            background-size: 400% 100%;
            animation: ceh-shimmer 1.2s ease-in-out infinite;
        }
        .ceh-grid__bar:nth-child(odd) { width: 92%; }
        .ceh-grid__bar:nth-child(even) { width: 74%; }
        @@keyframes ceh-shimmer {
            0% { background-position: 100% 0; }
            100% { background-position: 0 0; }
        }
        /* Respect a reduced-motion preference: keep the dim + overlay (the "busy"
           signal) but drop the shimmer animation entirely. */
        @@media (prefers-reduced-motion: reduce) {
            .ceh-grid__bar { animation: none; background: #e9ecf2; }
            .ceh-grid[data-ceh-grid-busy] > * { transition: none; }
        }
    </style>
    <!-- Danish-locale date picker (Monday-first, dd/mm/yyyy).
         Browser-native <input type="date"> ignores html lang and uses OS locale,
         so we replace every date input with flatpickr forced to da. -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr@4.6.13/dist/flatpickr.min.css">
    <script defer src="https://cdn.jsdelivr.net/npm/flatpickr@4.6.13/dist/flatpickr.min.js"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/flatpickr@4.6.13/dist/l10n/da.js"></script>
    <script defer>
        document.addEventListener('DOMContentLoaded', function () {
            if (typeof flatpickr === 'undefined') return;
            flatpickr.localize(flatpickr.l10ns.da);
            document.querySelectorAll('input[type="date"]').forEach(function (el) {
                // altInput=true: flatpickr hides the original, shows a sibling
                // input formatted dd/mm/yyyy (Danish), while the hidden one
                // keeps the ISO yyyy-mm-dd value that DateOnly parses on POST.
                flatpickr(el, {
                    locale:     'da',
                    dateFormat: 'Y-m-d',   // value posted to server (hidden)
                    altInput:   true,
                    altFormat:  'd/m/Y',   // value shown to user (visible)
                    allowInput: true
                });
            });
        });
    </script>
</head>
<body>
    <a class="skip-link" href="#main">@Localizer["Layout.SkipToContent"]</a>
    <div class="topbar">
        @* Ticket banner: config-driven (event.<edition>.json -> ticketSale).
           - Suppressed  => render nothing (sale open + afterOpen=hide).
           - Visible+Href => a link to the public ticket page (sale open).
           - Visible      => plain config text (before the sale opens).
           - otherwise    => the static resx literal (config absent/disabled). *@
        @if (ticketBanner.Suppressed)
        {
            // Intentionally empty — only the event-site button shows.
        }
        else if (ticketBanner.Visible && !string.IsNullOrEmpty(ticketBanner.Href))
        {
            <a class="ticket-info" href="@ticketBanner.Href" target="_blank" rel="noopener">@ticketBanner.Message &rarr;<span class="visually-hidden">@Localizer["Common.OpensNewTab"]</span></a>
        }
        else if (ticketBanner.Visible)
        {
            <span class="ticket-info">@ticketBanner.Message</span>
        }
        else
        {
            <span class="ticket-info">@Localizer["Layout.TicketInfo"]</span>
        }
        <a class="eventsite-btn" href="https://eldk27.expertslive.dk/" target="_blank" rel="noopener">@Localizer["Layout.VisitEventSite"] &rarr;<span class="visually-hidden">@Localizer["Common.OpensNewTab"]</span></a>
    </div>
    <header>
        <a class="brand" href="/" aria-label="@communityName">
            <img src="~/img/logo-experts-live-denmark-white.png" alt="Experts Live Denmark" style="height:48px; display:block;" />
        </a>
        <a class="brand" href="/" aria-label="ELDK27 event logo" style="background:#fff; padding:6px 8px; border-radius:8px;">
            <img src="~/img/logo-eldk27-event.png" alt="ELDK27" style="height:48px; display:block;" />
        </a>
        @if (isLoggedIn)
        {
            <div class="user-tools">
                <span class="who">@me!.FullName &middot; @CommunityHub.Branding.RoleDisplay.Name(role!.Value)</span>
                <form method="post" asp-page="/Logout">
                    <button type="submit" class="signout">@Localizer["Common.SignOut"]</button>
                </form>
            </div>
        }
    </header>
    @{
        // Mark the nav entry that matches the page being viewed so screen
        // readers announce "current page" (WCAG 2.4.8 / aria-current). Matched
        // on the request path; "/" only counts as current for the exact root.
        var currentPath = (Context.Request.Path.Value ?? "/").TrimEnd('/');
        if (string.IsNullOrEmpty(currentPath)) { currentPath = "/"; }
        Func<string, string?> ariaCurrent = href =>
        {
            var h = href.TrimEnd('/');
            if (string.IsNullOrEmpty(h)) { h = "/"; }
            var match = h == "/"
                ? currentPath == "/"
                : currentPath.Equals(h, StringComparison.OrdinalIgnoreCase);
            return match ? "page" : null;
        };
    }
    @{
        // Resolve a NavItem's visible label: a resx key when present (so the
        // i18n pass owns the copy), else the literal fallback. Keeps i18n in the
        // view while the route/grouping/gating decision lives in Core.NavBuilder.
        Func<NavItem, Microsoft.AspNetCore.Html.IHtmlContent> navLabel = item =>
            item.LabelKey is not null
                ? Localizer[item.LabelKey]
                : new Microsoft.AspNetCore.Html.HtmlString(
                      System.Net.WebUtility.HtmlEncode(item.FallbackLabel ?? item.Href));
        // Standalone pages (sign-in, magic-link, survey, etc.) opt OUT of the public
        // event nav bar via ViewData["HidePublicNav"]=true — that nav is for the public
        // SITE sections and does not belong on a bare auth/form page.
        var hidePublicNav = ViewData["HidePublicNav"] as bool? ?? false;
    }
    @if (isLoggedIn)
    {
        @* Two clearly separated, role-gated nav groups (REQUIREMENTS §11 nav/IA):
             1. the participant / "My event" group — always visible;
             2. the organizer / "Organizer area" group — emitted by NavBuilder
                ONLY for an Organizer, so a non-organizer never receives the
                management links at all (server-side gate, not a CSS hide).
           NavBuilder is unit-tested (NavBuilderTests). *@
        // Show the volunteer "Supervisor" dashboard item only to real supervisors
        // (a cheap indexed check, run for volunteers only).
        var isVolunteerSupervisor = false;
        if (role == CommunityHub.Core.Domain.ParticipantRole.Volunteer && me is not null)
        {
            isVolunteerSupervisor = await VolunteerStructure.IsSupervisorAsync(me.EventId, me.ParticipantId);
        }
        var nav = NavBuilder.Build(role!.Value, isVolunteerSupervisor);
        var participant = nav.Groups[0];
        var management = nav.ManagementGroup;

        // Ring scope (org-managed via /Organizer/Settings): each feature carries an
        // Enabled flag + a released ring. For nav items tagged with a FeatureKey:
        //   • the ORG turns it OFF (Enabled=false) -> hidden for everyone;
        //   • the ORG assigns its ring -> impact is SCOPED to users at that ring AND
        //     LOWER (a user above the ring doesn't see it), and a yellow "Ring N"
        //     pill marks it while it is not yet Broad/GA so a ring tester sees what's
        //     scoped to them. Resolved once per request; best-effort (never 500 nav).
        var featureMap = new Dictionary<string, CommunityHub.Core.Settings.FeatureState>(StringComparer.Ordinal);
        var userRing = CommunityHub.Core.Settings.Rings.Default;
        if (me is not null)
        {
            try
            {
                userRing = await RingResolver.GetEffectiveRingAsync(me.ParticipantId);
                foreach (var fs in await FeatureSettings.GetAllAsync(me.EventId))
                    featureMap[fs.Key] = fs;
            }
            catch { /* badges/gating are best-effort; never 500 the nav */ }
        }
        // Share the resolved ring data with _HubGrid (organizer hub tiles) so it
        // badges + gates the SAME way without re-querying. Read back as
        // (Dictionary<string,FeatureState>, Ring) in the partial.
        ViewData["RingFeatureMap"] = featureMap;
        ViewData["RingUserRing"] = userRing;
        // Hidden when the org disabled the feature, OR the user's ring is above the
        // feature's released ring (out of scope).
        // Only RING-SCOPED surfaces (Queue + User-impact) are GUI ring-scoped; Engine
        // / EngineQueued (plumbing) are never hidden/badged in the nav even if tagged.
        Func<CommunityHub.Core.Navigation.NavItem, bool> ringHidden = it =>
            it.FeatureKey is not null
            && featureMap.TryGetValue(it.FeatureKey, out var fs)
            && fs.Descriptor.IsRingScoped
            && (!fs.Enabled
                || !CommunityHub.Core.Settings.Rings.IsActiveForRing(userRing, fs.ReleasedToRing));
        // Badge the feature's ring while enabled + not yet Broad/GA.
        Func<CommunityHub.Core.Navigation.NavItem, CommunityHub.Core.Settings.Ring?> ringBadgeOf = it =>
            it.FeatureKey is not null
            && featureMap.TryGetValue(it.FeatureKey, out var fs)
            && fs.Descriptor.IsRingScoped
            && fs.Enabled
            && fs.ReleasedToRing != CommunityHub.Core.Settings.Ring.Broad
                ? fs.ReleasedToRing : (CommunityHub.Core.Settings.Ring?)null;

        // FEATURE B: hide a self-service FORM link unless the participant is ENTITLED
        // to the matching OrderItem — the same entitlement rule the form's own gate
        // applies (OrderEntitlements as the single source of truth). Non-speaker roles
        // keep their historical links; only speakers are entitlement-gated, so a
        // sponsor-self-funded speaker loses Hotel/Travel/Swag but keeps Lunch/Dinner.
        // Resolved ONCE per request; best-effort (never 500 the nav).
        var entitledItems = new HashSet<CommunityHub.Core.Domain.OrderItem>();
        if (me is not null)
        {
            try
            {
                entitledItems = new HashSet<CommunityHub.Core.Domain.OrderItem>(
                    await CommunityHub.Forms.FormEntitlementGate.EffectiveItemsAsync(
                        Db, me.EventId, me.ParticipantId, default));
            }
            catch { /* entitlement gating is best-effort; never 500 the nav */ }
        }
        var isSpeakerRole = role == CommunityHub.Core.Domain.ParticipantRole.Speaker;
        // Map a form href → the OrderItem(s) that entitle it. A link is hidden only
        // for SPEAKERS who lack the entitlement; every other role keeps its link.
        Func<CommunityHub.Core.Navigation.NavItem, bool> formEntitlementHidden = it =>
        {
            if (!isSpeakerRole) { return false; }
            var href = (it.Href ?? string.Empty).TrimEnd('/');
            bool Has(params CommunityHub.Core.Domain.OrderItem[] items) => items.Any(entitledItems.Contains);
            return href switch
            {
                "/Forms/Hotel"  => !Has(CommunityHub.Core.Domain.OrderItem.Hotel),
                "/Forms/Travel" => !Has(CommunityHub.Core.Domain.OrderItem.TravelReimbursement),
                "/Forms/Swag"   => !Has(CommunityHub.Core.Domain.OrderItem.Swag, CommunityHub.Core.Domain.OrderItem.Polo),
                "/Forms/Lunch"  => !Has(CommunityHub.Core.Domain.OrderItem.LunchPreDay, CommunityHub.Core.Domain.OrderItem.LunchMainDay),
                "/Forms/Dinner" => !Has(CommunityHub.Core.Domain.OrderItem.AppreciationDinner),
                _ => false,
            };
        };
        // Combined nav-item hide: ring scope OR (Feature B) form entitlement.
        Func<CommunityHub.Core.Navigation.NavItem, bool> navHidden = it =>
            ringHidden(it) || formEntitlementHidden(it);
        <nav class="primary" aria-label="@Localizer["Nav.MyEvent"]">
            @* Render the participant group by SECTION (mirrors the management
               bar). Items with no SectionKey collapse into the leading
               null-heading bucket and render as plain links exactly as before —
               so non-speaker roles are visually unchanged. Speaker-specific items
               carry SectionKey "Nav.SectionSpeaker" (NavBuilder) and render under
               a named, collapsible "Speaker" disclosure so the long speaker nav is
               grouped, not one flat list. Pure IA; NavBuilder owns the grouping
               and NavBuilderTests assert no route is dropped. *@
            @foreach (var section in participant.Sections())
            {
                if (section.HeadingKey is null)
                {
                    foreach (var item in section.Items)
                    {
                        if (navHidden(item)) { continue; }
                        var rb = ringBadgeOf(item);
                        <a href="@item.Href" target="@(item.External ? "_blank" : null)" rel="@(item.External ? "noopener noreferrer" : null)" aria-current="@ariaCurrent(item.Href)">@navLabel(item)@if (rb is not null) {<span class="set-tag ring" title="@Localizer["Settings.RingBadgeTitle"]">@CommunityHub.Core.Settings.Rings.Label(rb.Value)</span>}@if (item.External) {<span class="visually-hidden">@Localizer["Common.OpensNewTab"]</span>}</a>
                    }
                }
                else
                {
                    var visible = section.Items.Where(i => !navHidden(i)).ToList();
                    if (visible.Count == 0) { continue; }   // whole fold-out gated out
                    var sectionOpen = visible.Any(i => ariaCurrent(i.Href) == "page");
                    <details class="nav-section" open="@(sectionOpen ? "open" : null)">
                        <summary>
                            <span class="nav-section-label">@Localizer[section.HeadingKey]</span>
                            <span class="nav-section-caret" aria-hidden="true">&#9662;</span>
                        </summary>
                        <div class="nav-section-items">
                            @foreach (var item in visible)
                            {
                                var rb = ringBadgeOf(item);
                                <a href="@item.Href" target="@(item.External ? "_blank" : null)" rel="@(item.External ? "noopener noreferrer" : null)" aria-current="@ariaCurrent(item.Href)">@navLabel(item)@if (rb is not null) {<span class="set-tag ring" title="@Localizer["Settings.RingBadgeTitle"]">@CommunityHub.Core.Settings.Rings.Label(rb.Value)</span>}@if (item.External) {<span class="visually-hidden">@Localizer["Common.OpensNewTab"]</span>}</a>
                            }
                        </div>
                    </details>
                }
            }
        </nav>
        @if (management is not null)
        {
            @* Organizer/management group as a collapsible disclosure. <details>/
               <summary> gives a working dropdown with NO JavaScript, native
               aria-expanded, and keyboard operability; it collapses to a single
               control on ~360px so the long admin list never floods the phone
               nav. A distinct second-level bar visually separates management
               tools from the participant nav above. *@
            <nav class="manage-bar" aria-label="@Localizer["Nav.OrgAreaMenu"]">
                <details class="org-menu">
                    <summary aria-label="@Localizer["Nav.OrgAreaMenuToggle"]">
                        <span class="org-menu-label">@Localizer["Nav.OrgAreaMenu"]</span>
                        <span class="org-menu-caret" aria-hidden="true">&#9662;</span>
                    </summary>
                    @* REQUIREMENTS §21 "Group the organizer nav": the management
                       hubs are bucketed into named, collapsible sub-groups
                       (People / Sessions / Comms / Sponsors / Volunteers /
                       Logistics) instead of one flat list, so the menu is
                       scannable. Each section is a nested native <details> (no JS,
                       keyboard-operable, aria via summary). The leading
                       null-heading section (Organizer home / Command center /
                       Dashboard) renders as plain prominent links with no
                       disclosure. Every existing route is still present — this is
                       pure information architecture (NavBuilder owns the grouping;
                       NavBuilderTests assert no link is dropped). A section that
                       contains the current page is rendered open so aria-current is
                       visible without a click. *@
                    <div class="org-menu-items">
                        @foreach (var section in management.Sections())
                        {
                            if (section.HeadingKey is null)
                            {
                                @* Prominent, ungrouped entries — no disclosure. *@
                                foreach (var item in section.Items)
                                {
                                    <a href="@item.Href" aria-current="@ariaCurrent(item.Href)">@navLabel(item)</a>
                                }
                            }
                            else
                            {
                                @* Render every section OPEN by default: opening the
                                   "Organizer area" dropdown then showed each section
                                   still collapsed, so reaching a link took TWO expands
                                   (dropdown + section). Open sections mean one expand
                                   reveals all links; the carets still collapse them.
                                   (operator 2026-06-20) *@
                                <details class="org-section" open="open">
                                    <summary>
                                        <span class="org-section-label">@Localizer[section.HeadingKey]</span>
                                        <span class="org-section-caret" aria-hidden="true">&#9662;</span>
                                    </summary>
                                    <div class="org-section-items">
                                        @foreach (var item in section.Items)
                                        {
                                            <a href="@item.Href" aria-current="@ariaCurrent(item.Href)">@navLabel(item)</a>
                                        }
                                    </div>
                                </details>
                            }
                        }
                    </div>
                </details>
            </nav>
        }
    }
    else if (!hidePublicNav)
    {
        @* Public nav for anonymous visitors — the public site sections are all
           reachable without signing in (next to the Login entry in the topbar).
           REQUIREMENTS §21: complete the public nav (Agenda + master classes +
           Contributors) so no public page is an orphan. "Master classes" deep-links
           to the Sessions list pre-filtered to the master-class type (a real,
           URL-persisted filter — no separate index page needed). *@
        <nav class="primary" aria-label="@Localizer["Nav.Primary"]">
            <a href="/Agenda" aria-current="@ariaCurrent("/Agenda")">@Localizer["Nav.Agenda"]</a>
            <a href="/Sessions" aria-current="@ariaCurrent("/Sessions")">@Localizer["Nav.Sessions"]</a>
            <a href="/Sessions?FilterType=MasterClass">@Localizer["Nav.MasterClasses"]</a>
            <a href="/Speakers" aria-current="@ariaCurrent("/Speakers")">@Localizer["Nav.Speakers"]</a>
            <a href="/Sponsors" aria-current="@ariaCurrent("/Sponsors")">@Localizer["Nav.Sponsors"]</a>
            <a href="/Contributors" aria-current="@ariaCurrent("/Contributors")">@Localizer["Nav.Contributors"]</a>
        </nav>
    }
    @if (me is not null && me.IsActingAs)
    {
        @* Acting-as banner: unmistakable that this is an organizer/secretary
           operating ON BEHALF of someone, with a one-click way back. role=alert
           so assistive tech announces the elevated context immediately. *@
        <div role="alert"
             style="background:#fde68a;color:#7c2d12;border-bottom:2px solid #b45309;
                    padding:10px 16px;display:flex;flex-wrap:wrap;gap:10px;align-items:center;
                    justify-content:space-between;font-weight:600;">
            <span>
                @if (me.ActingAs!.Kind == CommunityHub.Core.Domain.ImpersonationActorKind.SecretaryToken)
                {
                    <text>Secure-link mode — you are filling in tasks on behalf of <strong>@me.FullName</strong>. Your access is limited to this person.</text>
                }
                else
                {
                    <text>You are acting as <strong>@me.FullName</strong> (started by @me.ActingAs!.ActorLabel). Changes you make are on this person's behalf.</text>
                }
            </span>
            @if (me.ActingAs!.Kind == CommunityHub.Core.Domain.ImpersonationActorKind.Organizer)
            {
                <form method="post" asp-page="/Organizer/ReturnToOrganizer" style="margin:0;">
                    <button type="submit" class="secondary">Return to organizer</button>
                </form>
            }
        </div>
    }
    <main id="main" tabindex="-1">
        @* Organizer back-office breadcrumb trail (REQUIREMENTS §21). The partial
           renders nothing for non-organizer / root / unknown paths, so it is safe
           here for every page. *@
        <partial name="_Breadcrumb" />
        @RenderBody()
    </main>
    <footer style="text-align:center;">
        <div>
            @ProductName (@ProductShortName) &mdash; @Localizer["Layout.FooterBuiltBy"]
            <a href="https://aka.ms/morten" target="_blank" rel="noopener">Morten Knudsen<span class="visually-hidden">@Localizer["Common.OpensNewTab"]</span></a>
            &middot; @Localizer["Layout.FooterFree"]
        </div>
        <div style="margin-top:4px;">
            <a href="https://github.com/KnudsenMorten/community-event-hub" target="_blank" rel="noopener">@Localizer["Layout.GitHub"]<span class="visually-hidden">@Localizer["Common.OpensNewTab"]</span></a>
            &middot;
            <a href="https://github.com/KnudsenMorten/community-event-hub/issues" target="_blank" rel="noopener">@Localizer["Layout.SubmitBug"]<span class="visually-hidden">@Localizer["Common.OpensNewTab"]</span></a>
            &middot;
            <a asp-page="/Contributors">@Localizer["Layout.Contributors"]</a>
        </div>
    </footer>
    @* ----------------------------------------------------------------------
       Shared UX component behaviour (REQUIREMENTS §21). Progressive
       enhancement only: with JS disabled the flash stays visible and the
       confirm modal falls back to a native confirm() (see _ConfirmModal).
       ---------------------------------------------------------------------- *@
    <script defer>
    (function () {
        // ---- 1. Flash toast: auto-dismiss (success) + close button ----------
        function dismissFlash(el) {
            if (!el) return;
            el.style.transition = 'opacity .25s ease';
            el.style.opacity = '0';
            setTimeout(function () { el.remove(); }, 260);
        }
        document.querySelectorAll('[data-ceh-flash]').forEach(function (flash) {
            var btn = flash.querySelector('[data-ceh-flash-close]');
            if (btn) btn.addEventListener('click', function () { dismissFlash(flash); });
            var ms = parseInt(flash.getAttribute('data-autodismiss') || '0', 10);
            if (ms > 0) setTimeout(function () { dismissFlash(flash); }, ms);
        });

        // ---- 3. Confirmation modal: open/close + focus trap (role=dialog) ----
        // A reusable accessible modal. Any element with
        //   data-ceh-confirm="<modalId>"
        // becomes a trigger: clicking it opens the modal instead of performing
        // its action, and the modal's Confirm button replays the original action
        // (submitting the trigger's form, or following its href).
        var FOCUSABLE = 'a[href],button:not([disabled]),input:not([disabled]),' +
                        'select:not([disabled]),textarea:not([disabled]),[tabindex]:not([tabindex="-1"])';
        var openModal = null, lastFocused = null;

        function trapFocus(e) {
            if (!openModal || e.key !== 'Tab') return;
            var nodes = openModal.querySelectorAll(FOCUSABLE);
            if (!nodes.length) return;
            var first = nodes[0], last = nodes[nodes.length - 1];
            if (e.shiftKey && document.activeElement === first) { last.focus(); e.preventDefault(); }
            else if (!e.shiftKey && document.activeElement === last) { first.focus(); e.preventDefault(); }
        }
        function close() {
            if (!openModal) return;
            openModal.removeAttribute('data-open');
            document.removeEventListener('keydown', onKey, true);
            openModal = null;
            if (lastFocused) { lastFocused.focus(); lastFocused = null; }
        }
        function onKey(e) {
            if (e.key === 'Escape') { e.preventDefault(); close(); }
            else trapFocus(e);
        }
        function open(modal, trigger) {
            lastFocused = trigger || document.activeElement;
            openModal = modal;
            // Fill in the per-action count/summary the trigger declares.
            var countEl = modal.querySelector('[data-ceh-modal-count]');
            if (countEl && trigger && trigger.hasAttribute('data-ceh-count')) {
                countEl.textContent = trigger.getAttribute('data-ceh-count');
            }
            var sumEl = modal.querySelector('[data-ceh-modal-summary]');
            if (sumEl && trigger && trigger.hasAttribute('data-ceh-summary')) {
                sumEl.textContent = trigger.getAttribute('data-ceh-summary');
            }
            // Wire the Confirm button to the originating action.
            var confirmBtn = modal.querySelector('[data-ceh-modal-confirm]');
            if (confirmBtn) {
                confirmBtn.onclick = function () {
                    close();
                    if (trigger && trigger.tagName === 'A' && trigger.href) {
                        window.location.href = trigger.href;
                    } else if (trigger) {
                        // A submit button: replay it on its own form so its
                        // name/value (asp-page-handler etc.) is included.
                        var form = trigger.form || trigger.closest('form');
                        if (form) {
                            if (trigger.name) {
                                var hidden = document.createElement('input');
                                hidden.type = 'hidden';
                                hidden.name = trigger.name;
                                hidden.value = trigger.value || '';
                                form.appendChild(hidden);
                            }
                            if (form.requestSubmit) form.requestSubmit(); else form.submit();
                        }
                    }
                };
            }
            modal.setAttribute('data-open', '');
            document.addEventListener('keydown', onKey, true);
            var firstFocus = modal.querySelector('[data-ceh-modal-confirm]') ||
                             modal.querySelector(FOCUSABLE);
            if (firstFocus) firstFocus.focus();
        }
        document.querySelectorAll('[data-ceh-confirm]').forEach(function (trigger) {
            trigger.addEventListener('click', function (e) {
                var modal = document.getElementById(trigger.getAttribute('data-ceh-confirm'));
                if (!modal) return; // no modal => let the native action proceed
                e.preventDefault();
                open(modal, trigger);
            });
        });
        document.querySelectorAll('.ceh-modal-backdrop').forEach(function (backdrop) {
            // Click on the backdrop (outside the dialog) closes it.
            backdrop.addEventListener('click', function (e) {
                if (e.target === backdrop) close();
            });
            backdrop.querySelectorAll('[data-ceh-modal-cancel]').forEach(function (c) {
                c.addEventListener('click', close);
            });
        });

        // ---- 4. Copy-to-clipboard with transient confirmation ---------------
        // A button with data-ceh-copy="<inputId>" copies that field's value and
        // briefly swaps its label to the localized "copied" text (data-ceh-copied),
        // announced via aria-live. Falls back to execCommand on old browsers; with
        // JS off the field is still selectable, so this is pure enhancement.
        document.querySelectorAll('[data-ceh-copy]').forEach(function (btn) {
            var target = document.getElementById(btn.getAttribute('data-ceh-copy'));
            if (!target) return;
            var label = btn.getAttribute('data-ceh-copy-label') || btn.textContent;
            var copied = btn.getAttribute('data-ceh-copied') || 'Copied!';
            var reset = null;
            btn.addEventListener('click', function () {
                var done = function () {
                    btn.textContent = copied;
                    btn.classList.add('ceh-copied');
                    btn.setAttribute('aria-live', 'polite');
                    if (reset) clearTimeout(reset);
                    reset = setTimeout(function () {
                        btn.textContent = label;
                        btn.classList.remove('ceh-copied');
                    }, 1500);
                };
                var fail = function () { try { target.select(); document.execCommand('copy'); done(); } catch (e) { } };
                try { target.select(); target.setSelectionRange && target.setSelectionRange(0, 99999); } catch (e) { }
                if (navigator.clipboard && navigator.clipboard.writeText) {
                    navigator.clipboard.writeText(target.value).then(done, fail);
                } else { fail(); }
            });
        });

        // ---- 5. Live character counter for maxlength fields -----------------
        // Any <textarea>/<input data-ceh-counter maxlength="N"> gets a live
        // "used / N" counter rendered just after it, announced politely; it turns
        // "near" amber inside the last 10% so a writer sees the cap approaching.
        document.querySelectorAll('[data-ceh-counter][maxlength]').forEach(function (field) {
            var max = parseInt(field.getAttribute('maxlength'), 10);
            if (!(max > 0)) return;
            var tmpl = field.getAttribute('data-ceh-counter') || '{0} / {1}';
            var counter = document.createElement('span');
            counter.className = 'ceh-counter';
            counter.setAttribute('aria-live', 'polite');
            counter.setAttribute('aria-atomic', 'true');
            field.insertAdjacentElement('afterend', counter);
            var render = function () {
                var used = (field.value || '').length;
                counter.textContent = tmpl.replace('{0}', used).replace('{1}', max);
                if (used >= max * 0.9) counter.classList.add('ceh-counter--near');
                else counter.classList.remove('ceh-counter--near');
            };
            field.addEventListener('input', render);
            render();
        });

        // ---- 6. Submit loading state + double-click guard -------------------
        // A <form data-ceh-loading> disables its submit control on the FIRST
        // submit (so a double-click can't fire two posts) and shows a busy label
        // (data-ceh-loading-text on the button) while the navigation is in flight.
        // The form is allowed to submit normally; we only guard re-entry. If the
        // form fails client validation (submit cancelled), the guard self-clears.
        document.querySelectorAll('form[data-ceh-loading]').forEach(function (form) {
            form.addEventListener('submit', function () {
                // Let any other submit handler (validation) run + cancel first.
                setTimeout(function () {
                    if (form.dataset.cehSubmitted) return;
                    form.dataset.cehSubmitted = '1';
                    form.classList.add('ceh-submitting');
                    var btn = form.querySelector('[type="submit"], button:not([type="button"])');
                    if (btn) {
                        var busy = btn.getAttribute('data-ceh-loading-text');
                        if (busy) {
                            if (btn.tagName === 'INPUT') btn.value = busy; else btn.textContent = busy;
                        }
                        btn.classList.add('ceh-busy');
                        btn.setAttribute('aria-busy', 'true');
                        // Re-enabling is avoided so a slow POST can't be re-fired;
                        // a fresh page load resets everything.
                        btn.disabled = true;
                    }
                }, 0);
            });
        });

        // ---- 7. Unsaved-changes guard ---------------------------------------
        // A <form data-ceh-dirty> warns (native beforeunload) if the user edits a
        // field then tries to leave WITHOUT submitting. Submitting the form (or
        // clicking a control that opts out via data-ceh-allow-leave) clears the
        // guard so the post itself never trips the prompt.
        document.querySelectorAll('form[data-ceh-dirty]').forEach(function (form) {
            var dirty = false;
            var clear = function () { dirty = false; };
            form.addEventListener('input', function () { dirty = true; });
            form.addEventListener('change', function () { dirty = true; });
            form.addEventListener('submit', clear);
            form.querySelectorAll('[data-ceh-allow-leave]').forEach(function (el) {
                el.addEventListener('click', clear);
            });
            window.addEventListener('beforeunload', function (e) {
                if (!dirty) return;
                e.preventDefault();
                e.returnValue = '';   // browsers show their own generic prompt
                return '';
            });
        });

        // ---- 8. Grid loading skeleton --------------------------------------
        // A container marked data-ceh-grid shows an animated skeleton overlay
        // while the next page of a data-heavy organizer grid is being fetched.
        // The grids navigate with a full-page GET (filter form submit, or a
        // sort/pagination link), so there is a perceptible wait the user gets no
        // feedback for today. We hook those navigations and flip the grid into a
        // busy state: the stale rows dim, the shimmer skeleton lays over them and
        // an aria-live region announces it. A fresh page load clears everything,
        // so there is nothing to reset. Pure enhancement (JS off => unchanged).
        document.querySelectorAll('[data-ceh-grid]').forEach(function (grid) {
            // Build the skeleton + live region once and keep them hidden until busy.
            var loadingText = grid.getAttribute('data-ceh-grid-loading') || 'Loading…';
            var skeleton = document.createElement('div');
            skeleton.className = 'ceh-grid__skeleton';
            skeleton.setAttribute('aria-hidden', 'true'); // decorative bars
            for (var i = 0; i < 6; i++) {
                var bar = document.createElement('div');
                bar.className = 'ceh-grid__bar';
                skeleton.appendChild(bar);
            }
            grid.appendChild(skeleton);

            var live = document.createElement('span');
            live.className = 'sr-only';
            live.setAttribute('role', 'status');
            live.setAttribute('aria-live', 'polite');
            grid.appendChild(live);

            var armed = false;
            function setBusy() {
                if (armed) return;       // one-shot per navigation
                armed = true;
                grid.setAttribute('data-ceh-grid-busy', '');
                grid.setAttribute('aria-busy', 'true');
                live.textContent = loadingText;
            }

            // a) the grid's own GET filter form (search / status / persona...).
            var filterForm = grid.querySelector('form[method="get"]');
            if (filterForm) filterForm.addEventListener('submit', function () { setTimeout(setBusy, 0); });

            // b) sort-header + pagination links inside the grid. Skip in-page
            //    anchors and anything that opts out (data-ceh-grid-skip), and
            //    ignore modified clicks (new tab / download) so we never show a
            //    skeleton for a navigation that isn't replacing this page.
            grid.addEventListener('click', function (e) {
                var a = e.target.closest && e.target.closest('a[href]');
                if (!a || !grid.contains(a)) return;
                if (a.hasAttribute('data-ceh-grid-skip')) return;
                if (a.target === '_blank' || a.hasAttribute('download')) return;
                if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey || e.button !== 0) return;
                var href = a.getAttribute('href') || '';
                if (href === '' || href.charAt(0) === '#') return;
                setBusy();
            });
        });

        // The browser's bfcache can restore a busy grid when the user navigates
        // back; clear the state on pageshow so it never sticks.
        window.addEventListener('pageshow', function () {
            document.querySelectorAll('[data-ceh-grid][data-ceh-grid-busy]').forEach(function (g) {
                g.removeAttribute('data-ceh-grid-busy');
                g.removeAttribute('aria-busy');
            });
        });
    })();
    </script>
    @* Render any page-defined @@section Scripts. Without this, every page that defines one
       (e.g. Organizer/Hotels) 500s on render: "section 'Scripts' has not been rendered". *@
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
