@*
    OTTO — the corner Community Helper widget (REQUIREMENTS §129).

    Rendered by _Layout for AUTHENTICATED, non-standalone pages only (the caller
    gates on isLoggedIn && !HidePublicNav), so it respects the anon-vs-auth chrome
    isolation (§27) and never appears on an anonymous survey/signup/login page.

    Otto peeks from the bottom-right corner with a small speech bubble; clicking him
    opens a chat panel. Pure vanilla JS fetch to /api/otto (no new dependencies).
    Mobile-first: on ~360px the panel is near-full-width and does not cover content
    when collapsed (just Otto in the corner). Progressive: with JS off, nothing pops.
*@
@Html.AntiForgeryToken()
<div id="otto-widget" class="otto-widget" data-endpoint="/api/otto">
    <button type="button" id="otto-launcher" class="otto-launcher"
            aria-expanded="false" aria-controls="otto-panel"
            aria-label="Open Otto, the Community Helper">
        <span class="otto-bubble" aria-hidden="true">Hej! Need a hand? &#128075;</span>
        <img class="otto-avatar" src="~/img/otto.svg" alt="" width="72" height="78" />
    </button>

    <section id="otto-panel" class="otto-panel" role="dialog" aria-modal="false"
             aria-labelledby="otto-title" hidden>
        <header class="otto-header">
            <img class="otto-head-avatar" src="~/img/otto.svg" alt="" width="34" height="37" />
            <span id="otto-title" class="otto-head-title">Otto &middot; Community Helper</span>
            <button type="button" id="otto-close" class="otto-close"
                    aria-label="Close Otto">&times;</button>
        </header>

        <div id="otto-log" class="otto-log" aria-live="polite">
            <div class="otto-msg otto-msg-bot">
                <img class="otto-msg-avatar" src="~/img/otto.svg" alt="Otto" width="28" height="30" />
                <div class="otto-msg-text">Hej! I'm Otto. Ask me about your tasks, your sessions, or
                    anything in your event info — I'll answer from what's relevant to you. &#128075;</div>
            </div>
        </div>

        <form id="otto-form" class="otto-form" autocomplete="off">
            <label for="otto-input" class="visually-hidden">Ask Otto a question</label>
            <input type="text" id="otto-input" class="otto-input" maxlength="1000"
                   placeholder="Ask Otto&hellip;" />
            <button type="submit" id="otto-send" class="otto-send"
                    aria-label="Send question">&#10148;</button>
        </form>
    </section>
</div>

<style>
    .otto-widget { position: fixed; right: 16px; bottom: 16px; z-index: 1200; }
    .otto-launcher {
        background: none; border: 0; padding: 0; cursor: pointer;
        display: flex; align-items: flex-end; gap: 8px;
    }
    .otto-bubble {
        background: #fff; color: #14223a; border: 1px solid #cdd8ea;
        border-radius: 14px 14px 2px 14px; padding: 8px 12px; font-size: .9rem;
        box-shadow: 0 4px 14px rgba(20,34,58,.18); max-width: 190px; line-height: 1.25;
    }
    .otto-avatar { display: block; filter: drop-shadow(0 3px 6px rgba(20,34,58,.25)); transition: transform .15s ease; }
    .otto-launcher:hover .otto-avatar { transform: translateY(-3px); }

    .otto-panel {
        position: fixed; right: 16px; bottom: 16px; width: 360px; max-width: calc(100vw - 24px);
        height: 480px; max-height: calc(100vh - 80px);
        background: #fff; border: 1px solid #cdd8ea; border-radius: 16px;
        box-shadow: 0 12px 40px rgba(20,34,58,.30);
        display: flex; flex-direction: column; overflow: hidden;
    }
    .otto-panel[hidden] { display: none; }
    .otto-header {
        display: flex; align-items: center; gap: 8px; padding: 10px 12px;
        background: linear-gradient(180deg,#3aa0ff,#1b6fe0); color: #fff; flex: 0 0 auto;
    }
    .otto-head-avatar { background: #fff; border-radius: 50%; }
    .otto-head-title { font-weight: 600; flex: 1 1 auto; }
    .otto-close { background: none; border: 0; color: #fff; font-size: 1.4rem; line-height: 1; cursor: pointer; padding: 0 4px; }
    .otto-log { flex: 1 1 auto; overflow-y: auto; padding: 12px; display: flex; flex-direction: column; gap: 10px; background: #f5f8fd; }
    .otto-msg { display: flex; gap: 8px; align-items: flex-start; }
    .otto-msg-user { flex-direction: row-reverse; }
    .otto-msg-avatar { background: #fff; border-radius: 50%; flex: 0 0 auto; }
    .otto-msg-text {
        background: #fff; border: 1px solid #e1e8f3; border-radius: 12px; padding: 8px 11px;
        font-size: .92rem; line-height: 1.35; max-width: 80%; white-space: pre-wrap; word-wrap: break-word;
    }
    .otto-msg-user .otto-msg-text { background: #1b6fe0; color: #fff; border-color: #1b6fe0; }
    .otto-msg-bot.otto-thinking .otto-msg-text { color: #6b7a90; font-style: italic; }
    .otto-form { display: flex; gap: 8px; padding: 10px; border-top: 1px solid #e1e8f3; flex: 0 0 auto; }
    .otto-input { flex: 1 1 auto; border: 1px solid #cdd8ea; border-radius: 20px; padding: 9px 14px; font-size: .95rem; }
    .otto-send { background: #1b6fe0; color: #fff; border: 0; border-radius: 50%; width: 40px; height: 40px; font-size: 1.1rem; cursor: pointer; flex: 0 0 auto; }
    .otto-send:disabled { opacity: .5; cursor: default; }

    @@media (max-width: 480px) {
        .otto-bubble { max-width: 150px; font-size: .82rem; }
        .otto-avatar { width: 60px; height: 65px; }
        .otto-panel { right: 8px; bottom: 8px; height: calc(100vh - 90px); }
    }
</style>

<script>
    (function () {
        var widget = document.getElementById('otto-widget');
        if (!widget) return;
        var endpoint = widget.getAttribute('data-endpoint');
        var launcher = document.getElementById('otto-launcher');
        var panel = document.getElementById('otto-panel');
        var closeBtn = document.getElementById('otto-close');
        var form = document.getElementById('otto-form');
        var input = document.getElementById('otto-input');
        var sendBtn = document.getElementById('otto-send');
        var log = document.getElementById('otto-log');
        var tokenEl = widget.parentNode
            ? widget.parentNode.querySelector('input[name="__RequestVerificationToken"]')
            : document.querySelector('input[name="__RequestVerificationToken"]');

        function open() {
            panel.hidden = false;
            launcher.setAttribute('aria-expanded', 'true');
            launcher.style.display = 'none';
            input.focus();
        }
        function close() {
            panel.hidden = true;
            launcher.setAttribute('aria-expanded', 'false');
            launcher.style.display = '';
        }
        launcher.addEventListener('click', open);
        closeBtn.addEventListener('click', close);
        document.addEventListener('keydown', function (e) {
            if ((e.key === 'Escape' || e.key === 'Esc') && !panel.hidden) close();
        });

        function bubble(text, who) {
            var wrap = document.createElement('div');
            wrap.className = 'otto-msg otto-msg-' + who;
            if (who === 'bot') {
                var av = document.createElement('img');
                av.className = 'otto-msg-avatar';
                av.src = '/img/otto.svg'; av.alt = 'Otto'; av.width = 28; av.height = 30;
                wrap.appendChild(av);
            }
            var t = document.createElement('div');
            t.className = 'otto-msg-text';
            t.textContent = text;
            wrap.appendChild(t);
            log.appendChild(wrap);
            log.scrollTop = log.scrollHeight;
            return wrap;
        }

        form.addEventListener('submit', function (e) {
            e.preventDefault();
            var q = (input.value || '').trim();
            if (!q) return;
            bubble(q, 'user');
            input.value = '';
            sendBtn.disabled = true;
            var thinking = bubble('Otto is thinking…', 'bot');
            thinking.classList.add('otto-thinking');

            var headers = { 'Content-Type': 'application/json' };
            if (tokenEl) headers['RequestVerificationToken'] = tokenEl.value;

            fetch(endpoint, {
                method: 'POST',
                headers: headers,
                body: JSON.stringify({ question: q })
            })
                .then(function (r) { return r.json().catch(function () { return {}; }); })
                .then(function (data) {
                    thinking.remove();
                    bubble((data && data.answer) ? data.answer
                        : 'Sorry, I could not answer that right now.', 'bot');
                })
                .catch(function () {
                    thinking.remove();
                    bubble('Sorry, I had trouble reaching the assistant. Please try again.', 'bot');
                })
                .finally(function () { sendBtn.disabled = false; input.focus(); });
        });
    })();
</script>
