@*
    PUBLIC / ANONYMOUS layout (operator 2026-06-24, REQUIREMENTS §27).

    For pages that must NEVER show internal/authenticated chrome — surveys, the
    volunteer signup, sign-in, magic-link. It injects NO auth services and renders
    NO nav, NO user identity, NO Sign-out: structurally impossible to leak an
    internal view, even if a signed-in organizer opens the page in the same browser.
    It reuses the SAME styles + client behaviours as _Layout via shared partials, so
    these pages look and behave identically — minus the chrome. Auth pages keep using
    _Layout and are completely unaffected by anything here.
*@
@{
    Layout = null;

    // Display name only, kept in sync with _Layout (no shared injects here on
    // purpose - this layout pulls in NO auth/nav services).
    const string ProductName = "Community Event Hub";
    const string ProductShortName = "CEH";
}<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <partial name="_LayoutStyles" />
</head>
<body>
    <header>
        <a class="brand" href="/" aria-label="Experts Live Denmark">
            <img src="~/img/logo-experts-live-denmark-white.png" alt="Experts Live Denmark" style="height:48px; display:block;" />
        </a>
        <a class="brand" href="/" aria-label="Experts Live Denmark event logo" style="background:#fff; padding:6px 8px; border-radius:8px;">
            <img src="~/img/logo-eldk27-event.png" alt="ELDK27" style="height:48px; display:block;" />
        </a>
    </header>
    <main id="main" tabindex="-1">
        @RenderBody()
    </main>
    @* Contentinfo landmark (a11y). The SAME open-source credit line as _Layout, but
       still NO internal nav, user identity, or Sign-out — the anonymous-isolation rule
       (REQUIREMENTS §27) is about auth chrome, not the public product/credit footer.
       English literals (no localizer is injected here on purpose). *@
    <footer style="text-align:center;">
        <div>
            @ProductName (@ProductShortName) &mdash; Built as open-source by
            <a href="https://aka.ms/morten" target="_blank" rel="noopener">Morten Knudsen<span class="visually-hidden"> (opens in a new tab)</span></a>
            &middot; free for any community to use.
        </div>
        <div style="margin-top:4px;">
            <a href="https://github.com/KnudsenMorten/community-event-hub" target="_blank" rel="noopener">GitHub<span class="visually-hidden"> (opens in a new tab)</span></a>
            &middot;
            <a href="https://github.com/KnudsenMorten/community-event-hub/issues" target="_blank" rel="noopener">Submit a bug<span class="visually-hidden"> (opens in a new tab)</span></a>
            &middot;
            <a href="/Contributors">Contributors</a>
        </div>
    </footer>
    <partial name="_LayoutClientScripts" />
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
