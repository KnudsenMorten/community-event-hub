    <style>
        /* Experts Live brand palette:
             --el-darkblue #1D3380  -- header background, headings
             --el-blue     #008BD2  -- accent, buttons, links
             --el-grey     #E3E3E3  -- page background / dividers   */
        :root {
            color-scheme: light;
            --el-darkblue: #1D3380;
            --el-blue:     #008BD2;
            --el-grey:     #E3E3E3;
        }
        body {
            font-family: system-ui, -apple-system, "Segoe UI", sans-serif;
            margin: 0; background: var(--el-grey); color: #1a1a2e;
            line-height: 1.5;
        }
        /* Visible keyboard focus on every interactive element (WCAG 2.4.7).
           :focus-visible keeps the ring for keyboard users without drawing it
           on mouse clicks, so the existing look is untouched for pointer use. */
        a:focus-visible, button:focus-visible, input:focus-visible,
        select:focus-visible, textarea:focus-visible, summary:focus-visible,
        [tabindex]:focus-visible {
            outline: 3px solid var(--el-blue);
            outline-offset: 2px;
            border-radius: 4px;
        }
        /* Skip-to-content link: off-screen until focused, then pinned top-left
           so a keyboard/screen-reader user can jump past the header + nav. */
        .skip-link {
            position: absolute; left: 8px; top: -48px;
            background: var(--el-darkblue); color: #fff;
            padding: 10px 16px; border-radius: 0 0 8px 8px;
            text-decoration: none; font-weight: 600; z-index: 1000;
            transition: top .15s ease;
        }
        .skip-link:focus { top: 0; color: #fff; }
        /* Screen-reader-only text: present in the accessibility tree, not on screen. */
        .visually-hidden {
            position: absolute !important; width: 1px; height: 1px;
            padding: 0; margin: -1px; overflow: hidden; clip: rect(0 0 0 0);
            white-space: nowrap; border: 0;
        }
        header {
            background: var(--el-darkblue); color: #fff;
            padding: 14px 20px;
            display: flex; align-items: center; gap: 20px;
            flex-wrap: wrap;
            border-bottom: 4px solid var(--el-blue);
            justify-content: center;     /* center the logo pair */
            position: relative;          /* user-tools floats right via abs pos */
        }
        /* Thin announcement bar above the logo header -- ticket-sale info
           + event-site button, visible to everyone (anonymous + logged-in). */
        .topbar {
            background: var(--el-blue); color: #fff;
            padding: 8px 20px;
            font-size: 13px;
            display: flex; align-items: center; justify-content: center;
            gap: 16px; flex-wrap: wrap; text-align: center;
        }
        .topbar .ticket-info { font-weight: 600; }
        /* When the ticket banner is a link (sale open + ticketUrl set) it uses
           the same .ticket-info class but is an <a>: keep it readable on the
           blue bar (white, underlined) instead of inheriting default link blue.
           No fixed height — the bar already wraps on ~360px via flex-wrap. */
        .topbar a.ticket-info { color: #fff; text-decoration: underline; }
        .topbar a.ticket-info:hover { text-decoration: none; }
        .topbar a.eventsite-btn {
            display: inline-block;
            background: #fff; color: var(--el-darkblue);
            padding: 4px 14px; border-radius: 999px;
            font-weight: 700; font-size: 12.5px;
            text-decoration: none; white-space: nowrap;
        }
        .topbar a.eventsite-btn:hover { background: var(--el-grey); }
        header .brand img { height: 56px; display: block; }
        header .product-mark {
            font-size: 30px; font-weight: 700; letter-spacing: .01em;
            color: #fff; white-space: nowrap;
        }
        header .titles { flex: 1 1 220px; min-width: 0; display: flex;
            align-items: baseline; gap: 16px; }
        header h1 { margin: 0; font-size: 22px; font-weight: 600;
            opacity: 1; white-space: nowrap; overflow: hidden;
            text-overflow: ellipsis; }
        header .user-tools { display: flex; align-items: center; gap: 10px;
            font-size: 13px; flex: 0 0 auto;
            position: absolute; right: 16px; top: 50%; transform: translateY(-50%); }
        header .user-tools .who { opacity: .85; white-space: nowrap; }
        @@media (max-width: 700px) {
            /* Stack the header on mobile and drop the user-tools out of absolute
               positioning (it otherwise floats OVER the centred logo and hides the
               Sign-out button). Put it in normal flow, centred below the logo. */
            header { flex-direction: column; gap: 10px; }
            header .user-tools {
                position: static; transform: none; right: auto; top: auto;
                width: 100%; flex-basis: 100%;
                justify-content: center; flex-wrap: wrap;
                margin: 4px 0 0; gap: 8px;
            }
        }
        header .user-tools form { margin: 0; }
        header .user-tools button.signout {
            background: transparent; color: #fff;
            border: 1px solid rgba(255,255,255,.6);
            padding: 6px 12px; border-radius: 6px; font-size: 13px;
        }
        header .user-tools button.signout:hover {
            background: rgba(255,255,255,.12);
        }
        nav.primary {
            background: #fff; border-bottom: 1px solid #d6d8e0;
            padding: 6px 24px; display: flex; flex-wrap: wrap; gap: 4px;
        }
        nav.primary a {
            display: inline-block; padding: 8px 14px; border-radius: 6px;
            text-decoration: none; color: var(--el-darkblue);
            font-size: 14px; font-weight: 500;
        }
        nav.primary a:hover { background: var(--el-grey); }
        nav.primary a.active,
        nav.primary a[aria-current="page"] { background: var(--el-darkblue); color: #fff; }
        /* Participant-nav named section (e.g. the speaker "Speaker" group): a
           native <details>/<summary> disclosure inside the primary bar so the
           long speaker nav is grouped, not one flat list. No JS, keyboard-
           operable. On desktop the panel floats under the toggle (like the
           organizer menu); on phone it flows inline full-width. */
        details.nav-section { position: relative; display: inline-block; }
        details.nav-section > summary {
            list-style: none; cursor: pointer; user-select: none;
            display: inline-flex; align-items: center; gap: 6px;
            padding: 8px 14px; border-radius: 6px;
            color: var(--el-darkblue); font-size: 14px; font-weight: 600;
        }
        details.nav-section > summary::-webkit-details-marker { display: none; }
        details.nav-section > summary:hover { background: var(--el-grey); }
        details.nav-section[open] > summary { background: var(--el-grey); }
        /* Current-section indicator on the CLOSED summary (the dropdown no longer
           auto-opens; it's an absolute overlay that would cover the page). */
        details.nav-section.is-active > summary { background: var(--el-grey); box-shadow: inset 0 -2px 0 var(--el-darkblue); }
        .nav-section-caret { transition: transform .15s ease; font-size: 11px; opacity: .7; }
        details.nav-section[open] .nav-section-caret { transform: rotate(180deg); }
        .nav-section-items {
            display: flex; flex-direction: column; gap: 2px;
            position: absolute; left: 0; top: calc(100% + 4px); z-index: 50;
            min-width: 220px; max-height: 70vh; overflow-y: auto;
            background: #fff; border: 1px solid #c4c8d4; border-radius: 8px;
            padding: 6px; box-shadow: 0 6px 18px rgba(0,0,0,.14);
        }
        .nav-section-items a {
            display: block; padding: 8px 12px; border-radius: 6px;
            text-decoration: none; color: var(--el-darkblue);
            font-size: 14px; font-weight: 500; white-space: nowrap;
        }
        .nav-section-items a:hover { background: var(--el-grey); }
        .nav-section-items a[aria-current="page"] { background: var(--el-darkblue); color: #fff; }
        @@media (max-width: 700px) {
            details.nav-section { display: block; }
            details.nav-section > summary { display: flex; justify-content: space-between; }
            .nav-section-items {
                position: static; min-width: 0; width: 100%;
                box-shadow: none; margin-top: 4px; max-height: none;
            }
        }
        /* Second-level management bar: a distinct strip below the participant
           nav so organizer tools read as a separate group, not mixed in. */
        nav.manage-bar {
            background: #eef0f6; border-bottom: 1px solid #d6d8e0;
            padding: 6px 24px;
        }
        /* Organizer-area dropdown (native <details>/<summary> — no JS). */
        details.org-menu { position: relative; display: inline-block; }
        details.org-menu > summary {
            list-style: none; cursor: pointer; user-select: none;
            display: inline-flex; align-items: center; gap: 6px;
            padding: 7px 14px; border-radius: 6px;
            color: var(--el-darkblue); font-size: 14px; font-weight: 600;
            background: #fff; border: 1px solid #c4c8d4;
        }
        details.org-menu > summary::-webkit-details-marker { display: none; }
        details.org-menu > summary:hover { background: var(--el-grey); }
        details.org-menu[open] > summary {
            background: var(--el-darkblue); color: #fff; border-color: var(--el-darkblue);
        }
        .org-menu-caret { transition: transform .15s ease; font-size: 11px; }
        details.org-menu[open] .org-menu-caret { transform: rotate(180deg); }
        /* Desktop: float the items as a panel under the toggle. */
        .org-menu-items {
            display: flex; flex-direction: column; gap: 2px;
            position: absolute; left: 0; top: calc(100% + 4px); z-index: 50;
            min-width: 220px; max-height: 70vh; overflow-y: auto;
            background: #fff; border: 1px solid #c4c8d4; border-radius: 8px;
            padding: 6px; box-shadow: 0 6px 18px rgba(0,0,0,.14);
        }
        .org-menu-items a {
            display: block; padding: 8px 12px; border-radius: 6px;
            text-decoration: none; color: var(--el-darkblue);
            font-size: 14px; font-weight: 500; white-space: nowrap;
        }
        .org-menu-items a:hover { background: var(--el-grey); }
        .org-menu-items a[aria-current="page"] { background: var(--el-darkblue); color: #fff; }
        /* REQUIREMENTS §21 — nested, collapsible section sub-groups inside the
           organizer menu (People / Sessions / Comms / Sponsors / Volunteers /
           Logistics). Native <details>/<summary>: no JS, keyboard-operable, a
           labelled disclosure per group. The leading prominent links (Organizer
           home / Command center / Dashboard) render before the first section, so a
           thin divider above the first section separates them. */
        .org-section { display: block; }
        .org-section + .org-section { margin-top: 2px; }
        .org-menu-items > .org-section:first-of-type {
            margin-top: 6px; padding-top: 6px; border-top: 1px solid #e1e3ec;
        }
        .org-section > summary {
            list-style: none; cursor: pointer; user-select: none;
            display: flex; align-items: center; justify-content: space-between;
            gap: 8px; padding: 7px 12px; border-radius: 6px;
            color: var(--el-darkblue); font-size: 12.5px; font-weight: 700;
            text-transform: uppercase; letter-spacing: .03em;
        }
        .org-section > summary::-webkit-details-marker { display: none; }
        .org-section > summary:hover { background: var(--el-grey); }
        .org-section-caret { transition: transform .15s ease; font-size: 10px; opacity: .7; }
        .org-section[open] > summary > .org-section-caret { transform: rotate(180deg); }
        /* Section links sit slightly indented so they read as children of the
           group heading above them. */
        .org-section-items { display: flex; flex-direction: column; gap: 2px; padding-left: 8px; }
        .org-section-items a {
            display: block; padding: 8px 12px; border-radius: 6px;
            text-decoration: none; color: var(--el-darkblue);
            font-size: 14px; font-weight: 500; white-space: nowrap;
        }
        .org-section-items a:hover { background: var(--el-grey); }
        .org-section-items a[aria-current="page"] { background: var(--el-darkblue); color: #fff; }
        /* Mobile (~360px): the toggle spans the bar and the panel flows inline
           (static, full width) so the long admin list scrolls with the page
           instead of overflowing a fixed dropdown off the small viewport. */
        @@media (max-width: 700px) {
            details.org-menu { display: block; }
            details.org-menu > summary { display: flex; justify-content: space-between; }
            .org-menu-items {
                position: static; min-width: 0; width: 100%;
                box-shadow: none; margin-top: 4px; max-height: none;
            }
        }
        main { max-width: 880px; margin: 24px auto; padding: 0 16px; }
        .card {
            background: #fff; border-radius: 10px;
            padding: 20px; margin-bottom: 16px;
            box-shadow: 0 1px 3px rgba(0,0,0,.08);
        }
        .card h2 { margin-top: 0; font-size: 22px; font-weight: 700; color: var(--el-darkblue); }
        /* Shared organizer hub button-grid (operator 2026-06-21): the hub landing
           pages fan out to their feature pages as a responsive grid of link-tiles,
           replacing the old one-per-feature card stacks. One definition, every hub. */
        .hub-grid { display: grid; grid-template-columns: 1fr; gap: 12px; margin: 4px 0 8px; }
        @@media (min-width: 560px) { .hub-grid { grid-template-columns: repeat(auto-fit, minmax(230px, 1fr)); } }
        a.hub-tile { display: flex; flex-direction: column; text-decoration: none; color: inherit;
            border: 1px solid #e6e8ee; background: #f7f8fa; border-radius: 10px; padding: 14px 16px;
            transition: box-shadow .12s ease, transform .12s ease, border-color .12s ease; }
        a.hub-tile:hover, a.hub-tile:focus-visible {
            box-shadow: 0 2px 10px rgba(0,0,0,.12); transform: translateY(-1px);
            border-color: var(--el-blue, #008BD2); outline: none; }
        a.hub-tile .hub-tile-title { font-size: 15.5px; font-weight: 700; color: var(--el-darkblue, #1D3380); }
        a.hub-tile .hub-tile-desc { font-size: 12.5px; color: #4b5563; margin-top: 4px; line-height: 1.4; }
        a.hub-tile .hub-tile-go { font-size: 12px; font-weight: 600; color: var(--el-blue, #008BD2); margin-top: 10px; }
        /* Ring badge — yellow "Ring N" pill next to a feature still in staged
           rollout (not yet Broad/GA). Promoted from /Organizer/Settings so nav +
           tiles render the identical marker. */
        .set-tag { display:inline-block; font-size:10.5px; line-height:1; padding:2px 6px;
            border-radius:999px; margin-left:6px; vertical-align:middle; }
        .set-tag.ring { background:#fef9c3; color:#854d0e; border:1px solid #fde047; font-weight:600; }
        .info { color: #1f2937; }  /* neutral dark slate — operator 2026-06-24: "don't use green, make it easier to read" (was #15803d green) */
        .error { color: #c0392b; }
        button, input[type=submit] {
            background: var(--el-blue); color: #fff; border: 0;
            padding: 9px 16px; border-radius: 7px;
            font-size: 15px; cursor: pointer;
        }
        button:hover, input[type=submit]:hover { background: var(--el-darkblue); }
        /* Secondary button is a darker grey than the page bg so it stays
           visible even on cards/pages that sit directly on the body. */
        button.secondary { background: #c4c8d4; color: var(--el-darkblue); }
        button.secondary:hover { background: #aab0c0; }
        input[type=email], input[type=text], input[type=number],
        input[type=date], input[type=tel], input[type=url],
        select, textarea {
            display: block; width: 100%; max-width: 360px;
            padding: 8px; margin: 6px 0 14px;
            border: 1px solid #c4c8d4; border-radius: 6px;
            font-size: 15px; box-sizing: border-box;
        }
        /* Each label sits on its own line so it labels the input BELOW it,
           not the input to the LEFT of it. Form-rows that want side-by-side
           (e.g. checkbox + text) override with their own display:flex.       */
        label { font-weight: 600; font-size: 14px;
            display: block; margin-top: 10px; }
        a { color: var(--el-blue); }
        a:hover { color: var(--el-darkblue); }
        /* URL / email auto-buttons rendered inside task descriptions.
           Sized to match the form action buttons (Mark complete, etc.) so
           the click target is the same and inline buttons read as primary
           actions rather than tiny inline pills. */
        a.task-link-btn {
            display: inline-block;
            background: var(--el-blue);
            color: #fff !important;
            padding: 8px 18px;
            border-radius: 6px;
            text-decoration: none;
            font-size: 14px;
            font-weight: 600;
            margin: 4px 4px;
            word-break: break-all;
            line-height: 1.2;
        }
        a.task-link-btn:hover {
            background: var(--el-darkblue);
            color: #fff !important;
        }
        footer { max-width: 880px; margin: 24px auto; padding: 0 16px;
            font-size: 12px; color: #6b7280; }
        /* Visually hidden but available to screen readers. left:0 pins it to the
           nearest positioned ancestor's left edge so an absolutely-positioned
           .sr-only in a far-right table cell can't extend past the body and cause
           horizontal overflow (e.g. the Organizer /Comms tables at 360px). */
        .sr-only { position: absolute; left: 0; width: 1px; height: 1px; padding: 0;
            margin: -1px; overflow: hidden; clip: rect(0,0,0,0);
            white-space: nowrap; border: 0; }

        /* ============================================================
           SHARED UX COMPONENTS (REQUIREMENTS §21) — reusable repo-wide
           1. Flash toast  (_Flash.cshtml)
           2. Field validation  (asp-validation-for / .ceh-field-error)
           3. Confirmation modal  (_ConfirmModal.cshtml)
           ============================================================ */

        /* 1. Flash toast — success/error banner after a POST. Mobile-first:
              full-width, wraps at ~360px, large tap targets. */
        /* Result toast — FIXED at the bottom of the viewport so the outcome of a
           POST is visible wherever the user was on the page (combined with scroll
           restoration, the window no longer jumps to the top after an action). */
        .ceh-flash {
            display: flex; align-items: flex-start; gap: 10px;
            padding: 12px 14px; border-radius: 8px;
            font-size: 14.5px; line-height: 1.4; border: 1px solid transparent;
            position: fixed; left: 50%; bottom: 18px; transform: translateX(-50%);
            z-index: 1200; max-width: min(560px, 92vw); width: max-content;
            box-shadow: 0 6px 24px rgba(0,0,0,.18);
        }
        @@media (max-width: 460px) { .ceh-flash { width: 92vw; } }
        .ceh-flash--success {
            background: #e7f6ec; border-color: #b6e0c4; color: #1b5e34;
        }
        .ceh-flash--error {
            background: #fcebec; border-color: #f3c2c6; color: #8a1f28;
        }
        .ceh-flash--info {
            background: #eaf1fb; border-color: #c2d4f3; color: #1f3f6b;
        }
        .ceh-flash__icon { font-weight: 700; flex: 0 0 auto; font-size: 16px; line-height: 1.3; }
        .ceh-flash__text { flex: 1 1 auto; min-width: 0; }
        .ceh-flash__close {
            flex: 0 0 auto; background: transparent; color: inherit;
            border: 0; font-size: 22px; line-height: 1; cursor: pointer;
            padding: 0 4px; min-width: 32px; min-height: 32px; border-radius: 6px;
        }
        .ceh-flash__close:hover { background: rgba(0,0,0,.08); }

        /* 2. Inline form validation — field-level error message + an invalid
              field outline. Works with the tag helpers (asp-validation-for /
              asp-validation-summary) which emit .field-validation-error /
              .input-validation-error, and with manual .ceh-field-error spans. */
        .ceh-field-error,
        .field-validation-error {
            display: block;
            color: #8a1f28; font-size: 13px; font-weight: 600;
            margin: -8px 0 12px;
        }
        /* Show a field-error span ONLY when it actually carries an error. The static
           .ceh-field-error class is present on every field, so without this a fresh
           form rendered a stray "⚠" + reserved space under every input. MVC marks a
           valid span .field-validation-valid (and leaves it empty); a manual
           .ceh-field-error with no message is :empty -- hide both. */
        .ceh-field-error:empty,
        span.field-validation-valid { display: none; }
        .ceh-field-error::before,
        .field-validation-error::before { content: "⚠ "; }
        /* Red outline on the offending input (tag-helper adds the class). */
        input.input-validation-error, select.input-validation-error,
        textarea.input-validation-error, .ceh-input-invalid {
            border-color: #c0392b !important;
            outline-color: #c0392b;
        }
        /* Error summary box at the top of a form. */
        .ceh-validation-summary {
            background: #fcebec; border: 1px solid #f3c2c6; color: #8a1f28;
            padding: 10px 14px; border-radius: 8px; margin: 0 0 16px; font-size: 14px;
        }
        .ceh-validation-summary ul { margin: 6px 0 0; padding-left: 20px; }
        .ceh-validation-summary p { margin: 0; font-weight: 700; }
        /* Hide the summary when there is NOTHING to show. :empty alone is not enough --
           asp-validation-summary renders an empty inner <ul> when valid, so the div is
           never truly :empty and the red bar showed on a fresh form. MVC adds
           .validation-summary-valid when there are no errors -- key off that. */
        .ceh-validation-summary:empty,
        .ceh-validation-summary.validation-summary-valid { display: none; }

        /* 3. Confirmation modal — accessible dialog for destructive/bulk/send
              actions. Centred overlay, scrolls on small screens, focus-trapped
              by the shared JS. */
        .ceh-modal-backdrop {
            position: fixed; inset: 0; background: rgba(15,18,40,.55);
            display: none; align-items: center; justify-content: center;
            padding: 16px; z-index: 2000;
        }
        .ceh-modal-backdrop[data-open] { display: flex; }

        /* Page-level confirm/bulk dialogs (Participants grid etc.) mark their
           fixed-position backdrop with .modal-backdrop and toggle the [hidden]
           attribute to open/close. Those backdrops carry an inline display:flex,
           which on its own OVERRIDES the UA [hidden]{display:none} rule — so a
           "closed" backdrop stayed display:flex over the whole viewport and
           swallowed clicks behind it (it intercepted "Switch to user" on the
           ~360px iPhone SE layout). Force a hidden backdrop fully inert here so
           the fix is GLOBAL to every .modal-backdrop, not per-modal: !important
           beats the inline display, and pointer-events:none is a belt-and-braces
           guard. Desktop is unaffected — an OPEN modal has [hidden] removed. */
        .modal-backdrop[hidden] { display: none !important; pointer-events: none; }
        .ceh-modal {
            background: #fff; border-radius: 12px; max-width: 460px; width: 100%;
            max-height: calc(100vh - 32px); overflow-y: auto;
            box-shadow: 0 12px 40px rgba(0,0,0,.3); padding: 22px 22px 18px;
        }
        .ceh-modal h2 { margin: 0 0 10px; font-size: 19px; color: var(--el-darkblue); }
        .ceh-modal__body { font-size: 14.5px; line-height: 1.5; color: #1a1a2e; }
        .ceh-modal__count {
            display: inline-block; font-weight: 700; background: var(--el-grey);
            color: var(--el-darkblue); padding: 2px 10px; border-radius: 999px;
        }
        .ceh-modal__actions {
            display: flex; flex-wrap: wrap; gap: 10px; justify-content: flex-end;
            margin-top: 20px;
        }
        .ceh-modal__actions button { min-width: 110px; }
        .ceh-modal--danger .ceh-modal__confirm { background: #c0392b; }
        .ceh-modal--danger .ceh-modal__confirm:hover { background: #962d22; }
        @@media (max-width: 480px) {
            .ceh-modal__actions { flex-direction: column-reverse; }
            .ceh-modal__actions button { width: 100%; }
        }
        /* ---- Micro-polish (REQUIREMENTS §21 Participant [L]) -----------------
           Live character counter shown under a maxlength field; the "near limit"
           state warns before the cap is hit. A copy button's transient "copied"
           confirmation. A form whose submit is in flight dims + shows it is busy.
           Mobile-first: the counter is a small, wrapping block under the field. */
        .ceh-counter {
            display: block; margin-top: 4px; font-size: 12px; color: #6b7280;
            text-align: right;
        }
        .ceh-counter--near { color: #b45309; font-weight: 600; }
        .ceh-copied { color: #15803d; font-weight: 600; }
        form.ceh-submitting { opacity: .7; }
        button.ceh-busy, input.ceh-busy { cursor: progress; }

        /* ---- Breadcrumb (REQUIREMENTS §21 cross-cutting) --------------------
