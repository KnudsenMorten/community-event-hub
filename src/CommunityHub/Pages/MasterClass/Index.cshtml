@page "/MasterClass/{slug}"
@model CommunityHub.Pages.MasterClass.IndexModel
@{
    Layout = "_Layout";
    ViewData["Title"] = Model.View is null
        ? Localizer["MC.Title"].Value
        : $"{Model.View.Title} — {Localizer["MC.LogisticsMeta"].Value}";
}

@if (Model.View is null)
{
    <div class="card"><h2>@Localizer["MC.NotFoundHeading"]</h2><p>@Localizer["MC.NotFoundBody"]</p></div>
    return;
}

<style>
    .mc-hero {
        background: var(--el-darkblue, #1D3380); color: #fff;
        padding: 22px; border-radius: 10px 10px 0 0; margin: 0; text-align: center;
    }
    .mc-hero h1 { margin: 0; font-size: 22px; font-weight: 700; line-height: 1.25; }
    .mc-hero .meta { font-size: 13.5px; opacity: .92; margin-top: 8px; line-height: 1.4; }
    .mc-body { padding: 18px 16px; }
    .mc-logistics { white-space: pre-wrap; line-height: 1.5; font-size: 15px; }
    .mc-empty { color: #555; font-style: italic; }
    .mc-edit textarea {
        width: 100%; min-height: 180px; font: inherit; padding: 10px;
        border: 1px solid #c4c4c4; border-radius: 6px; box-sizing: border-box;
    }
    /* Flash banners now use the shared _Flash component (.ceh-flash-*). */
    .mc-updated { font-size: 12.5px; color: #666; margin-top: 10px; }
    .sr-only { position:absolute; width:1px; height:1px; padding:0; margin:-1px;
        overflow:hidden; clip:rect(0,0,0,0); white-space:nowrap; border:0; }
</style>

<div class="card" style="padding:0; overflow:hidden; max-width:760px; margin:0 auto;">
    <div class="mc-hero">
        <h1>@Model.View.Title</h1>
        <div class="meta">
            @Localizer["MC.LogisticsMeta"]
            @if (!string.IsNullOrWhiteSpace(Model.View.Room)) { <text>· @Localizer["SessOv.RoomTag"] @Model.View.Room</text> }
            @if (Model.View.Speakers.Count > 0)
            {
                <br /><text>@string.Format(Localizer["MC.PresentedBy"].Value, string.Join(", ", Model.View.Speakers))</text>
            }
        </div>
    </div>

    <div class="mc-body">
        @* Shared flash toast (REQUIREMENTS §21) — generalised from the original
           bespoke mc-flash-* markup so this page uses the same component as the
           rest of the app. Success and error both flow through _Flash. *@
        @if (!string.IsNullOrEmpty(Model.Message))
        {
            <partial name="_Flash" model='new CommunityHub.Pages.Shared.FlashModel(Model.Message, "success")' />
        }
        @if (!string.IsNullOrEmpty(Model.Error))
        {
            <partial name="_Flash" model='new CommunityHub.Pages.Shared.FlashModel(Model.Error, "error")' />
        }

        @* Standard "what is a Master Class" explainer — the SAME copy for every
           Master Class (operator 2026-06-21). The per-MC speaker-published logistics
           below carry the specifics (what to bring for THIS class); this block is the
           general orientation + the laptop / charging house rules. *@
        <section class="mc-logistics" aria-labelledby="mc-about-h">
            <h2 id="mc-about-h" style="font-size:17px;margin:0 0 8px;">What is an Experts Live Master Class?</h2>
            <p>An Experts Live Master Class is a full-day, in-person learning event where people with a shared interest in a topic come together to learn from experienced professionals—mainly Microsoft MVPs and sometimes Microsoft itself.</p>
            <p>There isn't a strict definition of what makes up a master class. Our main goal is to create a room of peers and provide honest, practical insight — the "no filter" version of what works and what doesn't.</p>
            <p><strong>Key points:</strong></p>
            <ul style="margin:0 0 10px 18px;line-height:1.6;">
                <li>Open dialogue is encouraged — you can ask questions and challenge features.</li>
                <li>Speakers choose their own format.</li>
                <li>Some sessions include hands-on labs; others mix presentations and discussions.</li>
                <li>It's not meant to feel like traditional school despite the word "class."</li>
                <li>Asking questions is strongly encouraged, since much of the value comes from interaction.</li>
            </ul>
            <p>In short: it's an expert-led, interactive deep-dive day focused on real-world learning and peer discussion.</p>

            <h3 style="font-size:15px;margin:14px 0 4px;">Do I need to bring my laptop to attend the class?</h3>
            <p>Many attendees choose to bring their laptops so they can take notes, check email, and follow along during the sessions. Your master class may require you to bring your laptop as outlined in the logistics below.</p>

            <h3 style="font-size:15px;margin:14px 0 4px;">Can I charge my laptop during the master class?</h3>
            <p>Due to Danish fire safety regulations, we cannot provide charging facilities with cables running along the classroom table rows. However, because some attendees may need power, we have set up a charging table in each room where you can charge your laptop or phone. Each room supports up to 15 devices charging at the same time. To get the best start to your day, please arrive with your laptop fully charged for the session.</p>
        </section>

        <hr style="margin:18px 0;border:0;border-top:1px solid #e2e2e2;" />
        <section aria-labelledby="mc-logistics-h">
            <h2 id="mc-logistics-h" style="font-size:17px;margin:0 0 10px;">@Localizer["MC.BeforeYouArrive"]</h2>
            @if (string.IsNullOrWhiteSpace(Model.View.LogisticsText))
            {
                <p class="mc-empty">@Localizer["MC.NoLogistics"]</p>
            }
            else
            {
                <div class="mc-logistics">@Model.View.LogisticsText</div>
            }
            @if (Model.UpdatedLocal is not null)
            {
                <p class="mc-updated">@string.Format(Localizer["MC.LastUpdated"].Value, Model.UpdatedLocal)</p>
            }
        </section>

        @if (Model.CanEdit)
        {
            <hr style="margin:18px 0;border:0;border-top:1px solid #e2e2e2;" />
            <section class="mc-edit" aria-labelledby="mc-edit-h">
                <h2 id="mc-edit-h" style="font-size:16px;margin:0 0 8px;">@Localizer["MC.EditHeading"]</h2>
                <form method="post">
                    <label for="EditLogisticsText" class="sr-only">@Localizer["MC.EditFieldLabel"]</label>
                    <textarea id="EditLogisticsText" name="EditLogisticsText"
                              placeholder="@Localizer["MC.EditPlaceholder"]"
                              aria-describedby="mc-edit-help">@Model.EditLogisticsText</textarea>
                    <p id="mc-edit-help" style="font-size:12.5px;color:#666;margin:6px 0 10px;">
                        @Localizer["MC.EditHelp"]
                    </p>
                    <button type="submit" class="btn">@Localizer["MC.Save"]</button>
                </form>
            </section>
        }
    </div>
</div>
