@page
@model CommunityHub.Pages.IndexModel
@{
    ViewData["Title"] = "";
    ViewData["CommunityName"] = Model.CommunityName;
}

@{
    string DoneBadge() =>
        "<span style=\"display:inline-block;background:#0a6;color:#fff;border-radius:12px;padding:2px 10px;font-size:12px;font-weight:600;\">&#10003; Submitted</span>";
    string PendingBadge() =>
        "<span style=\"display:inline-block;background:#fff3cd;color:#856404;border:1px solid #ffe69c;border-radius:12px;padding:2px 10px;font-size:12px;font-weight:600;\">&#9888; Pending</span>";
}

<style>
    .status-row { display:flex; align-items:center; gap:10px; margin:6px 0 12px; flex-wrap:wrap; }
    .task-list { list-style:none; padding:0; margin:0; }
    .task-list li { padding:8px 12px; border-bottom:1px solid #eef0f4; display:flex; justify-content:space-between; gap:10px; align-items:center; }
    .task-list li:last-child { border-bottom:0; }
    .task-list .due { color:#6b7280; font-size:12px; }
    .task-list .overdue { color:#c0392b; font-weight:600; }
    .done-row { color:#0a6; }
    .done-row::before { content:"\2713"; margin-right:6px; font-weight:700; }
</style>

<div class="card">
    <h2>Welcome, @Model.Me.FirstName</h2>
    <p>@Model.EventDisplayName &middot; signed in as <strong>@CommunityHub.Branding.RoleDisplay.Name(Model.Me.Role)</strong></p>
    @if (Model.OpenTaskCount == 0)
    {
        <p><span style="color:#0a6;font-weight:600;">&#10003; All tasks complete!</span></p>
    }
</div>

@if (Model.PendingTasks.Count > 0)
{
    <div class="card">
        <h2>&#9888; Pending tasks (@Model.PendingTasks.Count)</h2>
        <table class="task-table" style="width:100%; border-collapse:collapse;">
            <thead>
                <tr style="text-align:left; color:#6b7280; font-size:12px; border-bottom:1px solid #e5e7eb;">
                    <th style="padding:8px 6px;">Task</th>
                    <th style="padding:8px 6px; width:130px;">Due date</th>
                    <th style="padding:8px 6px; width:120px;">Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in Model.PendingTasks)
                {
                    <tr style="border-bottom:1px solid #f3f4f6;">
                        <td style="padding:10px 6px;">
                            @if (t.Link is not null)
                            {
                                <a href="@t.Link" style="font-weight:600;">@t.Title &rarr;</a>
                            }
                            else
                            {
                                @t.Title
                            }
                        </td>
                        <td style="padding:10px 6px; white-space:nowrap;">
                            @(t.DueDate?.ToString("dd/MM/yyyy") ?? "-")
                        </td>
                        <td style="padding:10px 6px; white-space:nowrap;
                                   color:@(t.DaysOverdue is > 0 ? "#c0392b" : "#6b7280");
                                   font-weight:@(t.DaysOverdue is > 0 ? "600" : "400");">
                            @if (t.DaysOverdue is > 0)
                            {
                                <text>Overdue (@t.DaysOverdue day@(t.DaysOverdue == 1 ? "" : "s"))</text>
                            }
                            else
                            {
                                <text>Pending</text>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (Model.CompletedTasks.Count > 0)
{
    <div class="card">
        <h2 style="color:#0a6;">&#10003; Completed tasks (@Model.CompletedTasks.Count)</h2>
        <table class="task-table" style="width:100%; border-collapse:collapse;">
            <thead>
                <tr style="text-align:left; color:#6b7280; font-size:12px; border-bottom:1px solid #e5e7eb;">
                    <th style="padding:8px 6px;">Task</th>
                    <th style="padding:8px 6px; width:120px;">Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in Model.CompletedTasks)
                {
                    <tr style="border-bottom:1px solid #f3f4f6;">
                        <td style="padding:10px 6px;">
                            @if (t.Link is not null)
                            {
                                <a href="@t.Link" style="color:#0a6;">@t.Title</a>
                            }
                            else
                            {
                                @t.Title
                            }
                        </td>
                        <td style="padding:10px 6px; color:#0a6; font-weight:600;">&#10003; Done</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (Model.ShowHotel)
{
    <div class="card">
        <h2>Hotel</h2>
        <div class="status-row">
            @if (Model.HotelSubmitted) { @Html.Raw(DoneBadge()) <span>Your hotel preference is on file.</span> }
            else                       { @Html.Raw(PendingBadge()) <span>You have not submitted a hotel preference yet.</span> }
        </div>
        <a asp-page="/Forms/Hotel">@(Model.HotelSubmitted ? "Update" : "Submit") hotel preference</a>
    </div>
}

@if (Model.ShowDinner)
{
    <div class="card">
        <h2>Dinner / social event</h2>
        <div class="status-row">
            @if (Model.DinnerSubmitted) { @Html.Raw(DoneBadge()) <span>Your dinner RSVP is on file.</span> }
            else                        { @Html.Raw(PendingBadge()) <span>Please let us know if you will attend the dinner.</span> }
        </div>
        <a asp-page="/Forms/Dinner">@(Model.DinnerSubmitted ? "Update" : "Submit") dinner signup</a>
    </div>
}

@if (Model.ShowVolunteerShifts)
{
    <div class="card">
        <h2>Volunteer shifts</h2>
        <div class="status-row">
            @if (Model.VolunteerSubmitted) { @Html.Raw(DoneBadge()) <span>Your availability is on file.</span> }
            else                           { @Html.Raw(PendingBadge()) <span>Please submit which shifts you can work.</span> }
        </div>
        <a asp-page="/Forms/VolunteerWizard">@(Model.VolunteerSubmitted ? "Update" : "Start") volunteer sign-up</a>
    </div>
}

@if (Model.ShowSpeakerDeadlines)
{
    <div class="card">
        <h2>Speaker deadlines</h2>
        <p>Your session-related deadlines appear in your task list.</p>
        <a asp-page="/Tasks/Index">View deadlines</a>
    </div>
}

@if (Model.ShowSponsorPipeline)
{
    @await Html.PartialAsync("_KeyDates", Model.EventDates)

    <div class="card">
        <h2>Sponsor area</h2>
        <p>Your company's onboarding tasks appear in the Pending / Completed lists above. The two pages below give you the full view + the inline edit forms.</p>
        <p style="display:flex;gap:10px;flex-wrap:wrap;margin-top:8px;">
            <a class="task-link-btn" asp-page="/Sponsor/Index">Open Sponsor Engagement Details</a>
            <a class="task-link-btn" asp-page="/Sponsor/Tasks">Open Sponsor Tasks</a>
            <a class="task-link-btn" asp-page="/Sponsor/Leads">Your Leads API + download</a>
        </p>
    </div>
}

@if (Model.ShowAttendeeArea)
{
    <div class="card">
        <h2>Your Master Class</h2>
        @if (Model.AttendeeBookingStatus == CommunityHub.Core.Domain.MasterClassBookingStatus.Booked)
        {
            <p class="info">You have reserved a Master Class seat.</p>
        }
        else if (Model.AttendeeBookingStatus == CommunityHub.Core.Domain.MasterClassBookingStatus.MultipleBookings)
        {
            <p class="error">You have more than one Master Class booking - please keep one and cancel the others.</p>
        }
        else
        {
            <p class="error">You have not reserved a Master Class seat yet.</p>
        }
        <a asp-page="/Attendee/Index">Open attendee area</a>
    </div>
}

@if (Model.ShowOrganizerTools)
{
    <div class="card">
        <h2>Organizer tools</h2>
        <p>Attendee reconciliation, sponsor orders, and task management.</p>
        <a asp-page="/Organizer/Index">Open organizer area</a>
    </div>
}

<div class="card">
    <form method="post" asp-page="/Logout">
        <button type="submit" class="secondary">Sign out</button>
    </form>
</div>
