@page "/sessions/{token}/ask"
@model CommunityHub.Pages.Sessions.AskModel
@{
    Layout = "_Layout";
    ViewData["Title"] = Model.Session is null ? "Ask a question" : $"Ask: {Model.Session.Title}";
}

@*
    §136 (operator 2026-06-27): attendee 1:1 questions are DISABLED. This page no
    longer accepts a question (no form, no write). The route is kept so existing
    links don't 404; it now shows a short note pointing attendees to the per-Master
    Class Group Q&A (for Master Class attendees) or to the organizers.
*@

<style>
    .q-hero {
        background: var(--el-darkblue, #1D3380); color: #fff;
        padding: 22px 22px; border-radius: 10px 10px 0 0; margin: 0;
    }
    .q-hero .eyebrow { font-size: 12.5px; text-transform: uppercase; letter-spacing: .06em; opacity: .85; }
    .q-hero h1 { margin: 6px 0 0 0; font-size: 21px; font-weight: 700; line-height: 1.25; }
    .q-hero .speakers { font-size: 13.5px; opacity: .92; margin-top: 8px; line-height: 1.4; }
    .q-body { padding: 20px 22px 24px 22px; }
    .q-note { padding: 16px 18px; background: #eef6ff; border-left: 4px solid #008BD2;
        border-radius: 6px; color: #1f3a5f; font-size: 14px; line-height: 1.6; }
    .q-note h2 { margin: 0 0 8px 0; font-size: 18px; color: #1D3380; }
    .q-note p { margin: 6px 0 0 0; }
</style>

<div class="card" style="padding: 0; overflow: hidden;">
    <div class="q-hero">
        @if (Model.Session is not null)
        {
            <div class="eyebrow">@Model.Session.Event?.DisplayName</div>
            <h1>@Model.Session.Title</h1>
            @if (Model.SpeakerNames.Count > 0)
            {
                <div class="speakers">with @string.Join(", ", Model.SpeakerNames)</div>
            }
        }
        else
        {
            <h1>Questions</h1>
        }
    </div>

    <div class="q-body">
        <div class="q-note" role="status">
            <h2>Pre-event 1:1 questions are no longer available</h2>
            <p>
                We no longer collect individual questions for sessions ahead of the event.
            </p>
            <p>
                If you are attending a <strong>Master Class</strong>, please use that class's
                <strong>Group Q&amp;A</strong> on its Master Class page — your question (and the
                answer) is shared with everyone in that Master Class.
            </p>
            <p>
                For anything else, please <a href="/Contact">contact the organizers</a>.
            </p>
        </div>
    </div>
</div>
