@using CommunityHub.Core.Domain
@model ParticipantTask
@*
    §147: the generic participant task row (volunteer / media / event-partner /Tasks),
    rendered by the shared _TaskListPanel. Structurally identical to _SpeakerTaskRow and
    _SponsorTaskRow (same due / overdue badges, same Mark-complete / Reopen toggle, same
    TaskTextLinkifier description) so every role's task list reads the same. No .ics link
    and no Optional badge here — those are sponsor-only.
*@
@{
    // Overdue = the shared rule (today vs due date, UTC, DateOnly): an unfinished
    // task whose due date is in the past — same as the speaker / sponsor task rows.
    var today = DateOnly.FromDateTime(DateTime.UtcNow);
    var daysOverdue = (Model.State != TaskState.Done && Model.DueDate is DateOnly due && due < today)
        ? today.DayNumber - due.DayNumber
        : 0;
}

<details style="border-bottom:2px solid var(--el-blue);padding:18px 0 22px;">
    <summary style="font-size:18px;font-weight:700;color:var(--el-darkblue);line-height:1.45;cursor:pointer;">
        @Model.Title
        @if (Model.State == TaskState.Done)
        {
            <span style="display:inline-block;margin-left:8px;padding:2px 10px;font-size:0.72em;background:#d6f3e0;color:#1f6d3a;border:1px solid #87cda0;border-radius:9px;vertical-align:middle;font-weight:700;">&check; @Localizer["TaskRow.Done"]</span>
        }
        else if (daysOverdue > 0)
        {
            <span style="display:inline-block;margin-left:8px;padding:2px 10px;font-size:0.78em;background:#fde2e1;color:#c0392b;border:1px solid #e9a8a3;border-radius:9px;vertical-align:middle;font-weight:700;">&#9888; @Localizer["Hub.Overdue"] (@Localizer["TaskRow.OverdueDays", daysOverdue]) &middot; @Localizer["TaskRow.WasDue", Model.DueDate?.ToString("dd/MM/yyyy") ?? ""]</span>
        }
        else if (Model.DueDate is not null)
        {
            <span style="display:inline-block;margin-left:8px;padding:2px 10px;font-size:0.78em;background:#fff3cd;color:#7a5b00;border:1px solid #f0d878;border-radius:9px;vertical-align:middle;font-weight:700;">@Localizer["TaskRow.Due", Model.DueDate?.ToString("dd/MM/yyyy") ?? ""]</span>
        }
    </summary>
    @if (!string.IsNullOrWhiteSpace(Model.Description))
    {
        <p style="margin:8px 0;white-space:pre-line;font-size:15px;">@CommunityHub.Branding.TaskTextLinkifier.Render(Model.Description)</p>
    }
    <div style="display:flex;align-items:center;gap:14px;margin-top:22px;flex-wrap:wrap;">
        <form method="post" asp-page-handler="Toggle" style="display:inline;">
            <input type="hidden" name="taskId" value="@Model.Id" />
            @if (Model.State == TaskState.Done)
            {
                <button type="submit" class="secondary">@Localizer["TaskRow.Reopen"]</button>
            }
            else
            {
                <button type="submit"
                        style="background:#198754;color:#fff;border:1px solid #198754;padding:8px 18px;border-radius:6px;font-weight:600;cursor:pointer;">
                    @Localizer["TaskRow.MarkComplete"]
                </button>
            }
        </form>
        @if (Model.State != TaskState.Done)
        {
            <span style="color:#555;font-size:13px;font-style:italic;">@Localizer["TaskRow.CompleteBeforeDue"]</span>
        }
    </div>
</details>
