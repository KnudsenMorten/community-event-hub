@page
@using CommunityHub.Pages.Shared
@model CommunityHub.Pages.Tasks.IndexModel
@{
    ViewData["Title"] = Localizer["Tasks.Title"].Value;
}

@* §147: ONE unified task list. The page used to render BOTH the shared checklist-card
   component (pending + completed tables) AND a separate "My tasks" list, so every task
   appeared TWICE. Now it renders each task once via the shared _TaskListPanel (completion
   % header → pending at the top → completed collapsed at the bottom), identical to
   /Speaker/Tasks and /Sponsor/Tasks. *@
<div class="card">
    <h2>@Localizer["Tasks.Title"]</h2>
    @await Html.PartialAsync("Shared/_SecondaryEmailBanner")
    @if (Model.Tasks.Count == 0)
    {
        <p>@Localizer["Tasks.NoTasks"]</p>
    }
    else
    {
        @await Html.PartialAsync("Shared/_TaskListPanel",
            new TaskListPanelView { Tasks = Model.Tasks, RowPartialName = "_ParticipantTaskRow" })
    }
    <p style="margin-top:14px;"><a asp-page="/Index">@Localizer["Common.BackToHub"]</a></p>
</div>
