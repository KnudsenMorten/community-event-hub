@page "/volunteer/availability"
@using CommunityHub.Core.Domain
@model CommunityHub.Pages.Volunteer.AvailabilityModel
@{
    ViewData["Title"] = "My Availability";
}

<style>
    .av-intro { color:#374151; font-size:14px; margin:0 0 16px; line-height:1.5; }
    .av-day { background:#f6f8fb; border-radius:8px; padding:14px 16px; margin:12px 0; }
    .av-day h3 { margin:0 0 10px; font-size:15.5px; color:var(--el-darkblue,#1D3380); }
    .av-opts { display:flex; flex-wrap:wrap; gap:8px; margin:0 0 10px; }
    .av-opt { flex:1 1 150px; min-width:0; }
    .av-opt input { position:absolute; opacity:0; pointer-events:none; }
    .av-opt label { display:block; cursor:pointer; border:1.5px solid #c4c8d4; border-radius:8px;
        padding:10px 12px; font-size:13.5px; background:#fff; box-sizing:border-box; text-align:center; }
    .av-opt label .av-pct { display:block; font-weight:700; color:var(--el-darkblue,#1D3380); font-size:14px; }
    .av-opt label .av-sub { display:block; color:#6e7681; font-size:12px; margin-top:2px; }
    .av-opt input:checked + label { border-color:#008BD2; background:#e6f4fb; box-shadow:0 0 0 1px #008BD2 inset; }
    .av-opt input:focus-visible + label { outline:2px solid #1D3380; outline-offset:2px; }
    .av-note { width:100%; box-sizing:border-box; padding:8px 10px; font-size:13.5px;
        border:1px solid #c4c8d4; border-radius:6px; font-family:inherit; }
    .av-note-lbl { display:block; font-size:12.5px; color:#6e7681; margin:0 0 4px; }
    .av-actions { margin-top:18px; }
    .av-actions button { background:#008BD2; color:#fff; border:0; border-radius:8px;
        padding:12px 24px; font-size:15px; font-weight:600; cursor:pointer; }
    .av-note-saved { background:#f0fdf4; border-left:4px solid #16a34a; padding:10px 12px;
        border-radius:6px; margin-bottom:14px; font-size:13.5px; color:#166534; }
    @@media (max-width: 600px) { .av-opt { flex:1 1 100%; } }
</style>

<div class="card">
    <h2 style="margin-top:0;">My Availability</h2>

    @if (!string.IsNullOrEmpty(Model.Notice))
    {
        <div class="av-note-saved">@Model.Notice</div>
    }

    <p class="av-intro">
        Tell us how much you can help on each day. Some volunteers work the whole day,
        others split their time (helping for part of it and attending sessions the rest),
        and some days you may not be available to work at all. We use this to schedule
        your shifts fairly — you will only be assigned tasks inside your available windows.
        You can update this any time.
    </p>

    @if (Model.Days.Count == 0)
    {
        <p style="color:#888;font-style:italic;">No event days are configured yet. Please check back later.</p>
    }
    else
    {
        <form method="post">
            @for (var i = 0; i < Model.Days.Count; i++)
            {
                var d = Model.Days[i];
                <div class="av-day">
                    <h3>@d.Label</h3>
                    <input type="hidden" name="Inputs[@i].Day" value="@d.Day.ToString("yyyy-MM-dd")" />
                    <div class="av-opts">
                        <div class="av-opt">
                            <input type="radio" id="d@(i)_full" name="Inputs[@i].Level"
                                   value="@((int)VolunteerAvailabilityLevel.Full)"
                                   checked="@(d.Level == VolunteerAvailabilityLevel.Full)" />
                            <label for="d@(i)_full"><span class="av-pct">Full day</span><span class="av-sub">100% available to work</span></label>
                        </div>
                        <div class="av-opt">
                            <input type="radio" id="d@(i)_half" name="Inputs[@i].Level"
                                   value="@((int)VolunteerAvailabilityLevel.Half)"
                                   checked="@(d.Level == VolunteerAvailabilityLevel.Half)" />
                            <label for="d@(i)_half"><span class="av-pct">Half day</span><span class="av-sub">~50% — split work &amp; attend</span></label>
                        </div>
                        <div class="av-opt">
                            <input type="radio" id="d@(i)_blocked" name="Inputs[@i].Level"
                                   value="@((int)VolunteerAvailabilityLevel.Blocked)"
                                   checked="@(d.Level == VolunteerAvailabilityLevel.Blocked)" />
                            <label for="d@(i)_blocked"><span class="av-pct">Blocked</span><span class="av-sub">attending only — not working</span></label>
                        </div>
                    </div>
                    <label class="av-note-lbl" for="d@(i)_note">Note (optional) — e.g. which hours you need free</label>
                    <input class="av-note" type="text" id="d@(i)_note" name="Inputs[@i].Note"
                           maxlength="500" value="@d.Note" placeholder="e.g. blocked 13:00–15:00 for a session I want to attend" />
                </div>
            }
            <div class="av-actions">
                <button type="submit">Save my availability</button>
            </div>
        </form>
    }

    <p style="margin-top:18px;">
        <a asp-page="/Volunteer/MySchedule">&larr; Back to My schedule</a>
    </p>
</div>
