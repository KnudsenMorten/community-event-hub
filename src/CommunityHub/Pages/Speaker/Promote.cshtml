@page
@model CommunityHub.Pages.Speaker.PromoteModel
@{
    ViewData["Title"] = "Help to promote your session(s)";
}

<div class="card">
    <h1>Help to promote your session(s)</h1>

    @if (Model.Form.NotSpeaker)
    {
        <p class="error">This page is for speakers.</p>
        <p><a asp-page="/Index">Back to hub</a></p>
    }
    else
    {
        @* The promo content is the SAME partial the inline wizard step renders. *@
        <partial name="_PromoteFields" model="Model.Form" />

        <form method="post" asp-page-handler="Toggle">
            <button type="submit">@(Model.Form.Done ? "Mark as not completed" : "Mark as completed")</button>
        </form>

        <p style="margin-top:14px;"><a asp-page="/Index">Back to hub</a></p>
    }
</div>
