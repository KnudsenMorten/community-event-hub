@page "/Speaker/Tasks"
@using CommunityHub.Core.Domain
@model CommunityHub.Pages.Speaker.TasksModel
@{
    ViewData["Title"] = "My tasks";
}

@* §157 (operator 2026-06-28): the "Am I ready?" readiness rollup card was REMOVED from the top
   of My Tasks (repeat request) — its separate "Still to do" list duplicated the task list below
   and caused confusion. My Tasks now leads the page with a single, clearly-separated Still-to-do
   vs Completed task list (the shared _TaskListPanel). The /Speaker/Readiness page + the organizer
   roster remain; only this card is gone. *@
<div class="card">
    <h1>My tasks</h1>

    @if (!Model.NotSpeaker)
    {
        @await Html.PartialAsync("Shared/_SecondaryEmailBanner")
    }

    @if (Model.NotSpeaker)
    {
        <p class="error">This page is for speakers.</p>
        <p><a asp-page="/Index">@Localizer["Common.BackToHub"]</a></p>
    }
    else if (Model.Tasks.Count == 0)
    {
        <p>No tasks yet — check back soon.</p>
    }
    else
    {
        <div style="margin:6px 0 14px;padding:12px 14px;background:#f8fafc;border:1px solid #cbd5e0;border-left:4px solid var(--el-blue);border-radius:6px;color:#444;font-size:14px;line-height:1.5;">
            <p style="margin:0 0 10px;"><strong>Instructions:</strong></p>
            <p style="margin:0 0 10px;">Below are your speaker tasks. Please complete each one by its stated due date — it helps us finalise the programme, logistics and attendee planning in good time.</p>
            <p style="margin:0;">A red badge means a task is overdue; a yellow badge is an upcoming deadline. Mark a task complete once you're done. If you can't meet a deadline, contact the organizers as soon as possible.</p>
        </div>

        @* §147: the unified task list (completion % header → pending at the top →
           completed collapsed at the bottom), the SAME shared _TaskListPanel the /Tasks
           and /Sponsor/Tasks pages use. The "Task checklist" % here is ParticipantTask
           completion — deliberately distinct from the "Am I ready?" readiness rollup
           card above (which aggregates richer profile/upload signals). *@
        @await Html.PartialAsync("Shared/_TaskListPanel",
            new CommunityHub.Pages.Shared.TaskListPanelView { Tasks = Model.Tasks, RowPartialName = "_SpeakerTaskRow" })
    }
    <p style="margin-top:14px;"><a asp-page="/Index">@Localizer["Common.BackToHub"]</a></p>
</div>
