@page
@model CommunityHub.Pages.Speaker.QuestionsModel
@{
    ViewData["Title"] = Localizer["SpeakerQ.Title"].Value;
    string Stamp(DateTimeOffset at) => at.ToLocalTime().ToString("yyyy-MM-dd HH:mm");
}

@if (Model.AccessDenied)
{
    <div class="card">
        <h1>@Localizer["SpeakerQ.Title"]</h1>
        <p class="error">
            This area is for speakers
            (<strong>@CommunityHub.Branding.RoleDisplay.Name(Model.Role)</strong>).
        </p>
        <p><a asp-page="/Index">Back to hub</a></p>
    </div>
    return;
}

<style>
    /* Mobile-first: one clearly-separated card PER master class at ~360px. */
    .mcq-board { border:1px solid #d7dbe4; border-radius:10px; margin:0 0 18px 0; overflow:hidden; }
    .mcq-board-head { background:var(--el-darkblue,#1D3380); color:#fff; padding:12px 14px; }
    .mcq-board-head h2 { margin:0; font-size:16.5px; line-height:1.3; }
    .mcq-board-head .meta { font-size:12.5px; opacity:.92; margin-top:4px; line-height:1.5; }
    .mcq-board-head .scope { font-size:12px; opacity:.85; margin-top:6px; }
    .mcq-links { margin-top:8px; display:flex; flex-wrap:wrap; gap:8px; }
    .mcq-links a { display:inline-block; background:rgba(255,255,255,.18); color:#fff;
        border:1px solid rgba(255,255,255,.4); border-radius:6px; padding:5px 10px;
        font-size:12.5px; font-weight:600; text-decoration:none; }
    .mcq-links a:hover { background:rgba(255,255,255,.3); }
    .mcq-body { padding:12px 14px; }
    .mcq-c { background:#f6f8fb; border-radius:8px; padding:10px 12px; margin:8px 0; }
    .mcq-c .who { font-weight:600; font-size:13px; color:#1a1a2e; }
    .mcq-c .text { font-size:14px; color:#1a1a2e; white-space:pre-wrap; margin-top:2px; }
    .mcq-c .when { color:#6e7681; font-size:11.5px; margin-top:4px; }
    .mcq-reply { margin-left:20px; border-left:3px solid #008BD2; background:#eef6ff; }
    .mcq-form { display:flex; flex-wrap:wrap; gap:6px; align-items:flex-start; margin-top:8px; }
    .mcq-form textarea { flex:1 1 220px; min-width:0; box-sizing:border-box; padding:8px 10px;
        font-size:13.5px; border:1px solid #c4c8d4; border-radius:6px; min-height:44px; resize:vertical; font-family:inherit; }
    .mcq-form button { background:#008BD2; color:#fff; border:0; border-radius:6px;
        padding:9px 14px; font-size:13px; font-weight:600; cursor:pointer; white-space:nowrap; }
    .mcq-form button:hover { filter:brightness(.95); }
    .mcq-addbox { margin-top:12px; padding-top:12px; border-top:1px dashed #d7dbe4; }
    .mcq-note { background:#f0fdf4; border-left:4px solid #16a34a; padding:10px 12px;
        border-radius:6px; margin-bottom:14px; font-size:13.5px; color:#166534; }
    @@media (max-width: 600px) { .mcq-form textarea, .mcq-form button { flex:1 1 100%; } }
</style>

<div class="card">
    <h1>@Localizer["SpeakerQ.Title"]</h1>
    <p>
        Each of your master classes has its <strong>own separate Group Q&amp;A board</strong>,
        shown below. Questions and replies stay with the master class they belong to &mdash;
        they are never merged across your classes. Replies are visible to your co-speakers,
        the organizers, and the attendees in that master class.
    </p>

    @if (!string.IsNullOrEmpty(Model.Notice))
    {
        <div class="mcq-note" role="status">@Model.Notice</div>
    }

    @if (Model.Boards.Count == 0)
    {
        <p>You don't present any master classes in this edition yet, so there are no Group Q&amp;A boards to show.</p>
    }
</div>

@foreach (var b in Model.Boards)
{
    var topLevel = b.Comments.Where(c => c.ParentCommentId is null).ToList();
    <div class="mcq-board">
        <div class="mcq-board-head">
            <h2>@b.Session.Title</h2>
            @if (b.SpeakerNames.Count > 1)
            {
                <div class="meta">Co-speakers: @string.Join(", ", b.SpeakerNames)</div>
            }
            <div class="scope">Group Q&amp;A for this master class only.</div>
            <div class="mcq-links">
                <a asp-page="/Speaker/MasterClassPrep" asp-route-sessionId="@b.Session.Id">Edit attendee landing page</a>
                <a asp-page="/MasterClassPage" asp-route-sessionId="@b.Session.Id">View landing page</a>
            </div>
        </div>
        <div class="mcq-body">
            @if (topLevel.Count == 0)
            {
                <p style="color:#6e7681;font-size:13.5px;margin:4px 0;">No questions for this master class yet.</p>
            }
            @foreach (var c in topLevel)
            {
                var replies = b.Comments.Where(r => r.ParentCommentId == c.Id).ToList();
                <div class="mcq-c">
                    <div class="who">@c.AuthorDisplayName</div>
                    <div class="text">@c.Body</div>
                    <div class="when">@Stamp(c.CreatedAt)</div>
                </div>
                @foreach (var r in replies)
                {
                    <div class="mcq-c mcq-reply">
                        <div class="who">@r.AuthorDisplayName</div>
                        <div class="text">@r.Body</div>
                        <div class="when">@Stamp(r.CreatedAt)</div>
                    </div>
                }
                <form method="post" asp-page-handler="Reply" asp-route-sessionId="@b.Session.Id" class="mcq-form" style="margin-left:20px;">
                    <input type="hidden" name="ParentCommentId" value="@c.Id" />
                    <label class="sr-only" for="reply-@c.Id">Reply to this question</label>
                    <textarea id="reply-@c.Id" name="ReplyBody" maxlength="2000" required
                              placeholder="Reply (attendees, co-speakers + organizers see this)…"></textarea>
                    <button type="submit">Reply</button>
                </form>
            }

            <div class="mcq-addbox">
                <form method="post" asp-page-handler="Reply" asp-route-sessionId="@b.Session.Id" class="mcq-form">
                    <label class="sr-only" for="add-@b.Session.Id">Post a note to this master class's Group Q&amp;A</label>
                    <textarea id="add-@b.Session.Id" name="ReplyBody" maxlength="2000" required
                              placeholder="Post a note to everyone in this master class…"></textarea>
                    <button type="submit">Post</button>
                </form>
            </div>
        </div>
    </div>
}
