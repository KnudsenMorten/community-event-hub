@page
@model CommunityHub.Pages.Speaker.DetailsModel
@{
    ViewData["Title"] = "Speaker Details";
}

<div class="card">
    <h1>Speaker Details</h1>

    @if (Model.AccessDenied)
    {
        <p class="error">This page is for speakers.</p>
        <p><a asp-page="/Index">Back to hub</a></p>
    }
    else
    {
        <p>Everything about you as a speaker in one place — your name, bio, photo, accreditation and contact preferences. Saving keeps your own edits safe from the next Sessionize import.</p>

        @if (!string.IsNullOrEmpty(Model.Message))
        {
            <partial name="_Flash" model='new CommunityHub.Pages.Shared.FlashModel(Model.Message, Model.IsError ? "error" : "success")' />
        }

        <form method="post" data-ceh-loading data-ceh-dirty>
            <div asp-validation-summary="All" class="ceh-validation-summary"></div>

            @* The speaker-details fields are the SAME partial the inline wizard step renders. *@
            <partial name="/Pages/Speaker/_DetailsFields.cshtml" model="Model.Form" />

            <div style="margin-top:14px;display:flex;gap:10px;flex-wrap:wrap;align-items:center;">
                @* Plain "Save" keeps your edits in the hub WITHOUT touching Zoho — so a
                   small tweak never re-emails the organizers (the manual-update alert).
                   "Save & sync to Zoho" also pushes to Backstage. *@
                <button type="submit" asp-page-handler="Save" data-ceh-loading-text="Saving…">Save</button>
                <button type="submit" asp-page-handler="SaveAndSync" class="secondary" data-ceh-loading-text="Saving &amp; syncing…">Save &amp; sync to Event System (Zoho)</button>
                <partial name="_LastSaved" model="Model.Form.LastSavedAt" />
            </div>
        </form>

        <p style="margin-top:14px;"><a asp-page="/Index">Back to hub</a></p>
    }
</div>
