@page
@model CommunityHub.Pages.ContributorsModel
@{
    ViewData["Title"] = "Contributors";
}

@* Avatar (photo when set, initials otherwise) + name/role row. Mobile-first
   (~360px): the row stays a single flex line, the name wraps if needed.
   REQUIREMENTS §21 — Contributors roles/photos/links. *@
<style>
    .contrib-list { list-style:none; padding:0; margin:0; }
    .contrib-row { display:flex; align-items:center; gap:12px;
        padding:10px 0; border-bottom:1px solid #eee; }
    .contrib-row:last-child { border-bottom:0; }
    .contrib-avatar { flex:0 0 auto; width:40px; height:40px; border-radius:50%;
        object-fit:cover; background:#eef0f5; color:var(--el-darkblue,#1D3380);
        display:flex; align-items:center; justify-content:center;
        font-weight:700; font-size:14px; overflow:hidden; }
    .contrib-detail { min-width:0; }
    .contrib-name { font-weight:700; font-size:15px; line-height:1.25; }
    .contrib-role { font-size:13px; color:#5a6170; margin-top:2px; }
</style>

@functions {
    void RenderPeople(IEnumerable<CommunityHub.Pages.ContributorsModel.Contributor> people)
    {
        <ul class="contrib-list">
            @foreach (var c in people)
            {
                <li class="contrib-row">
                    @if (!string.IsNullOrWhiteSpace(c.PhotoUrl))
                    {
                        <img class="contrib-avatar" src="@c.PhotoUrl" alt="" loading="lazy" />
                    }
                    else
                    {
                        <span class="contrib-avatar" aria-hidden="true">@CommunityHub.Pages.ContributorsModel.Initials(c.Name)</span>
                    }
                    <div class="contrib-detail">
                        <div class="contrib-name">
                            @if (c.LinkedIn is not null)
                            {
                                <a href="@c.LinkedIn" target="_blank" rel="noopener">@c.Name</a>
                            }
                            else
                            {
                                @c.Name
                            }
                        </div>
                        @if (!string.IsNullOrWhiteSpace(c.Role))
                        {
                            <div class="contrib-role">@c.Role</div>
                        }
                    </div>
                </li>
            }
        </ul>
    }
}

<div class="card">
    <h2>Contributors</h2>
    <p>The Community Event Hub is shaped by a team of organizers and a
       growing list of external contributors. This page exists to credit
       every one of them &mdash; the event would not run without them.</p>
    <p>Want to contribute? Open an issue or a pull request on
       <a href="https://github.com/KnudsenMorten/community-event-hub" target="_blank" rel="noopener">GitHub</a>,
       or reach out via the event site. Code, design, content, sponsor
       outreach, dinner logistics &mdash; all of it counts.</p>
</div>

<div class="card">
    <h2>Organizer team</h2>
    <p>The people running the event year-round.</p>
    @{ RenderPeople(Model.Organizers); }
</div>

<div class="card">
    <h2>Contributors</h2>
    <p>External help on code, design, content, sponsor coordination, and
       everything in between.</p>
    @{ RenderPeople(Model.Contributors); }
</div>
