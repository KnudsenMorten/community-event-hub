@page
@model CommunityHub.Pages.Forms.DinnerModel
@{
    ViewData["Title"] = Localizer["Dinner.Title"].Value;
}

<div class="card">
    <h1>@Localizer["Dinner.Title"]</h1>

    @if (Model.AccessDenied)
    {
        <p class="error">@Localizer["Dinner.AccessDenied"]</p>
        <p><a asp-page="/Index">@Localizer["Common.BackToHub"]</a></p>
    }
    else
    {
        @if (Model.Form.IsLocked)
        {
            @* Locked: the shared partial renders the intro + read-only summary + _RequestChangeLink. *@
            <partial name="_DinnerFields" model="Model.Form" />
        }
        else
        {
            @* Shared success toast (REQUIREMENTS §21): role=status, auto-dismiss, dismissable. *@
            <partial name="_Flash" model='new CommunityHub.Pages.Shared.FlashModel(Model.Form.Message, "success")' />

            <form method="post">
                @* Shared inline-validation summary + per-field messages (§21). *@
                <div asp-validation-summary="All" class="ceh-validation-summary"></div>

                @* The dinner fields are the SAME partial the inline wizard step renders. *@
                <partial name="_DinnerFields" model="Model.Form" />

                <button type="submit">@Localizer["Dinner.SaveRsvp"]</button>
                <partial name="_LastSaved" model="Model.Form.LastSavedAt" />
            </form>
        }
        <p><a asp-page="/Index">@Localizer["Common.BackToHub"]</a></p>
    }
</div>
