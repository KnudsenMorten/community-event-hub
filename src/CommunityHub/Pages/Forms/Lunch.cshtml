@page
@model CommunityHub.Pages.Forms.LunchModel
@{
    ViewData["Title"] = Localizer["Lunch.Title"].Value;
}

<div class="card">
    <h2>@Localizer["Lunch.Title"]</h2>

    @if (Model.AccessDenied)
    {
        <p class="error">
            @Localizer["Lunch.AccessDenied", CommunityHub.Branding.RoleDisplay.Name(Model.Role)]
        </p>
        <p><a asp-page="/Index">@Localizer["Common.BackToHub"]</a></p>
    }
    else
    {
        <p>@Localizer["Lunch.Intro"]</p>

        @* Shared success toast (REQUIREMENTS §21): role=status, auto-dismiss, dismissable. *@
        <partial name="_Flash" model='new CommunityHub.Pages.Shared.FlashModel(Model.Message, "success")' />

        <form method="post">

            <label for="LunchName">@Localizer["Common.Name"]</label>
            <input type="text" id="LunchName" value="@Model.FullName" readonly />

            <label for="LunchEmail">@Localizer["Common.Email"]</label>
            <input type="text" id="LunchEmail" value="@Model.Email" readonly />

            <fieldset style="border:0;padding:0;margin:0;">
                <legend style="font-weight:600;font-size:14px;margin-top:10px;">@Localizer["Lunch.WhichLegend"]</legend>
                @if (Model.ShowSetupDay)
                {
                    <label style="font-weight:normal; display:flex; align-items:flex-start; gap:8px; margin-top:8px;">
                        <input type="checkbox" asp-for="LunchSetupDay" style="width:auto;margin:5px 0 0;" />
                        <span>
                            <strong>@Localizer["Lunch.SetupDay", Model.SetupDayLabel]</strong>
                        </span>
                    </label>
                }

                <label style="font-weight:normal; display:flex; align-items:flex-start; gap:8px; margin:8px 0 14px;">
                    <input type="checkbox" asp-for="LunchPreDay" style="width:auto;margin:5px 0 0;" />
                    <span>
                        <strong>@Localizer["Lunch.PreDay", Model.PreDayLabel]</strong>
                    </span>
                </label>
            </fieldset>

            @if (!Model.ShowSetupDay)
            {
                <p style="color:#6b7280;font-size:12px;margin:-4px 0 14px;">
                    @Localizer["Lunch.SetupVolNote"]
                </p>
            }

            <label for="Notes">@Localizer["Lunch.NotesLabel"]</label>
            <textarea asp-for="Notes" rows="3"></textarea>

            <button type="submit">@Localizer["Lunch.Save"]</button>
        </form>

        <p style="color:#6b7280;font-size:12px;margin-top:14px;">
            @Localizer["Lunch.MainNote"]
        </p>

        <p><a asp-page="/Index">@Localizer["Common.BackToHub"]</a></p>
    }
</div>
