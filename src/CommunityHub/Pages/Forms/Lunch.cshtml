@page
@model CommunityHub.Pages.Forms.LunchModel
@{
    ViewData["Title"] = Localizer["Lunch.Title"].Value;
}

<div class="card">
    <h1>@Localizer["Lunch.Title"]</h1>

    @if (Model.Form.AccessDenied)
    {
        @if (Model.Form.PreDayAutoCounted)
        {
            <p class="info">Your pre-day lunch is <strong>automatically counted</strong> — there's nothing to fill in here. Enjoy!</p>
        }
        else
        {
            <p class="error">
                @Localizer["Lunch.AccessDenied", CommunityHub.Branding.RoleDisplay.Name(Model.Form.Role)]
            </p>
        }
        <p><a asp-page="/Index">@Localizer["Common.BackToHub"]</a></p>
    }
    else
    {
        <p>@Localizer["Lunch.Intro"]</p>

        @* Shared success toast (REQUIREMENTS §21): role=status, auto-dismiss, dismissable. *@
        <partial name="_Flash" model='new CommunityHub.Pages.Shared.FlashModel(Model.Form.Message, "success")' />

        <form method="post">

            @* The lunch fields are the SAME partial the inline wizard step renders. *@
            <partial name="_LunchFields" model="Model.Form" />

            <button type="submit">@Localizer["Lunch.Save"]</button>
            <partial name="_LastSaved" model="Model.Form.LastSavedAt" />
        </form>

        <p style="color:#6b7280;font-size:12px;margin-top:14px;">
            @Localizer["Lunch.MainNote", Model.Form.MainDayLabel]
        </p>

        <p><a asp-page="/Index">@Localizer["Common.BackToHub"]</a></p>
    }
</div>
