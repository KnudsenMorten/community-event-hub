@page
@model CommunityHub.Pages.Forms.AcceptModel
@{
    ViewData["Title"] = "Code of Conduct & Privacy";
}

<div class="card">
    <h1>Code of Conduct &amp; Privacy</h1>

    @if (!string.IsNullOrEmpty(Model.Form.Message))
    {
        <p class="@(Model.Form.IsError ? "error" : "info")" role="@(Model.Form.IsError ? "alert" : "status")">@Model.Form.Message</p>
    }

    @if (Model.Form.AlreadyAccepted)
    {
        @* The shared partial renders the policy links + read-only acceptance confirmation. *@
        <partial name="_AcceptFields" model="Model.Form" />
        <p><a asp-page="/Index">Back to hub</a></p>
    }
    else
    {
        <form method="post">
            @* The accept fields are the SAME partial the inline wizard step renders. *@
            <partial name="_AcceptFields" model="Model.Form" />
            <button type="submit" style="margin-top:14px;">Confirm</button>
        </form>
        <p style="margin-top:14px;"><a asp-page="/Index">Back to hub</a></p>
    }
</div>
