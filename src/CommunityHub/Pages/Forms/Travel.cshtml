@page
@model CommunityHub.Pages.Forms.TravelModel
@{
    ViewData["Title"] = Localizer["Travel.Title"].Value;
}

<div class="card">
    <h2>@Localizer["Travel.Title"]</h2>

    @if (Model.AccessDenied)
    {
        <p class="error">
            @Localizer["Travel.AccessDenied", CommunityHub.Branding.RoleDisplay.Name(Model.Role)]
        </p>
        <p><a asp-page="/Index">@Localizer["Common.BackToHub"]</a></p>
    }
    else
    {
        <div style="background:#eef6ff;padding:14px 16px;border-radius:8px;font-size:14px;line-height:1.55;">
            <p style="margin:0 0 8px;"><strong>Travel reimbursement — flights only.</strong>
                We cover economy flights only: up to <strong>EUR 400</strong> per speaker for
                single-speaker sessions, and max <strong>EUR 300</strong> per person for co-speaking
                sessions. If you are not able to get flights within these boundaries, let us know and
                we will work with you on this. You will get the reimbursement after the event and we
                will give you instructions.</p>
            <p style="margin:0;">We do <strong>not</strong> cover taxi, Uber, public transportation,
                or own car in Denmark.</p>
        </div>

        <h3>Eligibility</h3>
        <p style="font-size:14px;">Reimbursement is available to <strong>international speakers only</strong>
            — defined as speakers travelling from outside Denmark.</p>

        <h3>Covered cost</h3>
        <ul style="font-size:14px;">
            <li><strong>Air travel (European)</strong> — EUR 400 for a single-speaker session (round trip),
                or EUR 300 per person for co-speaking sessions. Economy class only; booked at least
                6 weeks before the event.</li>
            <li><strong>Air travel (intercontinental)</strong> — EUR 800 for a single-speaker session
                (round trip), or EUR 600 per person for co-speaking sessions (round trip). Economy class
                only; booked at least 6 weeks before the event.</li>
        </ul>

        <h3>Not covered</h3>
        <ul style="font-size:14px;">
            <li>Seat upgrades / business class</li>
            <li>Ground transport / parking</li>
            <li>Meals / incidentals</li>
        </ul>

        <h3>Booking requirements</h3>
        <ul style="font-size:14px;">
            <li><strong>Economy class</strong> — all flights must be booked in economy class. Upgrades,
                premium economy and business class are not reimbursable.</li>
            <li><strong>Advance booking</strong> — tickets must be booked at least six weeks before the
                event date. Tickets booked later will only be reimbursed up to the equivalent economy
                price available at the six-week mark, unless a documented exception has been approved in
                advance by the organizing committee.</li>
            <li><strong>Original receipts or payment confirmations</strong> (PDF, JPG or PNG) showing
                name, route, dates and total amount paid are required. Booking confirmations without
                payment details are not sufficient.</li>
        </ul>

        <h3>Submission process</h3>
        <ul style="font-size:14px;">
            <li>Submit all reimbursement documents by this form no later than
                <strong>10 January 2027</strong>. Late submissions will not be processed.</li>
            <li>A receipt alone is not sufficient. You must also submit either:
                <ul>
                    <li><strong>Company invoice</strong> — if you have a registered company, an invoice
                        must be issued to Experts Live Denmark. The invoice must include sender details,
                        recipient details, a description (e.g. &ldquo;Speaker travel reimbursement —
                        Experts Live DK 2027&rdquo;) and the total amount.</li>
                    <li><strong>Personal declaration</strong> — if you do not have a company, a personal
                        declaration is acceptable. This must include your full name, address, a valid
                        identification number (passport or national ID), the recipient entity, a
                        description of the costs and the total amount claimed.</li>
                </ul>
            </li>
        </ul>

        <h3>Billing details</h3>
        <p style="font-size:14px;background:#f6f8fb;border-radius:8px;padding:12px 14px;margin:0 0 10px;">
            <strong>Experts Live Denmark</strong><br>
            Strandvejen 21A<br>
            6000 Kolding<br>
            Denmark<br>
            VAT Number: DK44197588
        </p>
        <p style="font-size:14px;">Your bank account details on the invoice must include:
            <strong>Bank name, IBAN, BIC/SWIFT, Account Holder Name</strong>.</p>

        @* Shared success toast (REQUIREMENTS §21): announced via role=status,
           auto-dismisses, dismissable. Replaces the bespoke <p class="info">. *@
        <partial name="_Flash" model='new CommunityHub.Pages.Shared.FlashModel(Model.Message, "success")' />

        <form method="post">

            @* Shared inline-validation pattern: an error summary at the top of the
               form (model-level + any field error), then field-level <span>s below
               each input. asp-validation-summary / asp-validation-for are the
               built-in tag helpers; the .ceh-validation-summary styling is shared. *@
            <div asp-validation-summary="All" class="ceh-validation-summary"></div>

            <label for="TravelName">@Localizer["Common.Name"]</label>
            <input type="text" id="TravelName" value="@Model.FullName" readonly />

            <label for="TravelEmail">@Localizer["Common.Email"]</label>
            <input type="text" id="TravelEmail" value="@Model.Email" readonly />

            <fieldset style="border:0;padding:0;margin:0;">
                <legend style="font-weight:600;font-size:14px;margin-top:10px;">@Localizer["Travel.ClaimLegend"]</legend>
                <div style="display:flex; gap:18px; margin:6px 0 14px;">
                    <label style="font-weight:normal;">
                        <input type="radio" asp-for="RequestReimbursement" value="false" id="ReqNo" />
                        @Localizer["Travel.ClaimNo"]
                    </label>
                    <label style="font-weight:normal;">
                        <input type="radio" asp-for="RequestReimbursement" value="true" id="ReqYes" />
                        @Localizer["Common.Yes"]
                    </label>
                </div>
            </fieldset>

            <div id="ClaimBlock" style="@(Model.RequestReimbursement ? "" : "display:none;")">

                <label for="OriginCity">@Localizer["Travel.OriginCity"]</label>
                <input type="text" asp-for="OriginCity" placeholder="@Localizer["Travel.OriginPlaceholder"]" />

                <label for="AmountChoice">@Localizer["Travel.AmountLabel"]</label>
                <select asp-for="AmountChoice" id="AmountChoice">
                    <option value="@CommunityHub.Pages.Forms.TravelModel.ChoiceNone">@Localizer["Travel.PickAmount"]</option>
                    <option value="@CommunityHub.Pages.Forms.TravelModel.Choice400">
                        @Localizer["Travel.AmountSingle", CommunityHub.Pages.Forms.TravelModel.Cap400]
                    </option>
                    <option value="@CommunityHub.Pages.Forms.TravelModel.Choice300">
                        @Localizer["Travel.AmountCo", CommunityHub.Pages.Forms.TravelModel.Cap300]
                    </option>
                    <option value="@CommunityHub.Pages.Forms.TravelModel.ChoiceOther">
                        @Localizer["Travel.AmountOther"]
                    </option>
                </select>
                <span asp-validation-for="AmountChoice" class="ceh-field-error"></span>

                @{
                    // Keep the "Other amount" block visible on a re-render that
                    // failed validation while "Other" was chosen, so the inline
                    // error is shown next to the field the user must fix.
                    var otherChosen = Model.AmountChoice == CommunityHub.Pages.Forms.TravelModel.ChoiceOther;
                }
                <div id="OtherBlock" style="@(otherChosen ? "" : "display:none;")">
                    <label for="OtherAmountEur">@Localizer["Travel.OtherAmount"]</label>
                    <input type="number" asp-for="OtherAmountEur" min="0" step="1" />
                    <span asp-validation-for="OtherAmountEur" class="ceh-field-error"></span>
                </div>

                <label for="Explanation">@Localizer["Travel.Explanation"]</label>
                <textarea asp-for="Explanation" rows="3"
                          placeholder="@Localizer["Travel.ExplanationPlaceholder"]"></textarea>
                <span asp-validation-for="Explanation" class="ceh-field-error"></span>
            </div>

            <h3 style="margin-top:8px;">Upload your invoice &amp; receipts</h3>
            <p style="font-size:14px;">Upload your invoice and receipts (PDF) here:</p>
            <p style="margin:6px 0 22px;">
                <a href="https://expertslivedk.sharepoint.com/sites/ExpertsLiveDK/Shared%20Documents/Forms/AllItems.aspx?id=%2Fsites%2FExpertsLiveDK%2FShared%20Documents%2FGeneral%2FEvents%2FELDK%202027%2FEventHub%2FFinance%2FTravel%20Reimbursement&amp;viewid=e81e24c2%2Dda6f%2D49c4%2D8961%2D86ba9876779b"
                   target="_blank" rel="noopener noreferrer"
                   style="display:inline-block;background:#1565c0;color:#ffffff;text-decoration:none;font-weight:700;font-size:15px;padding:12px 26px;border-radius:8px;box-shadow:0 2px 6px rgba(0,0,0,0.18);">Upload invoice + receipts (PDF)</a>
            </p>

            <button type="submit">@Localizer["Travel.Save"]</button>
        </form>

        <script>
            (function () {
                var reqYes = document.getElementById('ReqYes');
                var reqNo  = document.getElementById('ReqNo');
                var claim  = document.getElementById('ClaimBlock');
                var pick   = document.getElementById('AmountChoice');
                var other  = document.getElementById('OtherBlock');
                var amount = document.getElementById('OtherAmountEur');
                var form   = pick ? pick.closest('form') : null;
                function syncClaim() { claim.style.display = reqYes.checked ? '' : 'none'; }
                function syncOther() { other.style.display = pick.value === 'other' ? '' : 'none'; }
                reqYes.addEventListener('change', syncClaim);
                reqNo.addEventListener('change', syncClaim);
                pick.addEventListener('change', syncOther);
                syncClaim(); syncOther();

                // Client-side mirror of the server field validation (the shared
                // pattern: client + server field-level messages). HTML5 custom
                // validity gives an inline message without leaving the page; the
                // server re-checks regardless, so JS-off users are still safe.
                if (form) {
                    form.addEventListener('submit', function (e) {
                        if (!reqYes.checked) return;            // not claiming: skip
                        if (pick.value === 'other') {
                            var v = parseFloat(amount.value);
                            if (!(v > 0)) {
                                amount.setCustomValidity(
                                    '@Html.Raw(Localizer["Travel.ErrOtherAmount"].Value.Replace("'", "\\'"))');
                                amount.reportValidity();
                                amount.classList.add('ceh-input-invalid');
                                e.preventDefault();
                            }
                        }
                    });
                    amount.addEventListener('input', function () {
                        amount.setCustomValidity('');
                        amount.classList.remove('ceh-input-invalid');
                    });
                }
            })();
        </script>

        <p><a asp-page="/Index">@Localizer["Common.BackToHub"]</a></p>
    }
</div>
