@page
@model CommunityHub.Pages.Forms.TravelModel
@{
    ViewData["Title"] = Localizer["Travel.Title"].Value;
}

<div class="card">
    <h1>@Localizer["Travel.Title"]</h1>

    @if (Model.AccessDenied)
    {
        <p class="error">
            @Localizer["Travel.AccessDenied", CommunityHub.Branding.RoleDisplay.Name(Model.Form.Role)]
        </p>
        <p><a asp-page="/Index">@Localizer["Common.BackToHub"]</a></p>
    }
    else
    {
        @* Step 1 (upload) + Step 2 (claim) share ONE form so the upload/delete sub-actions
           (__action=…) and the Step-2 save post together. enctype=multipart/form-data is
           required for the receipt upload. The fields are the SAME _TravelFields partial the
           inline wizard step renders, so the two stay byte-for-byte identical. *@
        <form method="post" enctype="multipart/form-data">
            @* Shared inline-validation summary + per-field messages (§21). *@
            <div asp-validation-summary="All" class="ceh-validation-summary"></div>

            <partial name="_TravelFields" model="Model.Form" />

            @* Step-2 main save. Disabled until ≥1 receipt exists (the server re-checks the gate
               regardless); the base button style matches Step 1. *@
            <button type="submit"@(Model.Form.HasReceipt ? "" : " disabled")>Step 2: Request Travel Reimbursement</button>
            <partial name="_LastSaved" model="Model.Form.LastSavedAt" />
        </form>

        <p><a asp-page="/Index">@Localizer["Common.BackToHub"]</a></p>
    }
</div>
