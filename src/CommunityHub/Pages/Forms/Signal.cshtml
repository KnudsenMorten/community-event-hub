@page
@model CommunityHub.Pages.Forms.SignalModel
@{
    ViewData["Title"] = "Join Signal groups";
}

<div class="card">
    <h1>Join Signal groups</h1>

    @* The Signal links + manual-completion status are the SAME partial the inline wizard step renders. *@
    <partial name="_SignalFields" model="Model.Form" />

    @if (!Model.OutOfScope && Model.Form.Links is not null)
    {
        <form method="post" asp-page-handler="Toggle">
            <button type="submit">@(Model.Done ? "Mark as not completed" : "Mark as completed")</button>
        </form>
    }

    <p style="margin-top:14px;"><a asp-page="/Index">Back to hub</a></p>
</div>
