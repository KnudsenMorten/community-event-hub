@page
@model CommunityHub.Pages.Forms.HotelModel
@{
    ViewData["Title"] = Localizer["Hotel.Title"].Value;
}

@* Hotel is arranged + covered by us only for crew/speakers/organizers. Sponsors +
   attendees arrange their own accommodation -> self-contained not-relevant card, no form. *@
@if (!Model.HotelRelevant)
{
    <div class="card">
        <h1>@Localizer["Hotel.Title"]</h1>
        <p style="background:#eef6ff;padding:10px 14px;border-radius:6px;font-size:14px;">
            @Localizer["Hotel.NotRelevant"]
        </p>
        <p><a asp-page="/Index">@Localizer["Common.BackToHub"]</a></p>
    </div>
    return;
}

<div class="card">
    <h1>@Localizer["Hotel.Title"]</h1>

    @if (Model.Form.IsLocked)
    {
        @* Locked: the shared partial renders the read-only summary + _RequestChangeLink. *@
        <partial name="_HotelFields" model="Model.Form" />
    }
    else
    {
        @* Shared success toast (REQUIREMENTS §21): role=status, auto-dismiss, dismissable. *@
        <partial name="_Flash" model='new CommunityHub.Pages.Shared.FlashModel(Model.Form.Message, "success")' />

        <form method="post">
            @* Shared inline-validation summary + per-field messages (§21). *@
            <div asp-validation-summary="All" class="ceh-validation-summary"></div>

            @* The hotel fields are the SAME partial the inline wizard step renders. *@
            <partial name="_HotelFields" model="Model.Form" />

            <button type="submit">@Localizer["Common.Save"]</button>
            <partial name="_LastSaved" model="Model.Form.LastSavedAt" />
        </form>
    }
    <p><a asp-page="/Index">@Localizer["Common.BackToHub"]</a></p>
</div>
