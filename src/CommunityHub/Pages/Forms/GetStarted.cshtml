@page
@model CommunityHub.Pages.Forms.GetStartedModel
@{
    ViewData["Title"] = Localizer["RoleWiz.Title"].Value;
}

@* §148: thin router — OnGet redirects handled roles to the in-wizard stepper host
   (/Forms/Wizard), which renders each entitled step's fields inline. Only the access-denied
   case (a role this generic wizard does not serve, e.g. Attendee) renders here. *@
<div class="card">
    <h1>@Localizer["RoleWiz.Title"]</h1>
    @if (Model.AccessDenied)
    {
        <p class="error">@Localizer["RoleWiz.AccessDenied"]</p>
    }
    <p><a asp-page="/Index">@Localizer["Common.BackToHub"]</a></p>
</div>
