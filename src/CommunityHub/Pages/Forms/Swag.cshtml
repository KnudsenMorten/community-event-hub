@page
@model CommunityHub.Pages.Forms.SwagModel
@{
    ViewData["Title"] = Localizer["Swag.Title"].Value;
}

<div class="card">
    <h1>@Localizer["Swag.Title"]</h1>

    @if (Model.AccessDenied)
    {
        <p class="error">
            @Localizer["Swag.AccessDenied", CommunityHub.Branding.RoleDisplay.Name(Model.Form.Role)]
        </p>
        <p><a asp-page="/Index">@Localizer["Common.BackToHub"]</a></p>
    }
    else
    {
        <p>@Localizer["Swag.Intro"]</p>

        @* Shared success toast (REQUIREMENTS §21): role=status, auto-dismiss, dismissable. *@
        <partial name="_Flash" model='new CommunityHub.Pages.Shared.FlashModel(Model.Form.Message, "success")' />

        <form method="post">
            @* Shared inline-validation summary + per-field messages (§21). *@
            <div asp-validation-summary="All" class="ceh-validation-summary"></div>

            @* The swag fields are the SAME partial the inline wizard step renders. *@
            <partial name="_SwagFields" model="Model.Form" />

            <button type="submit">@Localizer["Swag.Save"]</button>
            <partial name="_LastSaved" model="Model.Form.LastSavedAt" />
        </form>

        <p style="color:#6b7280;font-size:12px;margin-top:14px;">
            @Localizer["Swag.QtyNote"]
        </p>

        <p><a asp-page="/Index">@Localizer["Common.BackToHub"]</a></p>
    }
</div>
