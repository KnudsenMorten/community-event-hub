@model CommunityHub.Forms.Steps.HotelFormModel
@*
    Fields-ONLY partial for the Hotel step (REQUIREMENTS §148, REFERENCE).
    Contains NO <form>, no validation summary, no buttons, no flash — the HOST
    (the standalone /Forms/Hotel page OR the generic /Forms/Wizard shell) owns those
    and places this partial inside its single <form method="post">. Mobile-first.
    Bound to CommunityHub.Forms.Steps.HotelFormModel; input names stay flat
    (NeedsRoom / CheckInDate / …) so the toggle script + model binding are unchanged.
*@

@* Role-specific policy. Organizers see no policy (not relevant to them). *@
@{
    var policyKey = Model.Role switch
    {
        ParticipantRole.Speaker => "Hotel.PolicySpeaker",
        ParticipantRole.Volunteer or ParticipantRole.Media or ParticipantRole.EventPartner => "Hotel.PolicyVolunteer",
        _ => (string?)null,
    };
}
@if (policyKey is not null)
{
    <p style="background:#eef6ff;padding:10px 14px;border-radius:6px;font-size:14px;">
        <strong>@Localizer["Hotel.PolicyLead"]</strong><br />
        @Localizer[policyKey]
    </p>
}

@* Read-only reservation confirmation (REQUIREMENTS §46). *@
@if (Model.IsReservationConfirmed)
{
    <p style="background:#dcfce7;color:#166534;padding:10px 14px;border-radius:6px;font-size:14px;">
        <strong>@Localizer["Hotel.Confirmed"]</strong><br />
        @if (!string.IsNullOrWhiteSpace(Model.AssignedHotelName))
        {
            @Localizer["Hotel.ConfirmedHotel", Model.AssignedHotelName!]<br />
        }
        @Localizer["Hotel.ConfirmationNumberLabel"] <strong>@Model.HotelConfirmationNumber</strong>
    </p>
}

@if (Model.IsLocked)
{
    @* Locked dead-end → read-only summary + self-service "request a change" hand-off (§21). *@
    <p class="error">@Localizer["Common.EditingClosed"]</p>
    <p>@Localizer["Hotel.NeedsRoomLabel"] <strong>@(Model.NeedsRoom == true ? Localizer["Common.Yes"].Value : Model.NeedsRoom == false ? Localizer["Common.No"].Value : Localizer["Common.NotChosen"].Value)</strong></p>
    @if (Model.NeedsRoom == true)
    {
        <p>@Localizer["Hotel.CheckInOut", Model.CheckInDate?.ToString("dd/MM/yyyy") ?? "", Model.CheckOutDate?.ToString("dd/MM/yyyy") ?? ""]</p>
    }
    <partial name="_RequestChangeLink" model="@("Hotel")" />
}
else
{
    <fieldset style="border:1px solid #e5e7eb;border-radius:6px;padding:10px 14px;margin:8px 0;">
        <legend style="font-weight:600;">@Localizer["Hotel.NeedRoomLegend"]</legend>
        <label style="display:block;margin:6px 0;">
            <input type="radio" asp-for="NeedsRoom" value="true" /> @Localizer["Hotel.YesNeed"]
        </label>
        <label style="display:block;margin:6px 0;">
            <input type="radio" asp-for="NeedsRoom" value="false" /> @Localizer["Hotel.NoNeed"]
        </label>
    </fieldset>
    <span asp-validation-for="NeedsRoom" class="ceh-field-error"></span>

    <div id="hotelDetails">
        <label for="CheckInDate">@Localizer["Hotel.CheckInDate"]</label>
        <input type="date" asp-for="CheckInDate" />
        <span asp-validation-for="CheckInDate" class="ceh-field-error"></span>
        <label for="CheckOutDate">@Localizer["Hotel.CheckOutDate"]</label>
        <input type="date" asp-for="CheckOutDate" />
        <span asp-validation-for="CheckOutDate" class="ceh-field-error"></span>
        <label for="Notes">@Localizer["Common.NotesOptional"]</label>
        <textarea asp-for="Notes" rows="3"></textarea>
    </div>

    <script>
        // Show date/notes block only when "Yes" is chosen.
        (function () {
            var details = document.getElementById('hotelDetails');
            var radios  = document.querySelectorAll('input[name="NeedsRoom"]');
            function refresh() {
                var picked = document.querySelector('input[name="NeedsRoom"]:checked');
                var show   = picked && picked.value === 'true';
                details.style.display = show ? '' : 'none';
            }
            radios.forEach(function (r) { r.addEventListener('change', refresh); });
            refresh();
        })();
    </script>
}
