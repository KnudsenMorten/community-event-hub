@model CommunityHub.Forms.Steps.SwagFormModel
@*
    Fields-ONLY partial for the Swag step (REQUIREMENTS §148). Contains NO <form>, no
    validation summary, no flash, no buttons, no last-saved, no Back-to-hub link — the HOST
    (the standalone /Forms/Swag page OR the generic /Forms/Wizard shell) owns those and places
    this partial inside its single <form method="post">. Mobile-first. Bound to
    CommunityHub.Forms.Steps.SwagFormModel; input names stay flat (PoloChoice / WantsGift / …)
    so model binding is unchanged between the standalone page and the inline wizard step.
*@

<label for="SwagName">@Localizer["Common.Name"]</label>
<input type="text" id="SwagName" value="@Model.FullName" readonly />

<label for="SwagEmail">@Localizer["Common.Email"]</label>
<input type="text" id="SwagEmail" value="@Model.Email" readonly />

<label for="PoloChoice">@Localizer["Swag.PoloSize"]</label>
<select asp-for="PoloChoice" required>
    <option value="">@Localizer["Swag.PickSize"]</option>
    @foreach (var size in CommunityHub.Core.Domain.SwagOptions.PoloSizes)
    {
        <option value="@size">@size</option>
    }
</select>
<span asp-validation-for="PoloChoice" class="ceh-field-error"></span>

<fieldset style="border:0;padding:0;margin:0;">
    <legend style="font-weight:600;font-size:14px;margin-top:10px;">@Localizer["Swag.ExtrasLegend"]</legend>
    <div style="display:flex; flex-direction:column; gap:6px; margin:6px 0 14px;">
        <label style="font-weight:normal; display:flex; align-items:center; gap:8px;">
            <input type="checkbox" asp-for="WantsGift" style="width:auto;margin:0;" />
            @Localizer["Swag.WantsGift"]
        </label>
        <label style="font-weight:normal; display:flex; align-items:center; gap:8px;">
            <input type="checkbox" asp-for="WantsCredlyBadge" style="width:auto;margin:0;" />
            @Localizer["Swag.WantsCredly"]
        </label>
    </div>
</fieldset>

<label for="Notes">@Localizer["Common.NotesOptional"]</label>
<textarea asp-for="Notes" rows="3"
          placeholder="@Localizer["Swag.NotesPlaceholder"]"></textarea>
