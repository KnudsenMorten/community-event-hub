@page
@model CommunityHub.Pages.Forms.VolunteerModel
@{
    ViewData["Title"] = "Volunteer availability";
}

<div class="card">
    <h2>Volunteer availability</h2>

    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <p class="info">@Model.Message</p>
    }

    @if (Model.IsLocked)
    {
        <p class="error">Editing is closed for this event.</p>
        <p>Shifts: @string.Join(", ", Model.SelectedShifts)</p>
        <p>Preferred role: @Model.PreferredRole</p>
    }
    else
    {
        <form method="post">
            <p><strong>Which shifts can you work?</strong></p>
            @foreach (var shift in CommunityHub.Pages.Forms.VolunteerModel.ShiftCatalogue)
            {
                <label>
                    <input type="checkbox" name="SelectedShifts" value="@shift"
                           checked="@Model.SelectedShifts.Contains(shift)" />
                    @shift
                </label>
            }
            <label for="PreferredRole">Preferred role (optional)</label>
            <input type="text" asp-for="PreferredRole" />
            <label for="MaxHoursPerDay">Max hours per day</label>
            <input type="text" inputmode="numeric" asp-for="MaxHoursPerDay" />
            <button type="submit">Save</button>
        </form>
    }
    <p><a asp-page="/Index">Back to hub</a></p>
</div>
