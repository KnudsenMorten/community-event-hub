@page
@model CommunityHub.Pages.Forms.SpeakerModel
@{
    ViewData["Title"] = Localizer["SpeakerForm.Title"].Value;
}

<style>
    /* Speaker bio tabs — pure CSS (no JS), keyboard-navigable, mobile-first. */
    .bio-tabs { margin: 8px 0 14px; }
    .bio-tabradio { position: absolute; opacity: 0; pointer-events: none; width: 0; height: 0; }
    .bio-tablist {
        display: flex; flex-wrap: wrap; gap: 6px;
        border-bottom: 2px solid #e5e7eb; margin-bottom: 14px;
    }
    .bio-tab {
        display: inline-block; cursor: pointer; user-select: none;
        padding: 9px 14px; margin: 0; font-weight: 600; font-size: 14px;
        color: #4b5563; background: transparent; border-radius: 8px 8px 0 0;
        border: 2px solid transparent; border-bottom: none;
    }
    .bio-tab:hover { color: var(--el-darkblue); }
    /* Keyboard focus is visible (a11y). */
    .bio-tabradio:focus-visible + .bio-tab,
    .bio-tab:focus-visible { outline: 2px solid var(--el-blue); outline-offset: 2px; }
    /* Each panel hides unless its matching radio is checked. */
    .bio-panel { display: none; }
    #biotab-bio:checked      ~ .bio-panel-bio,
    #biotab-tagline:checked  ~ .bio-panel-tagline,
    #biotab-links:checked    ~ .bio-panel-links,
    #biotab-photo:checked    ~ .bio-panel-photo { display: block; }
    /* Selected-tab styling. The radios precede the labels inside .bio-tablist. */
    #biotab-bio:checked      ~ .bio-tablist [for="biotab-bio"],
    #biotab-tagline:checked  ~ .bio-tablist [for="biotab-tagline"],
    #biotab-links:checked    ~ .bio-tablist [for="biotab-links"],
    #biotab-photo:checked    ~ .bio-tablist [for="biotab-photo"] {
        color: var(--el-darkblue);
        border-color: #e5e7eb;
        background: #f9fafb;
    }
    @@media (max-width: 420px) {
        .bio-tab { padding: 8px 10px; font-size: 13px; }
    }
</style>

<div class="card">
    <h1>@Localizer["SpeakerForm.Title"]</h1>

    @if (Model.AccessDenied)
    {
        <p class="error">
            @Localizer["SpeakerForm.AccessDenied", CommunityHub.Branding.RoleDisplay.Name(Model.Role)]
        </p>
        <p><a asp-page="/Index">@Localizer["Common.BackToHub"]</a></p>
    }
    else
    {
        <p>@Localizer["SpeakerForm.Intro"]</p>

        @* Shared success toast (REQUIREMENTS §21): role=status, auto-dismiss, dismissable. *@
        <partial name="_Flash" model='new CommunityHub.Pages.Shared.FlashModel(Model.Message, "success")' />

        <form method="post" data-ceh-loading data-ceh-dirty>

            @* Shared inline-validation summary (REQUIREMENTS §21). *@
            <div asp-validation-summary="All" class="ceh-validation-summary"></div>

            <label for="SpeakerName">@Localizer["Common.Name"]</label>
            <input type="text" id="SpeakerName" value="@Model.FullName" readonly />

            <label for="SpeakerSignInEmail">@Localizer["SpeakerForm.SignInEmail"]</label>
            <input type="text" id="SpeakerSignInEmail" value="@Model.Email" readonly />
            <p style="color:#6b7280;font-size:12px;margin:-8px 0 14px;">
                @Localizer["SpeakerForm.SignInNote"]
            </p>

            @* Speaker details (preferred email, accreditation, country, gender,
               first-time, speaking days) moved to My Profile (operator 2026-06-21).
               This form is now your BIO. *@
            <p style="background:#eef7ff;border-left:4px solid var(--el-blue);padding:8px 12px;border-radius:6px;font-size:13px;">
                Your contact details (preferred email, accreditation, country, gender) are now on
                <a asp-page="/Profile">My profile</a>.
            </p>

            <h3 style="color:var(--el-darkblue);margin-top:26px;">@Localizer["SpeakerForm.BioHeading"]</h3>
            <p style="color:#6b7280;font-size:13px;margin-top:0;">
                @Localizer["SpeakerForm.BioIntro"]
                @if (Model.LastSessionizeImportAt is not null)
                {
                    <span>@Localizer["SpeakerForm.LastImported", Model.LastSessionizeImportAt?.ToString("dd/MM/yyyy HH:mm 'UTC'") ?? ""]</span>
                }
                @if (Model.BioLastEditedBySpeakerAt is not null)
                {
                    <span>@Localizer["SpeakerForm.LastEdited", Model.BioLastEditedBySpeakerAt?.ToString("dd/MM/yyyy HH:mm 'UTC'") ?? ""]</span>
                }
            </p>

            @* Tabbed, speaker-editable bio. Tabs are plain radio inputs + CSS so
               they work with NO JavaScript and stay keyboard-navigable + a11y
               (ARIA tablist/tab/tabpanel). All tabs live in the SAME form, so a
               single Save submits every section. Mobile-first: tabs wrap. *@
            <div class="bio-tabs">
                @* Radios first so the :checked ~ sibling selectors reach both the
                   tablist (for selected styling) and the panels (for show/hide). *@
                <input type="radio" name="biotab" id="biotab-bio" class="bio-tabradio" checked />
                <input type="radio" name="biotab" id="biotab-tagline" class="bio-tabradio" />
                <input type="radio" name="biotab" id="biotab-links" class="bio-tabradio" />
                <input type="radio" name="biotab" id="biotab-photo" class="bio-tabradio" />

                <div class="bio-tablist" role="tablist" aria-label="@Localizer["SpeakerForm.BioHeading"]">
                    <label class="bio-tab" for="biotab-bio" role="tab" tabindex="0">@Localizer["SpeakerForm.Bio"]</label>
                    <label class="bio-tab" for="biotab-tagline" role="tab" tabindex="0">@Localizer["SpeakerForm.Tagline"]</label>
                    <label class="bio-tab" for="biotab-links" role="tab" tabindex="0">@Localizer["SpeakerForm.LinksTab"]</label>
                    <label class="bio-tab" for="biotab-photo" role="tab" tabindex="0">@Localizer["SpeakerForm.PhotoTab"]</label>
                </div>

                <section class="bio-panel bio-panel-bio" role="tabpanel" aria-label="@Localizer["SpeakerForm.Bio"]">
                    <label for="Biography">@Localizer["SpeakerForm.Bio"]</label>
                    <textarea asp-for="Biography" rows="7" maxlength="4000"
                              data-ceh-counter="@Localizer.GetString("Common.CharCount").Value"
                              placeholder="@Localizer["SpeakerForm.BioPlaceholder"]"></textarea>
                    <span asp-validation-for="Biography" class="error"></span>
                </section>

                <section class="bio-panel bio-panel-tagline" role="tabpanel" aria-label="@Localizer["SpeakerForm.Tagline"]">
                    <label for="Tagline">@Localizer["SpeakerForm.Tagline"]</label>
                    <input type="text" asp-for="Tagline"
                           placeholder="@Localizer["SpeakerForm.TaglinePlaceholder"]" />
                    <span asp-validation-for="Tagline" class="error"></span>
                    <p style="color:#6b7280;font-size:12px;">@Localizer["SpeakerForm.TaglineNote"]</p>
                </section>

                <section class="bio-panel bio-panel-links" role="tabpanel" aria-label="@Localizer["SpeakerForm.LinksTab"]">
                    <label for="LinkedIn">@Localizer["SpeakerForm.LinkedIn"]</label>
                    <input type="url" inputmode="url" asp-for="LinkedIn"
                           placeholder="https://www.linkedin.com/in/you" />
                    <span asp-validation-for="LinkedIn" class="error"></span>

                    <label for="Twitter">@Localizer["SpeakerForm.Twitter"]</label>
                    <input type="url" inputmode="url" asp-for="Twitter"
                           placeholder="https://x.com/you" />
                    <span asp-validation-for="Twitter" class="error"></span>

                    <label for="Blog">@Localizer["SpeakerForm.Blog"]</label>
                    <input type="url" inputmode="url" asp-for="Blog"
                           placeholder="https://yourblog.example" />
                    <span asp-validation-for="Blog" class="error"></span>
                </section>

                <section class="bio-panel bio-panel-photo" role="tabpanel" aria-label="@Localizer["SpeakerForm.PhotoTab"]">
                    <label for="PhotoUrl">@Localizer["SpeakerForm.PhotoLabel"]</label>
                    <input type="url" inputmode="url" asp-for="PhotoUrl"
                           placeholder="https://…/your-photo.jpg" />
                    <span asp-validation-for="PhotoUrl" class="error"></span>
                    <p style="color:#6b7280;font-size:12px;">@Localizer["SpeakerForm.PhotoNote"]</p>
                    @if (!string.IsNullOrWhiteSpace(Model.PhotoUrl))
                    {
                        <img src="@Model.PhotoUrl" alt="@Localizer["SpeakerForm.PhotoAlt"]"
                             style="max-width:160px;border-radius:10px;margin-top:8px;" />
                    }
                </section>
            </div>

            <button type="submit" data-ceh-loading-text="@Localizer["Common.Saving"]">@Localizer["SpeakerForm.Save"]</button>
        </form>

        <p><a asp-page="/Index">@Localizer["Common.BackToHub"]</a></p>
    }
</div>
