@page
@using CommunityHub.Core.Domain
@model CommunityHub.Pages.Organizer.SecureLinkModel
@{
    ViewData["Title"] = "Secure link";
    var now = DateTimeOffset.UtcNow;
}
<div class="card">
    <h1>Secure link</h1>

    @if (Model.AccessDenied)
    {
        <p class="error" role="alert">This area is for organizers only.</p>
    }
    else if (Model.NotFound_)
    {
        <p class="error" role="alert">That participant could not be found in this event.</p>
        <p><a asp-page="/Organizer/Participants">Back to participants</a></p>
    }
    else
    {
        <p>Secure links for <strong>@Model.TargetName</strong>. A link lets a delegate sign in
           <em>scoped to this one person</em> to fill in their onboarding/tasks on their behalf.
           Links are time-bound and can be revoked at any time. Share them privately.</p>

        @if (!string.IsNullOrEmpty(Model.Message))
        {
            <p class="info" role="status">@Model.Message</p>
        }

        <fieldset style="margin-bottom:20px;">
            <legend><strong>Issue a new link</strong></legend>
            <form method="post" asp-page-handler="Issue">
                <input type="hidden" name="ParticipantId" value="@Model.ParticipantId" />
                <label for="Label">Label (optional, e.g. "VP assistant")</label>
                <input type="text" id="Label" name="Label" maxlength="120" />
                <label for="LifetimeDays">Valid for (days)</label>
                <input type="number" id="LifetimeDays" name="LifetimeDays" min="1" max="90" value="7" />
                <div style="margin-top:10px;">
                    <button type="submit">Generate secure link</button>
                </div>
            </form>
        </fieldset>

        <h3>Existing links</h3>
        @if (Model.Grants.Count == 0)
        {
            <p>No secure links have been issued for this person yet.</p>
        }
        else
        {
            <div style="overflow-x:auto;">
            <table style="width:100%;border-collapse:collapse;min-width:600px;">
                <caption class="sr-only">Issued secure links</caption>
                <tr style="text-align:left;border-bottom:2px solid #ddd;">
                    <th scope="col">Label</th><th scope="col">Status</th>
                    <th scope="col">Expires</th><th scope="col">Link</th><th scope="col"></th>
                </tr>
                @foreach (var g in Model.Grants)
                {
                    var valid = g.IsValidAt(now);
                    <tr style="border-bottom:1px solid #eee;">
                        <td>@(string.IsNullOrWhiteSpace(g.Label) ? "—" : g.Label)</td>
                        <td>
                            @if (g.RevokedAt is not null)
                            {
                                <span class="error">Revoked</span>
                            }
                            else if (!valid)
                            {
                                <span class="error">Expired</span>
                            }
                            else
                            {
                                <span class="info">Active</span>
                            }
                        </td>
                        <td>@g.ExpiresAt.UtcDateTime.ToString("yyyy-MM-dd HH:mm") UTC</td>
                        <td style="word-break:break-all;">
                            @if (valid)
                            {
                                <code>@Model.LinkFor(g)</code>
                            }
                            else
                            {
                                <span style="color:#888;">(no longer usable)</span>
                            }
                        </td>
                        <td>
                            @if (valid)
                            {
                                <form method="post" asp-page-handler="Revoke" style="margin:0;">
                                    <input type="hidden" name="ParticipantId" value="@Model.ParticipantId" />
                                    <button type="submit" class="secondary"
                                            asp-route-tokenId="@g.Id">Revoke</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </table>
            </div>
        }

        <p style="margin-top:20px;"><a asp-page="/Organizer/Participants">Back to participants</a></p>
    }
</div>
