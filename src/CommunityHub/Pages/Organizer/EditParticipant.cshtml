@page "{id:int?}"
@model CommunityHub.Pages.Organizer.EditParticipantModel
@{
    ViewData["Title"] = Model.IsNew ? "Add participant" : "Edit participant";
}

<div class="card">
    <h1>@(Model.IsNew ? "Add participant" : $"Edit participant #{Model.Id}")</h1>

    @if (Model.AccessDenied)
    {
        <p class="error">This area is for organizers only.</p>
    }
    else
    {
        if (!string.IsNullOrEmpty(Model.Error))
        {
            <p class="error">@Model.Error</p>
        }
        if (!string.IsNullOrEmpty(Model.Message))
        {
            <p class="info">@Model.Message</p>
        }

        @* Unsaved-changes guard (data-ceh-dirty) + submit loading state
           (data-ceh-loading): an organizer who edits a field then navigates away
           without saving is warned, and a double-click cannot fire two posts.
           Saving clears the guard; the Cancel link opts out via
           data-ceh-allow-leave so leaving via Cancel never trips the prompt. *@
        <form method="post" data-ceh-dirty data-ceh-loading>
            <label for="Email">Email (unique within this edition)</label>
            <input type="email" asp-for="Email" required autocomplete="email" />

            <label for="FullName">Full name</label>
            <input type="text" asp-for="FullName" required />

            <label for="Phone">Phone (optional)</label>
            <input type="text" asp-for="Phone" />

            <label for="Role">Role</label>
            <select asp-for="Role">
                @foreach (var r in Enum.GetValues<CommunityHub.Core.Domain.ParticipantRole>())
                {
                    <option value="@((int)r)">@r</option>
                }
            </select>

            <label for="SponsorCompanyId">Sponsor company id (optional)</label>
            <input type="text" asp-for="SponsorCompanyId"
                   placeholder="Company Manager / WooCommerce company id" inputmode="numeric" />
            <p style="margin:-4px 0 10px;font-size:12px;color:#6b7280;">
                Links a Sponsor-role contact to their company so they see that company's
                tasks. Leave blank for non-sponsor people. Clear it to unlink.
            </p>

            <label style="font-weight:normal; display:flex; align-items:center; gap:8px;">
                <input type="checkbox" asp-for="IsActive" style="width:auto;margin:0;" />
                Active (can sign in)
            </label>

            @if (Model.IsNew)
            {
                <label style="font-weight:normal; display:flex; align-items:center; gap:8px; margin-top:8px;">
                    <input type="checkbox" asp-for="SendWelcome" style="width:auto;margin:0;" />
                    Send the welcome email now
                </label>
            }

            <div style="display:flex; flex-wrap:wrap; gap:10px; margin-top:14px;">
                <button type="submit" data-ceh-loading-text="@Localizer["Common.Saving"]">@(Model.IsNew ? "Create participant" : "Save changes")</button>
                <a asp-page="/Organizer/Participants" class="secondary" data-ceh-allow-leave
                   style="background:var(--el-grey);color:var(--el-darkblue);padding:9px 16px;border-radius:7px;text-decoration:none;font-size:15px;">
                    Cancel
                </a>
            </div>
        </form>

        @if (!Model.IsNew)
        {
            <form method="post" asp-page-handler="SendWelcome" style="margin-top:14px;">
                <input type="hidden" asp-for="Id" />
                <button type="submit"
                        style="background:var(--el-grey);color:var(--el-darkblue);padding:9px 16px;border-radius:7px;border:none;font-size:15px;cursor:pointer;">
                    @(Model.WelcomeAlreadySent ? "Resend welcome email" : "Send welcome email")
                </button>
                <span style="font-size:12px;color:#6b7280;display:block;margin-top:4px;">
                    @(Model.WelcomeAlreadySent
                        ? "A welcome was already sent — this will not send again (idempotent)."
                        : "No welcome has been sent to this person yet.")
                </span>
            </form>
        }

        @if (!Model.IsNew)
        {
            <p style="margin-top:18px;font-size:13px;color:#6b7280;">
                Tip: to edit hotel dates / dinner / swag answers on behalf of this person,
                use <a asp-page="/Organizer/DataGrid">the participant data grid</a>.
            </p>
        }
    }
    <p><a asp-page="/Organizer/Participants">Back to participants</a></p>
</div>
