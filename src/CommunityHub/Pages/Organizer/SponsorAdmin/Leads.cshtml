@page
@model CommunityHub.Pages.Organizer.SponsorAdmin.LeadsModel
@{
    ViewData["Title"] = "Sponsor leads";
}

<div class="card">
    <h1>Sponsor leads</h1>
    @if (Model.AccessDenied)
    {
        <p class="error">This area is for organizers only.</p>
        <p><a asp-page="/Index">Back to hub</a></p>
    }
    else
    {
        <p>Leads, inquiries, and booth-meeting requests pulled daily from
           Zoho CRM. View per sponsor; per-sponsor API keys + download
           samples + notification preferences live in the sections
           below.</p>
        <p><a asp-page="/Organizer/SponsorAdmin/Index">&larr; Back to Sponsor Admin</a></p>

        @if (TempData["Notice"] is string notice)
        {
            <p class="info">@notice</p>
        }
    }
</div>

@if (!Model.AccessDenied)
{
    <div class="card">
        <h2>1. Pipeline status</h2>
        <table style="width:100%;border-collapse:collapse;max-width:560px;">
            <tr style="border-bottom:1px solid #eee;"><td>Total leads in DB</td><td><strong>@Model.TotalLeads</strong></td></tr>
            <tr style="border-bottom:1px solid #eee;"><td>New in last 7 days</td><td><strong>@Model.LeadsLast7d</strong></td></tr>
            <tr><td>Last Zoho sync</td><td><strong>@(Model.LastZohoSyncAt?.ToString("u") ?? "(never &mdash;” pipeline not configured yet)")</strong></td></tr>
        </table>
        <p style="margin-top:14px;">
            <form method="post" asp-page-handler="SyncNow" style="display:inline;">
                <button type="submit">Run Zoho sync now</button>
            </form>
        </p>
    </div>

    <div class="card">
        <h2>2. Per-sponsor API keys + download</h2>
        <p>Every sponsor company gets its own API key. The key authenticates
           two endpoints (JSON + CSV) that return that sponsor's leads
           only. The key is shown ONCE at issue time &mdash;” copy it and hand
           it to the sponsor immediately; the hub stores only its SHA256
           hash.</p>

        @if (Model.FreshKeyForSponsor is string freshSponsor && Model.FreshKeyValue is string freshKey)
        {
            <div style="background:#fff8e1;border-left:3px solid #f4b400;padding:12px 14px;border-radius:4px;margin:12px 0;">
                <strong>New key issued for sponsor '@freshSponsor':</strong>
                <pre style="background:#fff;border:1px solid #d0d7de;border-radius:4px;padding:8px 10px;margin:8px 0 0 0;overflow-x:auto;user-select:all;">@freshKey</pre>
                <p style="margin:8px 0 0 0;font-size:12.5px;color:#5a6170;">
                    Hand this to the sponsor NOW &mdash;” it's not retrievable after you leave the page.
                </p>
            </div>
        }

        <!-- overflow-x wrapper: the 32-char tokens blow a 360px phone
             viewport otherwise (caught by the admin mobile suite) -->
        <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;min-width:760px;">
            <tr style="text-align:left;border-bottom:2px solid #ddd;">
                <th>Sponsor company id</th>
                <th>Deterministic token (current)</th>
                <th>Ver</th>
                <th>Legacy key</th>
                <th style="width:340px;">Actions</th>
            </tr>
            @foreach (var s in Model.SponsorKeys)
            {
                <tr style="border-bottom:1px solid #eee;">
                    <td><code>@s.SponsorCompanyId</code></td>
                    <td>
                        @if (!string.IsNullOrEmpty(s.DeterministicToken))
                        {
                            <code style="font-size:11.5px;background:#eef0f5;padding:2px 6px;border-radius:4px;user-select:all;">@s.DeterministicToken</code>
                        }
                        else
                        {
                            <em style="color:#cf222e;">global secret missing</em>
                        }
                    </td>
                    <td>v@s.TokenVersion</td>
                    <td>@(s.KeyPrefix is null ? "—" : s.KeyPrefix + "...")</td>
                    <td>
                        <form method="post" asp-page-handler="BumpTokenVersion" style="display:inline;" onsubmit="return confirm('Bump @s.SponsorCompanyId to v@(s.TokenVersion + 1)? Old token stops working immediately.');">
                            <input type="hidden" name="sponsorCompanyId" value="@s.SponsorCompanyId" />
                            <button type="submit">Bump version</button>
                        </form>
                        @if (s.KeyPrefix is not null)
                        {
                            <form method="post" asp-page-handler="RevokeKey" style="display:inline;" onsubmit="return confirm('Revoke legacy issued key for @s.SponsorCompanyId?');">
                                <input type="hidden" name="sponsorCompanyId" value="@s.SponsorCompanyId" />
                                <button type="submit" class="secondary">Revoke legacy</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </table>
        </div>

        <h3 style="margin-top:24px;">Download samples</h3>
        <p>Sponsors call these endpoints with their API key in either the
           <code>X-Sponsor-Api-Key</code> request header (preferred) or
           a <code>?key=</code> query parameter (browser-friendly).</p>

        <h4>A. PowerShell &mdash;” download CSV to file</h4>
<pre style="background:#0d1117;color:#c9d1d9;padding:12px 14px;border-radius:6px;overflow-x:auto;">
$key       = 'PASTE-YOUR-SPONSOR-API-KEY-HERE'
$cid       = 'YOUR-SPONSOR-COMPANY-ID'
$outFile   = "$env:USERPROFILE\Downloads\leads-$cid-$(Get-Date -Format yyyy-MM-dd).csv"

Invoke-WebRequest -Uri "@(Model.BaseUrl)/api/v1/sponsors/$cid/leads.csv" `
                  -Headers @@{ 'X-Sponsor-Api-Key' = $key } `
                  -OutFile $outFile
Write-Host "Saved $outFile"
</pre>

        <h4>B. PowerShell &mdash;” fetch JSON, pipe into your own pipeline</h4>
<pre style="background:#0d1117;color:#c9d1d9;padding:12px 14px;border-radius:6px;overflow-x:auto;">
$key = 'PASTE-YOUR-SPONSOR-API-KEY-HERE'
$cid = 'YOUR-SPONSOR-COMPANY-ID'

$resp = Invoke-RestMethod -Uri "@(Model.BaseUrl)/api/v1/sponsors/$cid/leads.json" `
                          -Headers @@{ 'X-Sponsor-Api-Key' = $key }

"$($resp.count) leads for $cid"
$resp.leads | Where-Object { $_.LeadKind -eq 'Meeting' } |
              Select-Object FullName, Company, Email, CapturedAt
</pre>

        <h4>C. PowerShell &mdash;” scheduled task (daily, 06:30 local)</h4>
<pre style="background:#0d1117;color:#c9d1d9;padding:12px 14px;border-radius:6px;overflow-x:auto;">
# Save as Download-Leads.ps1, then register the task.
$key     = $env:SPONSOR_API_KEY      # set once in scheduled-task env
$cid     = 'YOUR-SPONSOR-COMPANY-ID'
$outDir  = "$env:USERPROFILE\Downloads\sponsor-leads"
$null    = New-Item -ItemType Directory -Force -Path $outDir
$outFile = Join-Path $outDir "leads-$cid-$(Get-Date -Format yyyy-MM-dd).csv"
Invoke-WebRequest -Uri "@(Model.BaseUrl)/api/v1/sponsors/$cid/leads.csv" `
                  -Headers @@{ 'X-Sponsor-Api-Key' = $key } `
                  -OutFile $outFile

# Register the task (one-shot, run from an elevated PowerShell):
#   schtasks /create /tn "Download sponsor leads" /sc daily /st 06:30 /rl LIMITED `
#            /tr "powershell -NoProfile -File C:\path\Download-Leads.ps1"
</pre>

        <h4>D. Browser direct download (no PowerShell)</h4>
        <p>Paste this URL into the address bar &mdash;” the browser downloads
           <code>leads-&lt;sponsor&gt;-&lt;date&gt;.csv</code> into the
           Downloads folder. The query-string key form is only intended
           for this manual case (avoid embedding in bookmarks since URLs
           land in browser history):</p>
<pre style="background:#0d1117;color:#c9d1d9;padding:12px 14px;border-radius:6px;overflow-x:auto;">@(Model.BaseUrl)/api/v1/sponsors/YOUR-SPONSOR-COMPANY-ID/leads.csv?key=PASTE-API-KEY-HERE</pre>
    </div>

    <div class="card">
        <h2>3. Notification preferences (per sponsor)</h2>
        <p>Sponsors can opt-in to a delta digest of new leads since the
           last notification (daily at 06:15 UTC, or real-time on the
           hourly run). Recipients left blank = all sponsor contacts of
           the company. Saved per company; the SponsorLeadsJob reads
           these on every run.</p>

        @foreach (var s in Model.SponsorKeys)
        {
            var pref = Model.NotifyPrefs.TryGetValue(s.SponsorCompanyId, out var p0) ? p0 : null;
            <details style="margin:10px 0;padding:8px 12px;border:1px solid #d0d7de;border-radius:6px;">
                <summary><strong>@s.SponsorCompanyId</strong>
                    @if (pref?.Enabled == true)
                    {
                        <span class="info" style="font-size:13px;">(@pref.Cadence digest on)</span>
                    }
                </summary>
                <form method="post" asp-page-handler="SaveNotifyPrefs" style="display:grid;grid-template-columns:160px 1fr;gap:8px 12px;max-width:680px;align-items:center;margin-top:10px;">
                    <input type="hidden" name="sponsorCompanyId" value="@s.SponsorCompanyId" />

                    <label>Enabled</label>
                    <label><input type="checkbox" name="enabled" value="true"
                                  checked="@(pref?.Enabled == true)" /> Send digest of new leads</label>

                    <label>Cadence</label>
                    <select name="cadence">
                        <option value="Daily" selected="@(pref is null || pref.Cadence == SponsorLeadNotifyCadence.Daily)">Daily (06:15 UTC)</option>
                        <option value="RealTime" selected="@(pref?.Cadence == SponsorLeadNotifyCadence.RealTime)">Real-time (hourly delta)</option>
                    </select>

                    <label>Recipients</label>
                    <input name="recipients" type="text" placeholder="comma-separated emails (blank = all company contacts)"
                           value="@pref?.Recipients" />

                    <label>Skip junk</label>
                    <label><input type="checkbox" name="skipJunk" value="true"
                                  checked="@(pref is null || pref.SkipJunk)" /> Exclude leads the AI screen marked as junk</label>

                    <div></div>
                    <div><button type="submit">Save preferences</button>
                        @if (pref?.LastDeltaSentAt is not null)
                        {
                            <span style="color:#6b7280;font-size:13px;margin-left:8px;">Last digest:
                            @pref.LastDeltaSentAt.Value.UtcDateTime.ToString("dd MMM HH:mm") UTC</span>
                        }
                    </div>
                </form>
            </details>
        }
    </div>

    <div class="card">
        <h2>4. Leads + actions</h2>
        <p>Search, sort and page the captured leads. Nothing here hard-deletes
           &mdash; Ignore and Junk hide the row from the sponsor feed and this
           default view but preserve it (the AI screen learns from your overrides).</p>

        <form method="get" style="display:flex;flex-wrap:wrap;gap:12px;align-items:flex-end;margin-bottom:10px;">
            <div style="flex:2 1 220px;min-width:160px;">
                <label for="Search">@Localizer["OrgGrid.Search"] (name, email, sponsor)</label>
                <input type="text" id="Search" name="Search" value="@Model.Search" />
            </div>
            <div style="flex:1 1 160px;min-width:140px;">
                <label for="SponsorFilter">Sponsor</label>
                <select id="SponsorFilter" name="SponsorFilter">
                    <option value="">All sponsors</option>
                    @foreach (var s in Model.SponsorKeys)
                    {
                        <option value="@s.SponsorCompanyId" selected="@(Model.SponsorFilter == s.SponsorCompanyId)">@s.SponsorCompanyId</option>
                    }
                </select>
            </div>
            <label style="display:inline-flex;align-items:center;gap:8px;font-weight:400;flex:0 0 auto;margin-bottom:8px;">
                <input type="checkbox" name="ShowHidden" value="true"
                       checked="@Model.ShowHidden" style="width:auto;margin:0;" /> Show ignored / junk rows
            </label>
            @* keep the current sort; reset to page 1 on a new filter *@
            <input type="hidden" name="Sort" value="@Model.Sort" />
            <input type="hidden" name="Desc" value="@Model.Desc" />
            <div style="flex:0 0 auto;">
                <button type="submit">@Localizer["OrgGrid.Apply"]</button>
            </div>
        </form>

        @if (Model.Leads.Count == 0)
        {
            <p class="info">@Localizer["OrgGrid.NoMatch"] Leads land here from the nightly
               Zoho CRM pull (05:15 UTC) or the <strong>Sync now</strong>
               button at the top &mdash; both require <code>Zoho__CrmEnabled=true</code>.</p>
        }
        else
        {
            <p role="status">
                @Localizer["OrgGrid.ShowingRange", Model.Paging.FirstRowNumber, Model.Paging.LastRowNumber, Model.Paging.TotalItems]
            </p>
            <div style="overflow-x:auto;">
            <table style="width:100%;border-collapse:collapse;min-width:900px;">
                <caption class="sr-only">Sponsor leads for this edition</caption>
                <tr style="text-align:left;border-bottom:2px solid #ddd;">
                    <th scope="col" aria-sort="@Model.AriaSort("captured")">
                        <a asp-page-handler="" asp-route-ShowHidden="@Model.ShowHidden" asp-route-SponsorFilter="@Model.SponsorFilter"
                           asp-route-Search="@Model.Search" asp-route-Sort="captured" asp-route-Desc="@Model.NextDescFor("captured")" asp-route-PageNo="1">Captured@Model.SortIndicator("captured")</a>
                    </th>
                    <th scope="col" aria-sort="@Model.AriaSort("company")">
                        <a asp-page-handler="" asp-route-ShowHidden="@Model.ShowHidden" asp-route-SponsorFilter="@Model.SponsorFilter"
                           asp-route-Search="@Model.Search" asp-route-Sort="company" asp-route-Desc="@Model.NextDescFor("company")" asp-route-PageNo="1">Sponsor@Model.SortIndicator("company")</a>
                    </th>
                    <th scope="col">Type</th>
                    <th scope="col" aria-sort="@Model.AriaSort("name")">
                        <a asp-page-handler="" asp-route-ShowHidden="@Model.ShowHidden" asp-route-SponsorFilter="@Model.SponsorFilter"
                           asp-route-Search="@Model.Search" asp-route-Sort="name" asp-route-Desc="@Model.NextDescFor("name")" asp-route-PageNo="1">@Localizer["OrgGrid.Col.Name"]@Model.SortIndicator("name")</a>
                    </th>
                    <th scope="col">Company</th>
                    <th scope="col">@Localizer["OrgGrid.Col.Email"]</th>
                    <th scope="col">AI</th>
                    <th scope="col" aria-sort="@Model.AriaSort("status")">
                        <a asp-page-handler="" asp-route-ShowHidden="@Model.ShowHidden" asp-route-SponsorFilter="@Model.SponsorFilter"
                           asp-route-Search="@Model.Search" asp-route-Sort="status" asp-route-Desc="@Model.NextDescFor("status")" asp-route-PageNo="1">@Localizer["OrgGrid.Col.Status"]@Model.SortIndicator("status")</a>
                    </th>
                    <th scope="col" style="width:300px;">Actions</th>
                </tr>
                @foreach (var l in Model.Leads)
                {
                    <tr style="border-bottom:1px solid #eee;@(l.Status is SponsorLeadStatus.Ignore or SponsorLeadStatus.Junk ? "opacity:.55;" : "")">
                        <td style="white-space:nowrap;">@l.CapturedAt.UtcDateTime.ToString("dd MMM HH:mm")</td>
                        <td>@l.SponsorCompanyId</td>
                        <td>@l.LeadKind</td>
                        <td>@l.FullName
                            @if (!string.IsNullOrWhiteSpace(l.JobTitle))
                            {
                                <br /><span style="color:#6b7280;font-size:12px;">@l.JobTitle</span>
                            }
                        </td>
                        <td>@l.Company</td>
                        <td style="word-break:break-all;">@l.Email</td>
                        <td>
                            @if (l.AiScreenScore is not null)
                            {
                                <span title="@l.AiScreenLabel"
                                      style="display:inline-block;padding:2px 8px;border-radius:999px;font-size:12px;font-weight:600;background:@(l.AiScreenScore >= 60 ? "#dafbe1" : l.AiScreenScore >= 30 ? "#fff8c5" : "#ffebe9");">
                                    @l.AiScreenScore @l.AiScreenLabel</span>
                                @* Re-derive the SAME breakdown the screen scored with (single
                                   source of truth) so the organizer can see WHY this lead scored
                                   the way it did — no opaque badge (REQUIREMENTS §21 "explain AI scores"). *@
                                var why = CommunityHub.Core.Integrations.Sponsors.SponsorLeadScoreExplainer.Compute(l);
                                <details style="margin-top:4px;font-size:12px;">
                                    <summary style="cursor:pointer;color:#0969da;">@Localizer["LeadScore.WhyTitle"]</summary>
                                    <ul style="list-style:none;margin:4px 0 0;padding:0;color:#374151;">
                                        <li style="display:flex;justify-content:space-between;gap:10px;">
                                            <span>@Localizer["LeadScore.BaseLine"]</span>
                                            <span>@why.BaseScore</span>
                                        </li>
                                        @foreach (var f in why.Factors)
                                        {
                                            <li style="display:flex;justify-content:space-between;gap:10px;color:@(f.Points >= 0 ? "#1a7f37" : "#cf222e");">
                                                <span>@Localizer[f.ReasonKey]</span>
                                                <span>@(f.Points >= 0 ? "+" : "")@f.Points</span>
                                            </li>
                                        }
                                        <li style="display:flex;justify-content:space-between;gap:10px;font-weight:600;border-top:1px solid #eee;margin-top:4px;padding-top:4px;">
                                            <span>@Localizer["LeadScore.TotalLine"]</span>
                                            <span>@why.FinalScore</span>
                                        </li>
                                    </ul>
                                </details>
                            }
                        </td>
                        <td>@l.Status
                            @if (l.LastReplyAt is not null)
                            {
                                <br /><span style="color:#6b7280;font-size:12px;">replied @l.LastReplyAt.Value.UtcDateTime.ToString("dd MMM")</span>
                            }
                        </td>
                        <td>
                            <div style="display:flex;flex-wrap:wrap;gap:4px;">
                                <form method="post" asp-page-handler="MarkLeadProcessed" asp-route-ShowHidden="@Model.ShowHidden" asp-route-SponsorFilter="@Model.SponsorFilter" asp-route-Search="@Model.Search" asp-route-Sort="@Model.Sort" asp-route-Desc="@Model.Desc" asp-route-PageNo="@Model.PageNo" style="display:inline;">
                                    <input type="hidden" name="leadId" value="@l.Id" />
                                    <button type="submit" class="secondary" style="font-size:12px;padding:4px 9px;">Processed</button>
                                </form>
                                <form method="post" asp-page-handler="MarkLeadInterest" asp-route-ShowHidden="@Model.ShowHidden" asp-route-SponsorFilter="@Model.SponsorFilter" asp-route-Search="@Model.Search" asp-route-Sort="@Model.Sort" asp-route-Desc="@Model.Desc" asp-route-PageNo="@Model.PageNo" style="display:inline;">
                                    <input type="hidden" name="leadId" value="@l.Id" />
                                    <button type="submit" class="secondary" style="font-size:12px;padding:4px 9px;">Interest</button>
                                </form>
                                <form method="post" asp-page-handler="MarkLeadIgnore" asp-route-ShowHidden="@Model.ShowHidden" asp-route-SponsorFilter="@Model.SponsorFilter" asp-route-Search="@Model.Search" asp-route-Sort="@Model.Sort" asp-route-Desc="@Model.Desc" asp-route-PageNo="@Model.PageNo" style="display:inline;">
                                    <input type="hidden" name="leadId" value="@l.Id" />
                                    <button type="submit" class="secondary" style="font-size:12px;padding:4px 9px;">Ignore</button>
                                </form>
                                <form method="post" asp-page-handler="MarkLeadJunk" asp-route-ShowHidden="@Model.ShowHidden" asp-route-SponsorFilter="@Model.SponsorFilter" asp-route-Search="@Model.Search" asp-route-Sort="@Model.Sort" asp-route-Desc="@Model.Desc" asp-route-PageNo="@Model.PageNo" style="display:inline;">
                                    <input type="hidden" name="leadId" value="@l.Id" />
                                    <button type="submit" class="secondary" style="font-size:12px;padding:4px 9px;">Junk</button>
                                </form>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(l.Email))
                            {
                                <details style="margin-top:4px;">
                                    <summary style="font-size:12px;color:#0969da;cursor:pointer;">Reply&hellip;</summary>
                                    <form method="post" asp-page-handler="ReplyLead" asp-route-ShowHidden="@Model.ShowHidden" asp-route-SponsorFilter="@Model.SponsorFilter" asp-route-Search="@Model.Search" asp-route-Sort="@Model.Sort" asp-route-Desc="@Model.Desc" asp-route-PageNo="@Model.PageNo" style="margin-top:6px;">
                                        <input type="hidden" name="leadId" value="@l.Id" />
                                        <input name="subject" type="text" placeholder="Subject" style="margin:0 0 6px;max-width:280px;" />
                                        <textarea name="body" rows="3" placeholder="Message (plain text)" style="margin:0 0 6px;max-width:280px;"></textarea>
                                        <button type="submit" style="font-size:12px;padding:5px 12px;">Send reply</button>
                                    </form>
                                </details>
                            }
                        </td>
                    </tr>
                }
            </table>
            </div>
        }
    </div>

    <div class="card">
        <h2>Going live checklist</h2>
        <ol>
            <li><strong>Zoho OAuth refresh token</strong> with the
                <code>ZohoCRM.modules.READ</code> scope (the existing token
                covers Backstage + Bookings only).</li>
            <li><strong>CRM field</strong> holding the sponsor company id on
                each lead record &mdash; name it in
                <code>Zoho__CrmSponsorCompanyIdField</code>
                (default <code>Sponsor_Company_Id</code>).</li>
            <li>Flip <strong><code>Zoho__CrmEnabled=true</code></strong> on the
                web + Functions apps. Everything else (tables, sync job at
                05:15 UTC, digests, feed, this grid) is already live.</li>
        </ol>
    </div>
}

