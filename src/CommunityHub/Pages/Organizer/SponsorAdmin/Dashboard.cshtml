@page
@model CommunityHub.Pages.Organizer.SponsorAdmin.DashboardModel
@{
    ViewData["Title"] = "Sponsor status dashboard";
}

<div class="card">
    <h1>Sponsor status dashboard</h1>
    @if (Model.AccessDenied)
    {
        <p class="error">This area is for organizers only.</p>
        <p><a asp-page="/Index">Back to hub</a></p>
    }
    else
    {
        <p>Per-sponsor view of task completion and lead volume. Sorted by
           overdue tasks first.</p>
        <p><a asp-page="/Organizer/SponsorAdmin/Index">&larr; Back to Sponsor Admin</a></p>

        @if (!string.IsNullOrEmpty(Model.ActionMessage))
        {
            <p class="info" role="status">@Model.ActionMessage</p>
        }

        <div style="margin:10px 0 16px;padding:12px 14px;background:#eff6ff;border:1px solid #bfdbfe;border-left:4px solid #2563eb;border-radius:8px;">
            <strong>Webshop → Zoho maintenance.</strong>
            <p style="margin:4px 0 8px;font-size:13.5px;color:#374151;">
                Fill each sponsor's Event Coordinator from the webshop default coordinator (only where empty — CEH owns it once set),
                then re-sync every sponsor record to Zoho Backstage. This also corrects the older UTF-8 mojibake (æ/ø/å) in Zoho.
            </p>
            <form method="post" asp-page-handler="MigrateResync" style="display:inline;margin:0;">
                <button type="submit" data-ceh-confirm="confirmMigrateResync" data-ceh-count="@Model.Rows.Count">Migrate coordinators &amp; re-sync all to Zoho</button>
            </form>
            <form method="post" asp-page-handler="Provision" style="display:inline;margin:0 0 0 8px;">
                <button type="submit" data-ceh-confirm="confirmProvision" data-ceh-count="@Model.Rows.Count">Create / link missing in Zoho</button>
            </form>
            <form method="post" asp-page-handler="ReconcileErp" style="display:inline;margin:0 0 0 8px;">
                <button type="submit" data-ceh-confirm="confirmReconcileErp">Reconcile ERP → webshop (users + defaults)</button>
            </form>
            <p style="font-size:12px;color:#6b7280;margin:8px 0 0;">
                <strong>Create / link</strong> provisions sponsors/exhibitors that don't exist in Zoho yet (replaces the legacy sync script — also runs automatically after each order pull when enabled).
            </p>
        </div>
        <partial name="_ConfirmModal" model='new CommunityHub.Pages.Shared.ConfirmModalModel(
            Id: "confirmProvision",
            Title: "Create / link sponsors in Zoho?",
            Body: "This creates or links {count} sponsor compan(ies) in Zoho Backstage from webshop data. Existing/linked companies are left unchanged. Continue?",
            ConfirmLabel: "Run it",
            CancelLabel: "Cancel",
            DefaultCount: Model.Rows.Count.ToString())' />
        <partial name="_ConfirmModal" model='new CommunityHub.Pages.Shared.ConfirmModalModel(
            Id: "confirmReconcileErp",
            Title: "Reconcile ERP to webshop?",
            Body: "This creates missing Company Manager users from the backend group-1 contacts and sets each company default signer + event coordinator from the contact roles (never overwriting a curated default). Contacts missing a Role:1/Role:2 are emailed to the organizer. Continue?",
            ConfirmLabel: "Run it",
            CancelLabel: "Cancel")' />
        <partial name="_ConfirmModal" model='new CommunityHub.Pages.Shared.ConfirmModalModel(
            Id: "confirmMigrateResync",
            Title: "Migrate coordinators & re-sync to Zoho?",
            Body: "This fills missing Event Coordinators from the webshop and re-syncs {count} sponsor compan(ies) to Zoho Backstage, overwriting the synced fields there. Continue?",
            ConfirmLabel: "Run it",
            CancelLabel: "Cancel",
            DefaultCount: Model.Rows.Count.ToString())' />

        @if (Model.ZohoPipelinePending)
        {
            <p class="info" style="background:#fff8e1;border-left:3px solid #f4b400;padding:8px 12px;border-radius:4px;">
                <strong>Zoho pipeline not yet configured.</strong>
                The lead counters render as zero until the Zoho sync job is wired up
                (Zoho OAuth + DB migration + storage SAS). See the
                <a asp-page="/Organizer/SponsorAdmin/Leads">Leads page</a> for the
                full checklist.
            </p>
        }
    }
</div>

@if (!Model.AccessDenied)
{
    <div class="card">
        <h2>Sponsors (@Model.Rows.Count)</h2>
        @if (Model.Rows.Count == 0)
        {
            <p class="info">No sponsor companies have participants with tasks yet.</p>
        }
        else
        {
            <div style="overflow-x:auto;">
            <table style="width:100%;border-collapse:collapse;min-width:640px;">
                <tr style="text-align:left;border-bottom:2px solid #ddd;">
                    <th>Company</th>
                    <th style="text-align:right;">Contacts</th>
                    <th style="text-align:right;">Tasks done</th>
                    <th style="text-align:right;">Total tasks</th>
                    <th style="text-align:right;">Overdue</th>
                    <th style="text-align:right;">Leads</th>
                    <th style="text-align:right;">Leads 7d</th>
                    <th>Last Zoho sync</th>
                </tr>
                @foreach (var r in Model.Rows)
                {
                    <tr style="border-bottom:1px solid #eee; @(r.TasksOverdue > 0 ? "background:#fff5f5;" : "")">
                        <td>@r.CompanyName <span style="color:#9aa0aa;font-size:12px;">#@r.CompanyId</span></td>
                        <td style="text-align:right;">@r.Contacts</td>
                        <td style="text-align:right;">@r.TasksDone</td>
                        <td style="text-align:right;">@r.TasksTotal</td>
                        <td style="text-align:right;@(r.TasksOverdue > 0 ? "color:#c0392b;font-weight:700;" : "")">@r.TasksOverdue</td>
                        <td style="text-align:right;">@r.LeadsTotal</td>
                        <td style="text-align:right;">@r.LeadsLast7d</td>
                        <td>@(r.LastZohoSync?.ToString("u") ?? "-")</td>
                    </tr>
                }
            </table>
            </div>
        }
    </div>
}
