@page
@model CommunityHub.Pages.Organizer.SponsorAdmin.IndexModel
@{
    ViewData["Title"] = "Sponsor Admin";
}

<div class="card">
    <h2>Sponsor Admin</h2>
    @if (Model.AccessDenied)
    {
        <p class="error">This area is for organizers only.</p>
        <p><a asp-page="/Index">Back to hub</a></p>
    }
    else
    {
        <p>One stop for sponsor-facing operations: manage the task catalog,
           review and export leads that came in via Zoho, and watch the
           per-sponsor status dashboard.</p>
        <p><a asp-page="/Organizer/Index">&larr; Back to Organizer area</a></p>
    }
</div>

@if (!Model.AccessDenied)
{
    var tiles = new List<CommunityHub.Pages.Shared.HubTile>
    {
        new("/Organizer/SponsorAdmin/Tasks", "Sponsor tasks", "Catalog of tasks every sponsor company has to complete; create, delete, or shift deadlines.", "sponsor-tasks"),
        new("/Organizer/SponsorAdmin/Leads", "Sponsor leads", "Leads, inquiries, and booth-meeting requests pulled daily from Zoho CRM; view per sponsor and download as CSV.", "sponsor-leads"),
        new("/Organizer/SponsorAdmin/Dashboard", "Sponsor status dashboard", "Per-sponsor view of tasks done vs open, overdue items, lead volume, and last Zoho sync."),
        new("/Organizer/Sponsors", "Sponsor directory", "The full list of sponsor companies for this edition: contacts, tiers and onboarding status."),
        new("/Organizer/SponsorAdmin/Welcome", "Sponsor welcome", "Resend the sponsor welcome / intro email per company or to all sponsors, and reset the welcome flag.", "sponsor-welcome"),
        new("/Organizer/AppGame", "App game", "Track which sponsors take part in the attendee app game, the gift they committed, and send reminders.", "sponsor-reminders"),
        new("/Organizer/EconomicContacts", "e-conomic contacts", "Manage the contacts on any e-conomic customer (add / edit / delete) straight from the hub."),
    };
    <partial name="_HubGrid" model="@tiles" />
}
