@page
@using CommunityHub.Core.Domain
@model CommunityHub.Pages.Organizer.BucketAllocationModel
@{
    ViewData["Title"] = "Buckets & allocation";
}

<style>
    /* Mobile-first (~360px): cards stack, forms go full-width and wrap. */
    .ba-bucket { border:1px solid #d7dbe4; border-radius:10px; margin:0 0 16px 0; overflow:hidden; }
    .ba-head { background:var(--el-darkblue,#1D3380); color:#fff; padding:12px 14px; }
    .ba-head h3 { margin:0; font-size:17px; }
    .ba-head .lead { font-size:12.5px; opacity:.92; margin-top:4px; }
    .ba-body { padding:10px 12px; }
    .ba-task { background:#f6f8fb; border-radius:8px; padding:10px 12px; margin:8px 0; font-size:13.5px; }
    .ba-task .title { font-weight:600; }
    .ba-task .meta { color:#6e7681; font-size:12px; margin-top:2px; }
    .gap { display:inline-block; border-radius:10px; padding:2px 9px; font-size:12px; font-weight:700; }
    .gap.green { background:#dcfce7; color:#166534; }
    .gap.red { background:#fee2e2; color:#991b1b; }
    .gap.sim { background:#fef9c3; color:#854d0e; }
    .ba-form { display:flex; flex-wrap:wrap; gap:6px; align-items:center; margin-top:8px; }
    .ba-form select, .ba-form input[type=file] {
        flex:1 1 160px; min-width:0; box-sizing:border-box; padding:7px 9px;
        font-size:13.5px; border:1px solid #c4c8d4; border-radius:6px; }
    .ba-form button { background:#008BD2; color:#fff; border:0; border-radius:6px;
        padding:8px 14px; font-size:13px; font-weight:600; cursor:pointer; white-space:nowrap; }
    .ba-form button.green { background:#16a34a; }
    .ba-form button.danger { background:#c0392b; }
    .ba-form button.ghost { background:#fff; color:#1D3380; border:1px solid #c4c8d4; }
    .ba-form button:hover { filter:brightness(.95); }
    .ba-note { background:#f0fdf4; border-left:4px solid #16a34a; padding:10px 12px;
        border-radius:6px; margin-bottom:14px; font-size:13.5px; color:#166534; }
    .ba-tray { position:sticky; top:8px; z-index:5; background:#fffbe6; border:1px solid #fde68a;
        border-radius:10px; padding:12px 14px; margin-bottom:16px; }
    .ba-tray h3 { margin:0 0 6px 0; font-size:15px; }
    .ba-chip { display:inline-block; background:#fff; border:1px solid #e5d28a; border-radius:10px;
        padding:3px 8px; font-size:12px; margin:3px 4px 3px 0; }
    @@media (max-width: 600px) {
        .ba-form select, .ba-form input[type=file], .ba-form button { flex:1 1 100%; }
    }
</style>

<div class="card">
    <h2>Buckets &amp; allocation</h2>
    <p>Group volunteer tasks into <strong>buckets</strong>, see each task&rsquo;s resource
       gap (green = enough people, red = short), and map people&rarr;tasks. Mapping queues a
       <strong>draft</strong> you can simulate and tweak &mdash; nothing is assigned until you
       <strong>commit</strong>.</p>

    @if (Model.AccessDenied)
    {
        <p class="error">This area is for organizers only.</p>
        return;
    }

    @if (!string.IsNullOrEmpty(Model.Notice))
    {
        <div class="ba-note">@Model.Notice</div>
    }

    @* ---- Import plan ---- *@
    <form method="post" asp-page-handler="Import" enctype="multipart/form-data" class="ba-form" aria-label="Import plan">
        <label for="planFile" style="flex:1 1 100%;font-weight:600;">Import plan (CSV)</label>
        <input type="file" id="planFile" name="planFile" accept=".csv,text/csv" aria-label="Plan CSV file" />
        <button type="submit">Import plan</button>
    </form>
    <p class="meta" style="color:#6e7681;font-size:12px;margin-top:4px;">
        Buckets are derived from the plan&rsquo;s Responsible Team column. AI guidance:
        <strong>@(Model.AiEnabled ? "enabled (LLM)" : "heuristic fallback")</strong>.
    </p>
</div>

@* ---- Draft tray (sticky): the pending allocation queue ---- *@
<div class="ba-tray" aria-live="polite">
    <h3>Draft allocations (@Model.DraftCount pending)</h3>
    @if (Model.DraftCount == 0)
    {
        <p style="margin:0;font-size:13px;color:#6e7681;">No pending allocations. Add people to tasks below to build a draft, then commit.</p>
    }
    else
    {
        <div>
            @foreach (var d in Model.Draft)
            {
                <span class="ba-chip">
                    @(string.IsNullOrWhiteSpace(d.Participant.FullName) ? d.Participant.Email : d.Participant.FullName)
                    &rarr; @d.Task.Title
                    <form method="post" asp-page-handler="RemoveDraft" style="display:inline">
                        <input type="hidden" name="taskId" value="@d.TaskId" />
                        <input type="hidden" name="volunteerId" value="@d.ParticipantId" />
                        <button type="submit" title="Remove from draft"
                                style="background:none;border:0;color:#c0392b;cursor:pointer;font-weight:700;">&times;</button>
                    </form>
                </span>
            }
        </div>
        <div class="ba-form" style="margin-top:10px;">
            <form method="post" asp-page-handler="Commit" style="display:inline">
                <button type="submit" class="green">Commit draft</button>
            </form>
            <form method="post" asp-page-handler="Discard" style="display:inline">
                <button type="submit" class="danger">Discard draft</button>
            </form>
        </div>
    }
</div>

@* ---- Buckets with gap indicators + the task-mapper ---- *@
@foreach (var bucket in Model.Buckets)
{
    <div class="ba-bucket">
        <div class="ba-head">
            <h3>@bucket.Name</h3>
            @if (!string.IsNullOrWhiteSpace(bucket.EldkLeadName))
            {
                <div class="lead">ELDK lead: @bucket.EldkLeadName</div>
            }
        </div>
        <div class="ba-body">
            @foreach (var t in bucket.Tasks)
            {
                var cov = t.Coverage;
                var simClass = cov.IsCovered ? "green" : "red";
                <div class="ba-task">
                    <div class="title">@t.Title</div>
                    <div class="meta">
                        @if (!string.IsNullOrWhiteSpace(t.ResponsibleTeam)) { <text>@t.ResponsibleTeam &middot; </text> }
                        Status: @t.Status
                        @if (!string.IsNullOrWhiteSpace(t.EldkLeadName)) { <text> &middot; Lead: @t.EldkLeadName</text> }
                    </div>
                    <div style="margin-top:6px;">
                        <span class="gap @simClass" title="Needed vs committed+queued">
                            @cov.AssignedCount + @cov.DraftCount / @cov.ResourcesNeeded
                            @(cov.IsCovered ? "✓ covered" : $"short {cov.SimulatedShortfall}")
                        </span>
                        @if (cov.DraftCount > 0)
                        {
                            <span class="gap sim" title="Includes draft (simulation)">simulated</span>
                        }
                    </div>

                    @* Map a person into the DRAFT for this task. *@
                    <form method="post" asp-page-handler="AddDraft" class="ba-form" aria-label="Add to draft">
                        <input type="hidden" name="taskId" value="@t.Id" />
                        <select name="volunteerId" aria-label="Volunteer" asp-items="Model.VolunteerOptions">
                            <option value="">Add person to draft&hellip;</option>
                        </select>
                        <button type="submit" class="ghost">Queue</button>
                    </form>

                    <div class="ba-form">
                        @if (t.Status != VolunteerTaskStatus.Done)
                        {
                            <form method="post" asp-page-handler="Complete" style="display:inline">
                                <input type="hidden" name="taskId" value="@t.Id" />
                                <button type="submit" class="green">Mark completed (lead)</button>
                            </form>
                        }
                        <form method="post" asp-page-handler="RegenerateGuidance" style="display:inline">
                            <input type="hidden" name="taskId" value="@t.Id" />
                            <button type="submit" class="ghost">@(Model.AiEnabled ? "Regenerate guidance (AI)" : "Suggest guidance")</button>
                        </form>
                    </div>
                </div>
            }
            @if (bucket.Tasks.Count == 0)
            {
                <p style="font-size:13px;color:#6e7681;">No tasks in this bucket yet.</p>
            }
        </div>
    </div>
}

@if (Model.Buckets.Count == 0)
{
    <div class="card"><p>No buckets yet. Import the plan CSV above, or create buckets on the
        <a asp-page="/Organizer/VolunteerStructure">Volunteer structure</a> page.</p></div>
}
