@page
@model CommunityHub.Pages.Organizer.SpeakersModel
@{
    ViewData["Title"] = "Speakers admin";
}

<div class="card">
    <h2>Speakers</h2>
    @if (Model.AccessDenied)
    {
        <p class="error">This area is for organizers only.</p>
    }
    else
    {
        if (!string.IsNullOrEmpty(Model.Error))   { <p class="error">@Model.Error</p> }
        if (!string.IsNullOrEmpty(Model.Message)) { <p class="info">@Model.Message</p> }

        <p style="font-size:13px;color:#6b7280;margin:0 0 10px;" role="status">
            <strong>@Model.Rows.Count</strong> speaker(s) &middot;
            <strong>@Model.SessionCount</strong> session(s) imported from Sessionize.
        </p>

        <h3 style="color:var(--el-darkblue);margin-top:14px;">Bulk set: upload xlsx</h3>
        <p style="font-size:13px;color:#6b7280;">
            Columns: <strong>Email</strong> (required), <strong>SpeakingPreDay</strong>, <strong>SpeakingMainDay</strong>.
            Yes/Y/1/true/x = tick &middot; No/N/0/false = untick &middot; empty = leave unchanged.
        </p>
        <p>
            <a asp-page-handler="Template"
               style="display:inline-block;background:var(--el-grey);color:var(--el-darkblue);
                      padding:6px 12px;border-radius:6px;text-decoration:none;font-size:13px;">
                Download xlsx template
            </a>
        </p>
        <form method="post" asp-page-handler="ImportXlsx" enctype="multipart/form-data" style="margin-bottom:18px;">
            <label for="UploadFile">Pick xlsx file</label>
            <input type="file" name="UploadFile" id="UploadFile" accept=".xlsx,.xlsm" />
            <button type="submit">Upload and import</button>
        </form>

        <h3 style="color:var(--el-darkblue);margin-top:14px;">Bulk set: paste a list of emails</h3>
        <p style="font-size:13px;color:#6b7280;">
            One email per line (commas / spaces also OK). Only matching active speakers are updated.
        </p>
        <form method="post" asp-page-handler="BulkPaste">
            <label for="EmailList">Speaker emails</label>
            <textarea asp-for="EmailList" rows="5" placeholder="alice@example.com&#10;bob@example.com"></textarea>

            <label>Apply to which flag?</label>
            <div style="display:flex; flex-direction:column; gap:6px; margin:6px 0 14px;">
                <label style="font-weight:normal;">
                    <input type="radio" asp-for="FieldToSet" value="preday" /> SpeakingPreDay
                </label>
                <label style="font-weight:normal;">
                    <input type="radio" asp-for="FieldToSet" value="mainday" /> SpeakingMainDay
                </label>
            </div>

            <label>Target value</label>
            <div style="display:flex; gap:18px; margin:6px 0 14px;">
                <label style="font-weight:normal;">
                    <input type="radio" asp-for="TargetValue" value="true" /> Yes (tick)
                </label>
                <label style="font-weight:normal;">
                    <input type="radio" asp-for="TargetValue" value="false" /> No (untick)
                </label>
            </div>

            <button type="submit">Apply to pasted list</button>
        </form>

        <h3 style="color:var(--el-darkblue);margin-top:24px;">Multi-select grid</h3>
        <p style="font-size:13px;color:#6b7280;">
            Tick speakers below, set the field + target above, then click <em>Apply to selection</em>.
        </p>

        <!-- Server-side search over name + email. Submitting resets to page 1 and
             keeps the active sort (carried as hidden fields). -->
        <form method="get" style="margin-bottom:12px;display:flex;flex-wrap:wrap;gap:8px;align-items:end;">
            <span style="display:flex;flex-direction:column;gap:2px;">
                <label for="Search">@Localizer["OrgGrid.Search"]</label>
                <input type="search" id="Search" name="Search" value="@Model.Search"
                       placeholder="@Localizer["OrgGrid.Col.Name"] / @Localizer["OrgGrid.Col.Email"]" />
            </span>
            <input type="hidden" name="Sort" value="@Model.Sort" />
            <input type="hidden" name="Desc" value="@Model.Desc" />
            <button type="submit">@Localizer["OrgGrid.Apply"]</button>
        </form>

        <p role="status" style="font-size:13px;color:#6b7280;margin:0 0 8px;">
            @Localizer["OrgGrid.ShowingRange", Model.Paging.FirstRowNumber, Model.Paging.LastRowNumber, Model.Paging.TotalItems]
        </p>

        <form method="post" asp-page-handler="BulkSelected" id="bulkForm">
            <input type="hidden" asp-for="FieldToSet" />
            <input type="hidden" asp-for="TargetValue" />
            <input type="hidden" name="Search" value="@Model.Search" />
            <input type="hidden" name="Sort" value="@Model.Sort" />
            <input type="hidden" name="Desc" value="@Model.Desc" />
            <input type="hidden" name="PageNo" value="@Model.Paging.Page" />

            <div style="overflow-x:auto;">
            <table style="border-collapse:collapse;width:100%;font-size:13px;min-width:880px;">
                <thead>
                    <tr style="border-bottom:2px solid #ddd;text-align:left;">
                        <th style="padding:6px;text-align:center;">
                            <input type="checkbox" id="ToggleAll" aria-label="@Localizer["OrgGrid.SelectAll"]" style="width:auto;margin:0;" />
                        </th>
                        <th scope="col" style="padding:6px;" aria-sort="@Model.AriaSort("name")">
                            <a asp-page="/Organizer/Speakers" asp-route-Search="@Model.Search"
                               asp-route-Sort="name" asp-route-Desc="@Model.NextDescFor("name")" asp-route-PageNo="1">@Localizer["OrgGrid.Col.Name"]@Model.SortIndicator("name")</a>
                        </th>
                        <th scope="col" style="padding:6px;" aria-sort="@Model.AriaSort("email")">
                            <a asp-page="/Organizer/Speakers" asp-route-Search="@Model.Search"
                               asp-route-Sort="email" asp-route-Desc="@Model.NextDescFor("email")" asp-route-PageNo="1">@Localizer["OrgGrid.Col.Email"]@Model.SortIndicator("email")</a>
                        </th>
                        <th scope="col" style="padding:6px;">Sessions</th>
                        <th scope="col" style="padding:6px;text-align:center;" aria-sort="@Model.AriaSort("preday")">
                            <a asp-page="/Organizer/Speakers" asp-route-Search="@Model.Search"
                               asp-route-Sort="preday" asp-route-Desc="@Model.NextDescFor("preday")" asp-route-PageNo="1">@Localizer["OrgSpeakers.Col.PreDay"]@Model.SortIndicator("preday")</a>
                        </th>
                        <th scope="col" style="padding:6px;text-align:center;" aria-sort="@Model.AriaSort("mainday")">
                            <a asp-page="/Organizer/Speakers" asp-route-Search="@Model.Search"
                               asp-route-Sort="mainday" asp-route-Desc="@Model.NextDescFor("mainday")" asp-route-PageNo="1">@Localizer["OrgSpeakers.Col.MainDay"]@Model.SortIndicator("mainday")</a>
                        </th>
                        <th style="padding:6px;">Accreditation</th>
                        <th style="padding:6px;">Country</th>
                        <th style="padding:6px;text-align:center;">1st-time</th>
                        <th style="padding:6px;text-align:center;">Active</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Rows.Count == 0)
                    {
                        <tr><td colspan="10" style="padding:10px;color:#6b7280;">@Localizer["OrgGrid.NoMatch"]</td></tr>
                    }
                    @foreach (var r in Model.Rows)
                    {
                        <tr style="border-bottom:1px solid #eee;@(r.IsActive ? "" : "opacity:.5;")">
                            <td style="padding:6px;text-align:center;">
                                <input type="checkbox" name="SelectedIds" value="@r.Id" class="rowsel" style="width:auto;margin:0;" />
                            </td>
                            <td style="padding:6px;">@r.Name</td>
                            <td style="padding:6px;color:#8a8f9c;">@r.Email</td>
                            <td style="padding:6px;">
                                @if (r.Sessions.Count == 0)
                                {
                                    <span style="color:#9ca3af;">&mdash;</span>
                                }
                                else
                                {
                                    <ul style="margin:0;padding-left:16px;list-style:disc;">
                                        @foreach (var title in r.Sessions)
                                        {
                                            <li>@title</li>
                                        }
                                    </ul>
                                }
                            </td>
                            <td style="padding:6px;text-align:center;">@(r.SpeakingPreDay ? "✓" : "")</td>
                            <td style="padding:6px;text-align:center;">@(r.SpeakingMainDay ? "✓" : "")</td>
                            <td style="padding:6px;">@r.Accreditation</td>
                            <td style="padding:6px;">@r.Country</td>
                            <td style="padding:6px;text-align:center;">
                                @(r.IsFirstTime is true ? "✓" : r.IsFirstTime is false ? "" : "-")
                            </td>
                            <td style="padding:6px;text-align:center;">@(r.IsActive ? "✓" : "")</td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>

            <!-- type=button: opens the shared confirm modal showing the selected
                 COUNT, then submits this form. No bulk write on a single click. -->
            <button type="button" id="bulkApply" class="js-bulk" style="margin-top:12px;">Apply to selection</button>
        </form>

        @if (Model.Paging.TotalPages > 1)
        {
            <nav aria-label="Pagination" style="display:flex;flex-wrap:wrap;gap:8px;align-items:center;margin-top:14px;">
                @if (Model.Paging.HasPrevious)
                {
                    <a asp-page="/Organizer/Speakers" asp-route-Search="@Model.Search"
                       asp-route-Sort="@Model.Sort" asp-route-Desc="@Model.Desc" asp-route-PageNo="@(Model.Paging.Page - 1)" rel="prev"
                       style="padding:6px 12px;border:1px solid #c4c8d4;border-radius:6px;text-decoration:none;">@Localizer["OrgGrid.Prev"]</a>
                }
                <span>@Localizer["OrgGrid.PageOf", Model.Paging.Page, Model.Paging.TotalPages]</span>
                @if (Model.Paging.HasNext)
                {
                    <a asp-page="/Organizer/Speakers" asp-route-Search="@Model.Search"
                       asp-route-Sort="@Model.Sort" asp-route-Desc="@Model.Desc" asp-route-PageNo="@(Model.Paging.Page + 1)" rel="next"
                       style="padding:6px 12px;border:1px solid #c4c8d4;border-radius:6px;text-decoration:none;">@Localizer["OrgGrid.Next"]</a>
                }
            </nav>
        }

        <!-- Bulk confirmation modal: shows the selected-row COUNT before applying. -->
        <div id="bulkModal" class="modal-backdrop" role="dialog" aria-modal="true"
             aria-labelledby="bulkModalTitle" aria-describedby="bulkModalBody" hidden
             style="position:fixed;inset:0;background:rgba(0,0,0,.45);display:flex;
                    align-items:center;justify-content:center;padding:16px;z-index:1000;">
            <div class="modal-card"
                 style="background:#fff;border-radius:10px;max-width:440px;width:100%;
                        padding:20px;box-shadow:0 10px 30px rgba(0,0,0,.25);">
                <h3 id="bulkModalTitle" style="margin-top:0;">@Localizer["OrgGrid.BulkConfirmTitle"]</h3>
                <p id="bulkModalBody"></p>
                <div style="display:flex;flex-wrap:wrap;gap:10px;justify-content:flex-end;margin-top:16px;">
                    <button type="button" id="bulkModalCancel" class="secondary"
                            style="padding:8px 14px;border:1px solid #c4c8d4;border-radius:6px;background:#fff;cursor:pointer;">
                        @Localizer["OrgGrid.Cancel"]
                    </button>
                    <button type="button" id="bulkModalConfirm"
                            style="padding:8px 14px;border:none;border-radius:6px;background:#1f6feb;color:#fff;cursor:pointer;">
                        @Localizer["OrgGrid.Continue"]
                    </button>
                </div>
            </div>
        </div>

        <script>
            document.getElementById('ToggleAll').addEventListener('change', function () {
                document.querySelectorAll('.rowsel').forEach(c => c.checked = this.checked);
            });
            (function () {
                var modal = document.getElementById('bulkModal');
                var form = document.getElementById('bulkForm');
                var trigger = document.getElementById('bulkApply');
                if (!modal || !form || !trigger) return;
                var bodyEl = document.getElementById('bulkModalBody');
                var cancelBtn = document.getElementById('bulkModalCancel');
                var confirmBtn = document.getElementById('bulkModalConfirm');
                var bodyTemplate = @Html.Raw(Json.Serialize(Localizer["OrgGrid.BulkConfirmBody", "{0}"].Value));
                var pickFirst = @Html.Raw(Json.Serialize(Localizer["OrgGrid.BulkPickFirst"].Value));
                var lastFocused = null;

                function selectedCount() { return document.querySelectorAll('.rowsel:checked').length; }
                function openModal(count) {
                    bodyEl.textContent = bodyTemplate.replace('{0}', count);
                    modal.hidden = false;
                    lastFocused = document.activeElement;
                    confirmBtn.focus();
                }
                function closeModal() {
                    modal.hidden = true;
                    if (lastFocused && lastFocused.focus) lastFocused.focus();
                }
                trigger.addEventListener('click', function () {
                    var count = selectedCount();
                    if (count === 0) { alert(pickFirst); return; }
                    openModal(count);
                });
                confirmBtn.addEventListener('click', function () { form.submit(); });
                cancelBtn.addEventListener('click', closeModal);
                modal.addEventListener('click', function (e) { if (e.target === modal) closeModal(); });
                document.addEventListener('keydown', function (e) {
                    if (e.key === 'Escape' && !modal.hidden) closeModal();
                });
            })();
        </script>
    }
    <p><a asp-page="/Organizer/Index">Back to organizer area</a></p>
</div>
