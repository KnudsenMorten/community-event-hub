@page
@model CommunityHub.Pages.Organizer.SoMeModel
@{
    ViewData["Title"] = Localizer["OrgSoMe.Title"].Value;
}

<div class="card">
    <h2>@Localizer["OrgSoMe.Title"]</h2>
    @if (Model.AccessDenied)
    {
        <p class="error">@Localizer["Common.OrganizersOnly"]</p>
        <p><a asp-page="/Index">@Localizer["Common.BackToHub"]</a></p>
    }
    else
    {
        <p>@Localizer["OrgSoMe.Intro"]</p>
        <p><a asp-page="/Organizer/Index">&larr; @Localizer["Common.BackToOrganizerArea"]</a></p>
    }
</div>

@if (!Model.AccessDenied)
{
    var tiles = new List<CommunityHub.Pages.Shared.HubTile>
    {
        new("/Organizer/Graphics", Localizer["Nav.OrgGraphics"].Value, Localizer["OrgSoMe.Graphics"].Value),
        new("/Organizer/SoMeQueue", Localizer["Nav.OrgSoMeQueue"].Value, Localizer["OrgSoMe.Queue"].Value),
        new("/Organizer/SoMeSettings", Localizer["Nav.OrgSoMeSettings"].Value, Localizer["OrgSoMe.Settings"].Value),
        new("/Organizer/AssetLocations", Localizer["Nav.OrgAssetLocations"].Value, Localizer["OrgSoMe.AssetLocations"].Value),
    };
    <partial name="_HubGrid" model="@tiles" />
}
