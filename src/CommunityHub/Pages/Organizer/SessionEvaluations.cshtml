@page
@model CommunityHub.Pages.Organizer.SessionEvaluationsModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Session evaluations";
}

@if (Model.AccessDenied)
{
    <div class="card"><h1>Organizers only</h1><p>You need an organizer account to view evaluation results.</p></div>
    return;
}

<style>
    .se-summary { display: flex; flex-wrap: wrap; gap: 12px; margin: 0 0 18px 0; }
    .se-tile {
        flex: 1 1 140px; background: #fff; border: 1px solid #e4e7ee; border-radius: 10px;
        padding: 14px 16px;
    }
    .se-tile .lbl { font-size: 12px; color: #6a7280; text-transform: uppercase; letter-spacing: .05em; }
    .se-tile .val { font-size: 26px; font-weight: 700; color: #1D3380; margin-top: 4px; line-height: 1.1; }
    .se-tile .val .face { font-size: 24px; }

    .se-filters { display: flex; flex-wrap: wrap; gap: 10px; align-items: end; margin: 0 0 18px 0; }
    .se-filters .f { display: flex; flex-direction: column; gap: 4px; }
    .se-filters label { font-size: 12px; font-weight: 600; color: #24292f; }
    .se-filters select { padding: 8px 10px; border: 1px solid #c4c8d4; border-radius: 7px; font-size: 14px; }
    .se-filters button, .se-filters a.clear {
        padding: 9px 16px; border-radius: 7px; font-size: 14px; font-weight: 600; cursor: pointer;
        border: 1px solid #c4c8d4; background: #fff; color: #24292f; text-decoration: none;
    }
    .se-filters button { background: var(--el-blue, #008BD2); color: #fff; border-color: var(--el-blue, #008BD2); }

    .se-section-title { font-size: 16px; font-weight: 700; color: #24292f; margin: 22px 0 10px 0; }

    table.se-table { width: 100%; border-collapse: collapse; font-size: 14px; }
    table.se-table caption { text-align: left; font-weight: 600; padding: 6px 0; color: #4a5160; }
    table.se-table th, table.se-table td { text-align: left; padding: 9px 10px; border-bottom: 1px solid #eef0f5; vertical-align: top; }
    table.se-table th { font-size: 12px; text-transform: uppercase; letter-spacing: .04em; color: #6a7280; }
    table.se-table td.num, table.se-table th.num { text-align: right; white-space: nowrap; }
    .se-face { font-size: 18px; }
    .se-empty { padding: 16px; color: #6a7280; font-size: 14px; }

    .se-comments { margin: 6px 0 0 0; padding: 0; list-style: none; }
    .se-comments li { display: flex; gap: 8px; padding: 6px 0; border-top: 1px dashed #eef0f5; font-size: 13.5px; }
    .se-comments li:first-child { border-top: 0; }
    .se-comments .c-face { font-size: 16px; flex: 0 0 auto; }
    .se-comments .c-text { color: #24292f; line-height: 1.45; }

    details.se-det summary { cursor: pointer; font-size: 13px; color: var(--el-blue, #008BD2); font-weight: 600; }

    /* Mobile: let the tables scroll rather than overflow at ~360px. */
    .se-scroll { overflow-x: auto; -webkit-overflow-scrolling: touch; }
</style>

<div class="card">
    <h1 style="margin-top:0;">Session evaluations</h1>
    <p style="color:#4a5160; font-size:14px; margin-top:4px;">
        Attendee ratings collected from the public evaluate page (the room QR). Results are
        aggregated per session and per room; comments are anonymous.
    </p>

    @if (Model.Dashboard is null)
    {
        <div class="se-empty">No data.</div>
    }
    else
    {
    <div class="se-summary" role="status">
        <div class="se-tile">
            <div class="lbl">Total ratings</div>
            <div class="val">@Model.Dashboard.TotalCount</div>
        </div>
        <div class="se-tile">
            <div class="lbl">Overall average</div>
            <div class="val">
                @(Model.Dashboard.OverallAverage?.ToString("0.0") ?? "—")
                <span class="face" aria-hidden="true">@CommunityHub.Pages.Organizer.SessionEvaluationsModel.Face(Model.Dashboard.OverallAverage)</span>
            </div>
        </div>
    </div>

    <form method="get" class="se-filters">
        <div class="f">
            <label for="FilterType">Session type</label>
            <select asp-for="FilterType" id="FilterType" asp-items="Model.TypeOptions">
                <option value="">All types</option>
            </select>
        </div>
        <div class="f">
            <label for="FilterRoom">Room</label>
            <select asp-for="FilterRoom" id="FilterRoom">
                <option value="">All rooms</option>
                @foreach (var room in Model.Rooms)
                {
                    <option value="@room" selected="@(room == Model.FilterRoom)">@room</option>
                }
            </select>
        </div>
        <div class="f">
            <button type="submit">Apply filters</button>
        </div>
        @if (Model.FilterType is not null || !string.IsNullOrWhiteSpace(Model.FilterRoom))
        {
            <div class="f"><a class="clear" asp-page="/Organizer/SessionEvaluations">Clear</a></div>
        }
    </form>

    <h3 class="se-section-title">Per room</h3>
    <div class="se-scroll">
        <table class="se-table">
            <caption class="sr-only">Average rating and count per room</caption>
            <thead>
                <tr>
                    <th scope="col">Room</th>
                    <th scope="col" class="num">Sessions</th>
                    <th scope="col" class="num">Ratings</th>
                    <th scope="col" class="num">Average</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Dashboard.Rooms.Count == 0)
                {
                    <tr><td colspan="4" class="se-empty">No rooms with sessions match the filters.</td></tr>
                }
                else
                {
                    foreach (var r in Model.Dashboard.Rooms)
                    {
                        <tr>
                            <th scope="row">@r.Room</th>
                            <td class="num">@r.SessionCount</td>
                            <td class="num">@r.Count</td>
                            <td class="num">
                                @(r.AverageRating?.ToString("0.0") ?? "—")
                                <span class="se-face" aria-hidden="true">@CommunityHub.Pages.Organizer.SessionEvaluationsModel.Face(r.AverageRating)</span>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <h3 class="se-section-title">Per session</h3>
    <div class="se-scroll">
        <table class="se-table">
            <caption class="sr-only">Average rating, count and comments per session</caption>
            <thead>
                <tr>
                    <th scope="col">Session</th>
                    <th scope="col">Room</th>
                    <th scope="col" class="num">Ratings</th>
                    <th scope="col" class="num">Average</th>
                    <th scope="col">Comments</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Dashboard.Sessions.Count == 0)
                {
                    <tr><td colspan="5" class="se-empty">No sessions match the filters.</td></tr>
                }
                else
                {
                    foreach (var s in Model.Dashboard.Sessions)
                    {
                        <tr>
                            <th scope="row">@s.Title</th>
                            <td>@(string.IsNullOrWhiteSpace(s.Room) ? "—" : s.Room)</td>
                            <td class="num">@s.Count</td>
                            <td class="num">
                                @(s.AverageRating?.ToString("0.0") ?? "—")
                                <span class="se-face" aria-hidden="true">@CommunityHub.Pages.Organizer.SessionEvaluationsModel.Face(s.AverageRating)</span>
                            </td>
                            <td>
                                @if (s.Comments.Count == 0)
                                {
                                    <span class="se-empty" style="padding:0;">—</span>
                                }
                                else
                                {
                                    <details class="se-det">
                                        <summary>@s.Comments.Count comment@(s.Comments.Count == 1 ? "" : "s")</summary>
                                        <ul class="se-comments">
                                            @foreach (var c in s.Comments)
                                            {
                                                <li>
                                                    <span class="c-face" aria-label="@c.Rating out of 5">@CommunityHub.Pages.Organizer.SessionEvaluationsModel.Face(c.Rating)</span>
                                                    <span class="c-text">@c.Comment</span>
                                                </li>
                                            }
                                        </ul>
                                    </details>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
    }
</div>

<div class="card" style="margin-top:18px;">
    <h2 style="margin-top:0;">Final evaluation PDFs</h2>
    <p style="color:#4a5160; font-size:14px; margin-top:4px;">
        Upload the final evaluation PDF for each session (e.g. the HappyOrNot summary). Once
        uploaded, the session's speaker(s) can download it from their My Sessions page and are
        emailed that it is ready. Speakers never see the SharePoint location — the file is served
        through the hub.
    </p>

    @if (!string.IsNullOrEmpty(Model.PdfMessage))
    {
        <div class="se-note ok" role="status">@Model.PdfMessage</div>
    }
    @if (!string.IsNullOrEmpty(Model.PdfError))
    {
        <div class="se-note err" role="alert">@Model.PdfError</div>
    }

    @if (!Model.PdfConfigured)
    {
        <div class="se-note warn">
            The SharePoint folder for final evaluation PDFs is not configured yet
            (<code>Graphics:SharePoint:SessionEvalPdfFolderPath</code>). Uploads are disabled until
            an operator sets it; the session list below still shows which sessions already have a PDF.
        </div>
    }

    <div class="se-scroll">
        <table class="se-table">
            <caption class="sr-only">Final evaluation PDF status + upload per session</caption>
            <thead>
                <tr>
                    <th scope="col">Session</th>
                    <th scope="col">Speakers</th>
                    <th scope="col">PDF</th>
                    <th scope="col">Upload</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.PdfSessions.Count == 0)
                {
                    <tr><td colspan="4" class="se-empty">No sessions yet.</td></tr>
                }
                else
                {
                    foreach (var s in Model.PdfSessions)
                    {
                        <tr>
                            <th scope="row">@s.Title</th>
                            <td>@(s.SpeakerNames.Count == 0 ? "—" : string.Join(", ", s.SpeakerNames))</td>
                            <td>
                                @if (s.HasPdf)
                                {
                                    <span class="se-badge ok">Uploaded</span>
                                }
                                else
                                {
                                    <span class="se-badge no">Not uploaded</span>
                                }
                            </td>
                            <td>
                                @if (Model.PdfConfigured)
                                {
                                    <form method="post" asp-page-handler="UploadPdf" enctype="multipart/form-data"
                                          class="se-upload">
                                        <input type="hidden" name="UploadSessionId" value="@s.SessionId" />
                                        <input type="file" name="Pdf" accept="application/pdf,.pdf" required
                                               aria-label="Final evaluation PDF for @s.Title" />
                                        <button type="submit">@(s.HasPdf ? "Replace" : "Upload")</button>
                                    </form>
                                }
                                else
                                {
                                    <span class="se-empty" style="padding:0;">—</span>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    .se-note { padding: 10px 14px; border-radius: 8px; font-size: 14px; margin: 0 0 14px 0; }
    .se-note.ok { background: #e8f7ee; border: 1px solid #b7e3c6; color: #1c6b3a; }
    .se-note.err { background: #fdecea; border: 1px solid #f5b9b3; color: #97231b; }
    .se-note.warn { background: #fff7e6; border: 1px solid #f3dea6; color: #7a5a00; }
    .se-badge { display: inline-block; padding: 2px 9px; border-radius: 999px; font-size: 12px; font-weight: 700; }
    .se-badge.ok { background: #e8f7ee; color: #1c6b3a; }
    .se-badge.no { background: #f1f2f5; color: #6a7280; }
    .se-upload { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; }
    .se-upload input[type=file] { font-size: 13px; max-width: 220px; }
    .se-upload button {
        padding: 8px 16px; border-radius: 7px; font-size: 14px; font-weight: 600; cursor: pointer;
        border: 1px solid var(--el-blue, #008BD2); background: var(--el-blue, #008BD2); color: #fff;
    }
</style>
