@page
@using CommunityHub.Core.Domain
@model CommunityHub.Pages.Organizer.IndexModel
@{
    ViewData["Title"] = Localizer["OrgArea.Title"].Value;
}

<div class="card">
    <h1>@Localizer["OrgArea.Title"]</h1>
    @if (Model.AccessDenied)
    {
        <p class="error">@Localizer["Common.OrganizersOnly"]</p>
        <p><a asp-page="/Index">@Localizer["Common.BackToHub"]</a></p>
    }
    else
    {
        <p>@Localizer["OrgArea.Intro"]</p>
    }
</div>

@if (!Model.AccessDenied)
{
    var tiles = new List<CommunityHub.Pages.Shared.HubTile>
    {
        new("/Organizer/CommandCenter", Localizer["Nav.OrgCommandCenter"].Value, Localizer["OrgArea.CommandCenter"].Value),
        new("/Organizer/Dashboard", Localizer["Nav.OrgDashboard"].Value, Localizer["OrgArea.Dashboard"].Value),
        new("/Organizer/Overview", "Event overview", "A single at-a-glance read on the event — key counts and progress bars across people, sessions, sponsors and logistics."),
        new("/Organizer/FindPerson", Localizer["Nav.OrgFindPerson"].Value, Localizer["OrgPeople.FindPerson"].Value),
        new("/Organizer/People", Localizer["Nav.OrgPeople"].Value, Localizer["OrgPeople.Intro"].Value),
        new("/Organizer/Content", Localizer["Nav.OrgSessionsHub"].Value, Localizer["OrgContent.Intro"].Value),
        new("/Organizer/Comms", Localizer["Nav.OrgComms"].Value, Localizer["OrgComms.Intro"].Value),
        new("/Organizer/SoMe", Localizer["Nav.OrgSoMe"].Value, Localizer["OrgSoMe.Intro"].Value),
        new("/Organizer/SponsorAdmin/Index", Localizer["Nav.OrgSponsorsHub"].Value, Localizer["OrgArea.Sponsors"].Value),
        new("/Organizer/Volunteers", Localizer["Nav.OrgVolunteers"].Value, Localizer["OrgVolunteers.Intro"].Value),
        new("/Organizer/Logistics", Localizer["Nav.OrgLogistics"].Value, Localizer["OrgLogistics.Intro"].Value),
        new("/Organizer/Setup", Localizer["Nav.OrgSetup"].Value, Localizer["OrgSetup.Intro"].Value),
        new("/Organizer/ImpersonationLog", Localizer["Nav.OrgImpersonationLog"].Value, Localizer["OrgArea.Audit"].Value),
    };
    <partial name="_HubGrid" model="@tiles" />

    @if (Model.Mismatches.Count > 0)
    {
        <div class="card">
            <h2>@Localizer["OrgArea.MismatchesTitle"]</h2>
            <p>@Model.Mismatches.Count @Localizer["OrgArea.MismatchesNeedReview"]</p>
            <table style="width:100%;border-collapse:collapse;">
                <tr style="text-align:left;border-bottom:2px solid #ddd;">
                    <th>@Localizer["OrgArea.ColName"]</th><th>@Localizer["OrgArea.ColEmail"]</th><th>@Localizer["OrgArea.ColTicket"]</th><th>@Localizer["OrgArea.ColBooking"]</th>
                </tr>
                @foreach (var a in Model.Mismatches)
                {
                    <tr style="border-bottom:1px solid #eee;">
                        <td>@a.FirstName @a.LastName</td>
                        <td>@a.Email</td>
                        <td>@a.TicketStatus</td>
                        <td>@a.BookingStatus</td>
                    </tr>
                }
            </table>
        </div>
    }
}
