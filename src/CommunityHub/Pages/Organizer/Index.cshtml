@page
@using CommunityHub.Core.Domain
@model CommunityHub.Pages.Organizer.IndexModel
@{
    ViewData["Title"] = "Organizer area";
}

<div class="card">
    <h2>Dashboard</h2>
    <p>Live snapshot: form completion, task status, sponsor progress,
       attendee reconciliation, volunteer coverage.</p>
    <p><a asp-page="/Organizer/Dashboard">Open dashboard</a></p>
</div>

<div class="card">
    <h2>Attendee reconciliation mismatches</h2>

    @if (Model.AccessDenied)
    {
        <p class="error">This area is for organizers only.</p>
    }
    else if (Model.Mismatches.Count == 0)
    {
        <p class="info">No mismatches. Every attendee's ticket and Master
           Class booking line up.</p>
    }
    else
    {
        <p>@Model.Mismatches.Count attendee(s) need review. The hub flags
           these; resolve identity questions manually.</p>
        <table style="width:100%;border-collapse:collapse;">
            <tr style="text-align:left;border-bottom:2px solid #ddd;">
                <th>Name</th><th>Email</th><th>Ticket</th><th>Booking</th>
            </tr>
            @foreach (var a in Model.Mismatches)
            {
                <tr style="border-bottom:1px solid #eee;">
                    <td>@a.FirstName @a.LastName</td>
                    <td>@a.Email</td>
                    <td>@a.TicketStatus</td>
                    <td>@a.BookingStatus</td>
                </tr>
            }
        </table>
    }
    <p><a asp-page="/Index">Back to hub</a></p>
</div>

<div class="card">
    <h2>Attendees</h2>
    <p>Browse the full reconciled attendee list (Zoho tickets + Master Class
       bookings) with filters, search and CSV export.</p>
    <p><a asp-page="/Organizer/Attendees">Browse attendees</a></p>
</div>

<div class="card">
    <h2>Email center</h2>
    <p>Preview every branded email template, send yourself a test copy, and
       browse the delivery ledger (what the reminder engine actually sent).</p>
    <p><a asp-page="/Organizer/EmailCenter">Open email center</a></p>
</div>

<div class="card">
    <h2>Broadcast email</h2>
    <p>Send one branded message to whole role groups (speakers, volunteers,
       sponsors, attendees) with per-subject dedup so retries never
       double-mail.</p>
    <p><a asp-page="/Organizer/Broadcast">Compose broadcast</a></p>
</div>

<div class="card">
    <h2>Manage participants</h2>
    <p>View all participants, filter by role and active/inactive status, and
       deactivate anyone who has dropped out.</p>
    <p><a asp-page="/Organizer/Participants">Manage participants</a></p>
</div>

<div class="card">
    <h2>Import speakers</h2>
    <p>Pull accepted speakers from Sessionize and add them as participants.</p>
    <p><a asp-page="/Organizer/SessionizeImport">Import from Sessionize</a></p>
</div>

<div class="card">
    <h2>Data grids</h2>
    <p>Excel-like tables for managing data in place, with CSV export.</p>
    <p><a asp-page="/Organizer/DataGrid">Participant grid</a> &mdash;
       active status and hotel check-in / check-out per person.</p>
    <p><a asp-page="/Organizer/TasksTable">Tasks grid</a> &mdash;
       edit task title, due date, state and assignee.</p>
</div>

<div class="card">
    <h2>Sponsor Admin</h2>
    <p>Manage the sponsor task catalog (create / delete / shift deadline),
       review leads pulled from Zoho with per-sponsor CSV / JSON download
       endpoints, and watch the per-sponsor status dashboard.</p>
    <p><a asp-page="/Organizer/SponsorAdmin/Index">Open Sponsor Admin</a></p>
</div>
