@page
@using CommunityHub.Core.Domain
@model CommunityHub.Pages.Organizer.IndexModel
@{
    ViewData["Title"] = Localizer["OrgArea.Title"].Value;
}

<div class="card">
    <h2>@Localizer["OrgArea.Title"]</h2>
    @if (Model.AccessDenied)
    {
        <p class="error">@Localizer["Common.OrganizersOnly"]</p>
        <p><a asp-page="/Index">@Localizer["Common.BackToHub"]</a></p>
    }
    else
    {
        <p>@Localizer["OrgArea.Intro"]</p>
    }
</div>

@if (!Model.AccessDenied)
{
    <div class="card">
        <h2>@Localizer["Nav.OrgCommandCenter"]</h2>
        <p>@Localizer["OrgArea.CommandCenter"]</p>
        <p><a asp-page="/Organizer/CommandCenter">@Localizer["Nav.OrgCommandCenter"]</a></p>
    </div>

    <div class="card">
        <h2>@Localizer["Nav.OrgDashboard"]</h2>
        <p>@Localizer["OrgArea.Dashboard"]</p>
        <p><a asp-page="/Organizer/Dashboard">@Localizer["Nav.OrgDashboard"]</a></p>
        @if (Model.OpenActionItems > 0)
        {
            <p><a asp-page="/Organizer/ActionQueue">
                <span style="display:inline-block;font-size:13px;font-weight:700;background:#fee2e2;color:#991b1b;border-radius:999px;padding:2px 10px;">@Model.OpenActionItems</span>
                @Localizer["OrgArea.OpenActions"]</a></p>
        }
    </div>

    <div class="card">
        <h2>@Localizer["Nav.OrgPeople"]</h2>
        <p>@Localizer["OrgPeople.Intro"]</p>
        <p><a asp-page="/Organizer/People">@Localizer["Nav.OrgPeople"]</a></p>
    </div>

    <div class="card">
        <h2>@Localizer["Nav.OrgComms"]</h2>
        <p>@Localizer["OrgComms.Intro"]</p>
        <p><a asp-page="/Organizer/Comms">@Localizer["Nav.OrgComms"]</a></p>
    </div>

    <div class="card">
        <h2>@Localizer["Nav.OrgSessionsHub"]</h2>
        <p>@Localizer["OrgContent.Intro"]</p>
        <p><a asp-page="/Organizer/Content">@Localizer["Nav.OrgSessionsHub"]</a></p>
    </div>

    <div class="card">
        <h2>@Localizer["Nav.OrgSponsorsHub"]</h2>
        <p>@Localizer["OrgArea.Sponsors"]</p>
        <p><a asp-page="/Organizer/SponsorAdmin/Index">@Localizer["Nav.OrgSponsorsHub"]</a></p>
    </div>

    <div class="card">
        <h2>@Localizer["Nav.OrgVolunteers"]</h2>
        <p>@Localizer["OrgVolunteers.Intro"]</p>
        <p><a asp-page="/Organizer/Volunteers">@Localizer["Nav.OrgVolunteers"]</a></p>
    </div>

    <div class="card">
        <h2>@Localizer["Nav.OrgLogistics"]</h2>
        <p>@Localizer["OrgLogistics.Intro"]</p>
        <p><a asp-page="/Organizer/Logistics">@Localizer["Nav.OrgLogistics"]</a></p>
    </div>

    <div class="card">
        <h2>@Localizer["Nav.OrgExports"]</h2>
        <p>@Localizer["OrgArea.Exports"]</p>
        <p><a asp-page="/Organizer/Exports">@Localizer["Nav.OrgExports"]</a></p>
    </div>

    <div class="card">
        <h2>@Localizer["Nav.OrgSoMe"]</h2>
        <p>@Localizer["OrgSoMe.Intro"]</p>
        <p><a asp-page="/Organizer/SoMe">@Localizer["Nav.OrgSoMe"]</a></p>
    </div>

    <div class="card">
        <h2>@Localizer["Nav.OrgSetup"]</h2>
        <p>@Localizer["OrgSetup.Intro"]</p>
        <p><a asp-page="/Organizer/Setup">@Localizer["Nav.OrgSetup"]</a></p>
    </div>

    <div class="card">
        <h2>@Localizer["Nav.OrgImpersonationLog"]</h2>
        <p>@Localizer["OrgArea.Audit"]</p>
        <p><a asp-page="/Organizer/ImpersonationLog">@Localizer["Nav.OrgImpersonationLog"]</a></p>
    </div>

    @if (Model.Mismatches.Count > 0)
    {
        <div class="card">
            <h2>@Localizer["OrgArea.MismatchesTitle"]</h2>
            <p>@Model.Mismatches.Count @Localizer["OrgArea.MismatchesNeedReview"]</p>
            <table style="width:100%;border-collapse:collapse;">
                <tr style="text-align:left;border-bottom:2px solid #ddd;">
                    <th>@Localizer["OrgArea.ColName"]</th><th>@Localizer["OrgArea.ColEmail"]</th><th>@Localizer["OrgArea.ColTicket"]</th><th>@Localizer["OrgArea.ColBooking"]</th>
                </tr>
                @foreach (var a in Model.Mismatches)
                {
                    <tr style="border-bottom:1px solid #eee;">
                        <td>@a.FirstName @a.LastName</td>
                        <td>@a.Email</td>
                        <td>@a.TicketStatus</td>
                        <td>@a.BookingStatus</td>
                    </tr>
                }
            </table>
        </div>
    }
}
