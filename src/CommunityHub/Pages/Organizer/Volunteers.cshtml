@page
@model CommunityHub.Pages.Organizer.VolunteersModel
@{
    ViewData["Title"] = Localizer["OrgVolunteers.Title"].Value;
}

<div class="card">
    <h1>@Localizer["OrgVolunteers.Title"]</h1>
    @if (Model.AccessDenied)
    {
        <p class="error">@Localizer["Common.OrganizersOnly"]</p>
        <p><a asp-page="/Index">@Localizer["Common.BackToHub"]</a></p>
    }
    else
    {
        <p>@Localizer["OrgVolunteers.Intro"]</p>
        <p><a asp-page="/Organizer/Index">&larr; @Localizer["Common.BackToOrganizerArea"]</a></p>
    }
</div>

@if (!Model.AccessDenied)
{
    var tiles = new List<CommunityHub.Pages.Shared.HubTile>
    {
        new("/Organizer/VolunteerStructure", Localizer["Nav.OrgVolunteerStructure"].Value, Localizer["OrgVolunteers.Structure"].Value, "volunteer-tasks"),
        new("/Organizer/BucketAllocation", Localizer["Nav.OrgBucketAllocation"].Value, Localizer["OrgVolunteers.Buckets"].Value, "volunteer-allocation"),
        new("/Organizer/AllocationScenarios", "Allocation scenarios", "Stage a bulk reshuffle, simulate the coverage impact, then commit it — or auto-seed a drop-out backfill.", "volunteer-allocation"),
    };
    <partial name="_HubGrid" model="@tiles" />
}
