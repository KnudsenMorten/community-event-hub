@page
@model CommunityHub.Pages.Organizer.SetupModel
@{
    ViewData["Title"] = Localizer["OrgSetup.Title"].Value;
}

<div class="card">
    <h2>@Localizer["OrgSetup.Title"]</h2>
    @if (Model.AccessDenied)
    {
        <p class="error">@Localizer["Common.OrganizersOnly"]</p>
        <p><a asp-page="/Index">@Localizer["Common.BackToHub"]</a></p>
    }
    else
    {
        <p>@Localizer["OrgSetup.Intro"]</p>
        <p><a asp-page="/Organizer/Index">&larr; @Localizer["Common.BackToOrganizerArea"]</a></p>
    }
</div>

@if (!Model.AccessDenied)
{
    var tiles = new List<CommunityHub.Pages.Shared.HubTile>
    {
        new("/Organizer/CalendarSettings", Localizer["Nav.OrgCalendarSettings"].Value, Localizer["OrgSetup.Calendar"].Value),
        new("/Organizer/SessionizeEndpointSettings", Localizer["Nav.OrgSessionizeEndpoint"].Value, Localizer["OrgSetup.Sessionize"].Value),
        new("/Organizer/SoMeSettings", Localizer["Nav.OrgSoMeSettings"].Value, Localizer["OrgSetup.SoMe"].Value),
        new("/Organizer/Settings", Localizer["Nav.OrgSettings"].Value, Localizer["OrgSetup.Settings"].Value),
        new("/Organizer/TestDataCleanup", Localizer["Nav.OrgTestDataCleanup"].Value, Localizer["OrgSetup.TestData"].Value),
    };
    <partial name="_HubGrid" model="@tiles" />
}
