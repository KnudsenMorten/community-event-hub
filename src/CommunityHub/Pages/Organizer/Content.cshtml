@page
@model CommunityHub.Pages.Organizer.ContentModel
@using CommunityHub.Pages.Shared
@{
    ViewData["Title"] = Localizer["OrgContent.Title"].Value;

    var tiles = new List<HubTile>
    {
        new HubTile("/Organizer/Speakers", Localizer["Nav.OrgSpeakers"].Value, Localizer["OrgContent.Speakers"].Value),
        new HubTile("/Organizer/Sessions", Localizer["Nav.OrgSessions"].Value, Localizer["OrgContent.Sessions"].Value),
        new HubTile("/Organizer/SessionQuestions", Localizer["Nav.OrgSessionQuestions"].Value, Localizer["OrgContent.SessionQuestions"].Value),
        new HubTile("/Organizer/SessionEvaluations", Localizer["Nav.OrgSessionEvaluations"].Value, Localizer["OrgContent.SessionEvaluations"].Value),
        new HubTile("/Organizer/SessionizeImport", Localizer["Nav.OrgSessionizeImport"].Value, Localizer["OrgContent.SessionizeImport"].Value),
        new HubTile("/Organizer/SessionizeEndpointSettings", Localizer["Nav.OrgSessionizeEndpoint"].Value, "Configure the Sessionize API endpoint."),
        new HubTile("/Organizer/SessionSource", "Session source", "Choose the session source (Sessionize / Backstage)."),
        new HubTile("/Organizer/MasterClasses", "Master Classes", "Seat capacity + waitlist rosters, set capacity, and attendee self-service links."),
        new HubTile("/Organizer/Surveys", Localizer["Nav.OrgSurveys"].Value, Localizer["OrgContent.Surveys"].Value),
    };
}

<div class="card">
    <h2>@Localizer["OrgContent.Title"]</h2>
    @if (Model.AccessDenied)
    {
        <p class="error">@Localizer["Common.OrganizersOnly"]</p>
        <p><a asp-page="/Index">@Localizer["Common.BackToHub"]</a></p>
    }
    else
    {
        <p>@Localizer["OrgContent.Intro"]</p>
        <p><a asp-page="/Organizer/Index">&larr; @Localizer["Common.BackToOrganizerArea"]</a></p>
    }
</div>

@if (!Model.AccessDenied)
{
    <partial name="_HubGrid" model="@tiles" />
}
