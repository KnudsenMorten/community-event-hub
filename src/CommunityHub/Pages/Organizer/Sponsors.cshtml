@page
@model CommunityHub.Pages.Organizer.SponsorsModel
@{
    ViewData["Title"] = "Sponsors";
}

<div class="card">
    <h2>Sponsors</h2>
    @if (Model.AccessDenied)
    {
        <p class="error">This area is for organizers only.</p>
    }
    else
    {
        if (!string.IsNullOrEmpty(Model.Error))   { <p class="error" role="alert">@Model.Error</p> }
        if (!string.IsNullOrEmpty(Model.Message)) { <p class="info" role="status">@Model.Message</p> }

        <p style="font-size:13px;color:#6b7280;">
            Company name + contact details live in <strong>Company Manager (WordPress)</strong>.
            Tasks are auto-generated from completed WooCommerce sponsor orders
            (daily 06:00 UTC) via <code>SponsorTaskExpander</code> + <code>config/sponsor.eldk27.json</code>.
            This page summarises the per-company state and exports the full grid.
        </p>

        <div class="stat-grid" style="display:flex;flex-wrap:wrap;gap:12px;margin:12px 0 16px;">
            <div class="stat" style="background:var(--el-grey);border-radius:8px;padding:12px 16px;min-width:140px;">
                <div style="font-size:22px;font-weight:700;color:var(--el-darkblue);">@Model.CompanyCount</div>
                <div style="font-size:12px;color:#6b7280;text-transform:uppercase;">Companies</div>
            </div>
            <div class="stat" style="background:var(--el-grey);border-radius:8px;padding:12px 16px;min-width:140px;">
                <div style="font-size:22px;font-weight:700;color:var(--el-darkblue);">@Model.ContactCount</div>
                <div style="font-size:12px;color:#6b7280;text-transform:uppercase;">Sponsor contacts</div>
            </div>
            <div class="stat" style="background:var(--el-grey);border-radius:8px;padding:12px 16px;min-width:140px;">
                <div style="font-size:22px;font-weight:700;color:var(--el-darkblue);">@Model.TotalTasks</div>
                <div style="font-size:12px;color:#6b7280;text-transform:uppercase;">Tasks total</div>
            </div>
            <div class="stat" style="background:var(--el-grey);border-radius:8px;padding:12px 16px;min-width:140px;">
                <div style="font-size:22px;font-weight:700;color:#0a6;">@Model.DoneTasks</div>
                <div style="font-size:12px;color:#6b7280;text-transform:uppercase;">Done</div>
            </div>
            <div class="stat" style="background:var(--el-grey);border-radius:8px;padding:12px 16px;min-width:140px;">
                <div style="font-size:22px;font-weight:700;color:#c0392b;">@Model.OverdueTasks</div>
                <div style="font-size:12px;color:#6b7280;text-transform:uppercase;">Overdue</div>
            </div>
        </div>

        <p>
            <a asp-page-handler="Download"
               style="display:inline-block;background:var(--el-blue);color:#fff;
                      padding:9px 16px;border-radius:7px;text-decoration:none;font-size:15px;">
                Download .xlsx (Companies + Contacts + Tasks)
            </a>
        </p>

        <!-- ---- Search (company id or contact) ----------------------------- -->
        <form method="get" style="display:flex;flex-wrap:wrap;gap:12px;align-items:flex-end;margin:14px 0 4px;">
            <div style="flex:2 1 240px;min-width:160px;">
                <label for="Search">@Localizer["OrgGrid.Search"] (company, contact name / email)</label>
                <input type="text" id="Search" name="Search" value="@Model.Search" />
            </div>
            @* keep the current sort; reset to page 1 on a new search *@
            <input type="hidden" name="Sort" value="@Model.Sort" />
            <input type="hidden" name="Desc" value="@Model.Desc" />
            <div style="flex:0 0 auto;">
                <button type="submit">@Localizer["OrgGrid.Apply"]</button>
                <a asp-page="/Organizer/Sponsors" style="margin-left:8px;font-size:13px;">Clear</a>
            </div>
        </form>

        @if (Model.Companies.Count == 0)
        {
            <p style="margin-top:16px;color:#6b7280;">
                @Localizer["OrgGrid.NoMatch"] The WooCommerce pull job is daily &mdash; once an order completes, tasks will appear here.
            </p>
        }
        else
        {
            <p role="status" style="margin-top:8px;">
                @Localizer["OrgGrid.ShowingRange", Model.Paging.FirstRowNumber, Model.Paging.LastRowNumber, Model.Paging.TotalItems]
            </p>
            <div style="overflow-x:auto;margin-top:6px;">
            <table style="border-collapse:collapse;width:100%;font-size:13px;min-width:920px;">
                <caption class="sr-only">Sponsor companies for this edition</caption>
                <thead>
                    <tr style="border-bottom:2px solid #ddd;text-align:left;">
                        <th scope="col" style="padding:6px;" aria-sort="@Model.AriaSort("company")">
                            <a asp-page="/Organizer/Sponsors" asp-route-Search="@Model.Search" asp-route-Sort="company" asp-route-Desc="@Model.NextDescFor("company")" asp-route-PageNo="1">Company id@Model.SortIndicator("company")</a>
                        </th>
                        <th scope="col" style="padding:6px;" aria-sort="@Model.AriaSort("contacts")">
                            <a asp-page="/Organizer/Sponsors" asp-route-Search="@Model.Search" asp-route-Sort="contacts" asp-route-Desc="@Model.NextDescFor("contacts")" asp-route-PageNo="1">Contacts@Model.SortIndicator("contacts")</a>
                        </th>
                        <th scope="col" style="padding:6px;text-align:right;" aria-sort="@Model.AriaSort("open")">
                            <a asp-page="/Organizer/Sponsors" asp-route-Search="@Model.Search" asp-route-Sort="open" asp-route-Desc="@Model.NextDescFor("open")" asp-route-PageNo="1">Open@Model.SortIndicator("open")</a>
                        </th>
                        <th scope="col" style="padding:6px;text-align:right;">In progress</th>
                        <th scope="col" style="padding:6px;text-align:right;" aria-sort="@Model.AriaSort("done")">
                            <a asp-page="/Organizer/Sponsors" asp-route-Search="@Model.Search" asp-route-Sort="done" asp-route-Desc="@Model.NextDescFor("done")" asp-route-PageNo="1">Done@Model.SortIndicator("done")</a>
                        </th>
                        <th scope="col" style="padding:6px;text-align:right;" aria-sort="@Model.AriaSort("overdue")">
                            <a asp-page="/Organizer/Sponsors" asp-route-Search="@Model.Search" asp-route-Sort="overdue" asp-route-Desc="@Model.NextDescFor("overdue")" asp-route-PageNo="1">Overdue@Model.SortIndicator("overdue")</a>
                        </th>
                        <th scope="col" style="padding:6px;text-align:right;" aria-sort="@Model.AriaSort("total")">
                            <a asp-page="/Organizer/Sponsors" asp-route-Search="@Model.Search" asp-route-Sort="total" asp-route-Desc="@Model.NextDescFor("total")" asp-route-PageNo="1">Total@Model.SortIndicator("total")</a>
                        </th>
                        <th scope="col" style="padding:6px;" aria-sort="@Model.AriaSort("nextdue")">
                            <a asp-page="/Organizer/Sponsors" asp-route-Search="@Model.Search" asp-route-Sort="nextdue" asp-route-Desc="@Model.NextDescFor("nextdue")" asp-route-PageNo="1">Next due@Model.SortIndicator("nextdue")</a>
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model.Companies)
                    {
                        var rowBg = c.Overdue > 0 ? "background:#fff5f5;" : "";
                        <tr style="border-bottom:1px solid #eee;@(rowBg)">
                            <td style="padding:6px;font-family:monospace;">
                                @* Drill down to this company's sponsor contacts on the Participants grid. *@
                                <a asp-page="/Organizer/Participants"
                                   asp-route-SponsorCompanyFilter="@c.CompanyId"
                                   asp-route-RoleFilter="Sponsor"
                                   asp-route-ActiveFilter="all"
                                   title="View this company's participants">@c.CompanyId</a>
                            </td>
                            <td style="padding:6px;">
                                @if (c.Contacts.Count == 0)
                                {
                                    <em style="color:#c0392b;">no contacts in this edition</em>
                                }
                                else
                                {
                                    @for (int i = 0; i < c.Contacts.Count; i++)
                                    {
                                        var cn = c.Contacts[i];
                                        <span>@cn.Name <span style="color:#8a8f9c;font-size:11px;">&lt;@cn.Email&gt;</span></span>
                                        @if (i < c.Contacts.Count - 1) { <br /> }
                                    }
                                }
                            </td>
                            <td style="padding:6px;text-align:right;">@c.Open</td>
                            <td style="padding:6px;text-align:right;">@c.InProgress</td>
                            <td style="padding:6px;text-align:right;color:#0a6;">@c.Done</td>
                            <td style="padding:6px;text-align:right;@(c.Overdue > 0 ? "color:#c0392b;font-weight:600;" : "")">@c.Overdue</td>
                            <td style="padding:6px;text-align:right;">@c.Total</td>
                            <td style="padding:6px;">@(c.NextDue?.ToString("dd/MM/yyyy") ?? "-")</td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>

            @if (Model.Paging.TotalPages > 1)
            {
                <nav aria-label="Pagination" style="display:flex;flex-wrap:wrap;gap:8px;align-items:center;margin-top:14px;">
                    @if (Model.Paging.HasPrevious)
                    {
                        <a asp-page="/Organizer/Sponsors" asp-route-Search="@Model.Search"
                           asp-route-Sort="@Model.Sort" asp-route-Desc="@Model.Desc"
                           asp-route-PageNo="@(Model.Paging.Page - 1)" rel="prev"
                           style="padding:6px 12px;border:1px solid #c4c8d4;border-radius:6px;text-decoration:none;">@Localizer["OrgGrid.Prev"]</a>
                    }
                    <span>@Localizer["OrgGrid.PageOf", Model.Paging.Page, Model.Paging.TotalPages]</span>
                    @if (Model.Paging.HasNext)
                    {
                        <a asp-page="/Organizer/Sponsors" asp-route-Search="@Model.Search"
                           asp-route-Sort="@Model.Sort" asp-route-Desc="@Model.Desc"
                           asp-route-PageNo="@(Model.Paging.Page + 1)" rel="next"
                           style="padding:6px 12px;border:1px solid #c4c8d4;border-radius:6px;text-decoration:none;">@Localizer["OrgGrid.Next"]</a>
                    }
                </nav>
            }
        }

        @if (Model.ContactsWithoutCompany.Count > 0)
        {
            <h3 style="color:#c0392b;margin-top:18px;">Sponsor contacts without a company id</h3>
            <p style="font-size:13px;color:#6b7280;">
                These are participants with role Sponsor but no SponsorCompanyId. They won't see any tasks until the company id is set — usually via the WooCommerce order's <code>_cm_company_id</code> or via the participants page.
            </p>
            <ul>
                @foreach (var c in Model.ContactsWithoutCompany)
                {
                    <li>@c.Name &lt;@c.Email&gt;</li>
                }
            </ul>
        }
        @* ---- Stale / orphaned company-facts (§22 CRUD gap) ----------------- *@
        @if (Model.OrphanedSponsorFacts.Count > 0)
        {
            <h3 style="color:#b45309;margin-top:22px;">@Localizer["SponsorFacts.OrphanHeading"]</h3>
            <p style="font-size:13px;color:#6b7280;">@Localizer["SponsorFacts.OrphanIntro"]</p>
            <div style="overflow-x:auto;">
            <table style="border-collapse:collapse;width:100%;font-size:13px;">
                <caption class="sr-only">@Localizer["SponsorFacts.OrphanHeading"]</caption>
                <thead>
                    <tr style="border-bottom:2px solid #ddd;text-align:left;">
                        <th scope="col" style="padding:6px;">@Localizer["SponsorFacts.ColCompany"]</th>
                        <th scope="col" style="padding:6px;">@Localizer["SponsorFacts.ColShortDesc"]</th>
                        <th scope="col" style="padding:6px;">@Localizer["SponsorFacts.Delete"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var f in Model.OrphanedSponsorFacts)
                    {
                        <tr style="border-bottom:1px solid #eee;">
                            <td style="padding:6px;font-family:monospace;">@f.CompanyId</td>
                            <td style="padding:6px;color:#6b7280;">@(string.IsNullOrWhiteSpace(f.ShortDescription) ? "—" : f.ShortDescription)</td>
                            <td style="padding:6px;">
                                @* type=button opens the shared confirm modal, then posts
                                   the hidden delete form with this facts-row id. *@
                                <button type="button" class="js-delete-facts"
                                        data-id="@f.Id" data-name="@f.CompanyId"
                                        aria-haspopup="dialog"
                                        style="background:#b91c1c;color:#fff;border:none;border-radius:6px;padding:5px 10px;cursor:pointer;font-size:12.5px;">
                                    @Localizer["SponsorFacts.Delete"]
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>

            @* Hidden form the per-row delete posts to (after the confirm modal). *@
            <form method="post" asp-page-handler="DeleteFacts" id="deleteFactsForm" hidden>
                <input type="hidden" name="sponsorInfoId" id="deleteFactsId" value="" />
                <input type="hidden" name="Search" value="@Model.Search" />
                <input type="hidden" name="Sort" value="@Model.Sort" />
                <input type="hidden" name="Desc" value="@Model.Desc" />
                <input type="hidden" name="PageNo" value="@Model.Paging.Page" />
            </form>

            @* Accessible confirm modal (§21) gating a single facts delete. *@
            <div id="confirmDeleteFacts" class="modal-backdrop" role="dialog" aria-modal="true"
                 aria-labelledby="deleteFactsTitle" aria-describedby="deleteFactsBody" hidden
                 style="position:fixed;inset:0;background:rgba(0,0,0,.45);display:flex;
                        align-items:center;justify-content:center;padding:16px;z-index:1000;">
                <div class="modal-card"
                     style="background:#fff;border-radius:10px;max-width:440px;width:100%;
                            padding:20px;box-shadow:0 10px 30px rgba(0,0,0,.25);">
                    <h3 id="deleteFactsTitle" style="margin-top:0;">@Localizer["SponsorFacts.DeleteConfirmTitle"]</h3>
                    <p id="deleteFactsBody">
                        @Localizer["SponsorFacts.DeleteConfirmBody"]
                        <strong data-facts-summary></strong>
                    </p>
                    <div style="display:flex;flex-wrap:wrap;gap:10px;justify-content:flex-end;margin-top:16px;">
                        <button type="button" data-facts-cancel class="secondary"
                                style="padding:8px 14px;border:1px solid #c4c8d4;border-radius:6px;background:#fff;cursor:pointer;">
                            @Localizer["OrgGrid.Cancel"]
                        </button>
                        <button type="button" data-facts-ok
                                style="padding:8px 14px;border:none;border-radius:6px;background:#b91c1c;color:#fff;cursor:pointer;">
                            @Localizer["SponsorFacts.Delete"]
                        </button>
                    </div>
                </div>
            </div>

            <script>
                (function () {
                    var form = document.getElementById('deleteFactsForm');
                    var idInput = document.getElementById('deleteFactsId');
                    var modal = document.getElementById('confirmDeleteFacts');
                    if (!form || !idInput || !modal) return;
                    var summaryEl = modal.querySelector('[data-facts-summary]');
                    var okBtn = modal.querySelector('[data-facts-ok]');
                    var cancelBtn = modal.querySelector('[data-facts-cancel]');
                    var lastFocused = null;
                    var pendingId = null;

                    function open(name) {
                        if (summaryEl) summaryEl.textContent = name;
                        modal.hidden = false;
                        lastFocused = document.activeElement;
                        if (okBtn) okBtn.focus();
                    }
                    function close() {
                        modal.hidden = true;
                        if (lastFocused && lastFocused.focus) lastFocused.focus();
                    }
                    document.querySelectorAll('.js-delete-facts').forEach(function (b) {
                        b.addEventListener('click', function () {
                            pendingId = b.getAttribute('data-id');
                            open(b.getAttribute('data-name') || '');
                        });
                    });
                    if (okBtn) okBtn.addEventListener('click', function () {
                        idInput.value = pendingId;
                        form.submit();
                    });
                    if (cancelBtn) cancelBtn.addEventListener('click', close);
                    modal.addEventListener('click', function (e) { if (e.target === modal) close(); });
                    document.addEventListener('keydown', function (e) {
                        if (e.key === 'Escape' && !modal.hidden) close();
                    });
                })();
            </script>
        }
    }
    <p><a asp-page="/Organizer/Index">Back to organizer area</a></p>
</div>
