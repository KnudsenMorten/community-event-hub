@page
@model CommunityHub.Pages.Organizer.VolunteerStructureModel
@{
    ViewData["Title"] = "Volunteer work structure";
}

<style>
    /* Mobile-first: cards stack, controls go full-width and wrap at ~360px. */
    .vs-cat { border:1px solid #d7dbe4; border-radius:10px; margin:0 0 16px 0; overflow:hidden; }
    .vs-cat-head { background:var(--el-darkblue,#1D3380); color:#fff; padding:12px 14px; }
    .vs-cat-head h3 { margin:0; font-size:17px; }
    .vs-cat-head .owners { font-size:12.5px; opacity:.92; margin-top:4px; line-height:1.5; }
    .vs-body { padding:12px 14px; }
    .vs-sub { border-left:3px solid #008BD2; padding:8px 0 8px 12px; margin:10px 0; }
    .vs-sub h4 { margin:0 0 6px 0; font-size:14.5px; }
    .vs-task { background:#f6f8fb; border-radius:6px; padding:8px 10px; margin:6px 0; font-size:13.5px; }
    .vs-task .meta { color:#6e7681; font-size:12px; }
    .vs-task .assignees { margin-top:4px; }
    .vs-pill { display:inline-block; background:#e6f3fb; color:#1D3380; border-radius:10px;
               padding:2px 8px; font-size:11.5px; margin:2px 4px 2px 0; }
    .vs-form { display:flex; flex-wrap:wrap; gap:6px; align-items:center; margin-top:6px; }
    .vs-form input[type=text], .vs-form input[type=date], .vs-form select {
        flex:1 1 140px; min-width:0; box-sizing:border-box; padding:7px 9px;
        font-size:13.5px; border:1px solid #c4c8d4; border-radius:6px; }
    .vs-form button { background:#008BD2; color:#fff; border:0; border-radius:6px;
        padding:8px 14px; font-size:13px; font-weight:600; cursor:pointer; white-space:nowrap; }
    .vs-form button.danger { background:#c0392b; }
    .vs-form button:hover { filter:brightness(.93); }
    .vs-note { background:#f0fdf4; border-left:4px solid #16a34a; padding:10px 12px;
        border-radius:6px; margin-bottom:14px; font-size:13.5px; color:#166534; }
    @@media (max-width: 600px) {
        .vs-form input, .vs-form select, .vs-form button { flex:1 1 100%; }
    }
</style>

<div class="card">
    <h2>Volunteer work structure</h2>
    <p>Build the work tree (Category &rarr; Subcategory &rarr; Task), name each
       category&rsquo;s <strong>lead</strong> (an organizer, for oversight) and
       appoint its <strong>supervisor</strong> (a volunteer who runs it), then
       assign volunteers to tasks.</p>

    @if (Model.AccessDenied)
    {
        <p class="error">This area is for organizers only.</p>
    }
    else
    {
        @if (!string.IsNullOrEmpty(Model.Notice))
        {
            <div class="vs-note">@Model.Notice</div>
        }

        <form method="post" asp-page-handler="CreateCategory" class="vs-form">
            <input type="text" name="name" placeholder="New category name" maxlength="200" required />
            <input type="text" name="description" placeholder="Description (optional)" maxlength="2000" />
            <button type="submit">Add category</button>
        </form>
    }
</div>

@if (!Model.AccessDenied)
{
    @if (Model.Tree.Count == 0)
    {
        <div class="card"><p class="info">No categories yet. Add your first one above.</p></div>
    }
    else
    {
        @* Bulk bar (§20 universal CRUD + bulk): tick task checkboxes anywhere in the
           tree, then change status / delete the selection in one action. Checkboxes
           are plain (the task rows host their own forms — nested forms are invalid);
           the JS copies the checked ids into a hidden POST form and submits, gated by
           the confirm modal (live count). The server re-validates + is event-scoped. *@
        <div class="card" style="position:sticky;top:0;z-index:5;">
            <div style="display:flex;flex-wrap:wrap;gap:8px;align-items:center;">
                <strong style="font-size:13.5px;color:var(--el-darkblue,#1D3380);">Bulk task actions</strong>
                <label for="vsBulkStatus" style="margin:0;font-size:13px;">Set status to</label>
                <select id="vsBulkStatus" style="padding:7px 9px;border:1px solid #c4c8d4;border-radius:6px;font-size:13px;">
                    @foreach (var s in Enum.GetValues<CommunityHub.Core.Domain.VolunteerTaskStatus>())
                    {
                        <option value="@s">@s</option>
                    }
                </select>
                <button type="button" id="vsBulkStatusBtn"
                        style="background:#008BD2;color:#fff;border:0;border-radius:6px;padding:8px 14px;font-size:13px;font-weight:600;cursor:pointer;">
                    Apply status
                </button>
                <button type="button" id="vsBulkDeleteBtn" aria-haspopup="dialog"
                        style="background:#c0392b;color:#fff;border:0;border-radius:6px;padding:8px 14px;font-size:13px;font-weight:600;cursor:pointer;">
                    Delete selected tasks
                </button>
                <span id="vsBulkCount" role="status" style="font-size:12.5px;color:#6b7280;">0 selected</span>
            </div>
            <p style="font-size:12px;color:#9ca3af;margin:6px 0 0;">
                Tasks with help-request history are protected from delete (you will be told how many were kept).
            </p>
            <form method="post" id="vsBulkForm" hidden>
                <input type="hidden" name="BulkStatus" id="vsBulkStatusField" />
                <div id="vsBulkIds"></div>
            </form>
        </div>
    }

    @foreach (var cat in Model.Tree)
    {
        var leadName = cat.LeadParticipant is null ? "(none)" :
            (string.IsNullOrWhiteSpace(cat.LeadParticipant.FullName) ? cat.LeadParticipant.Email : cat.LeadParticipant.FullName);
        var supName = cat.SupervisorParticipant is null ? "(none)" :
            (string.IsNullOrWhiteSpace(cat.SupervisorParticipant.FullName) ? cat.SupervisorParticipant.Email : cat.SupervisorParticipant.FullName);
        var taskCount = cat.Subcategories.Sum(s => s.Tasks.Count);

        <div class="vs-cat">
            <div class="vs-cat-head">
                <h3>@cat.Name</h3>
                <div class="owners">
                    Lead (organizer): <strong>@leadName</strong> &middot;
                    Supervisor (volunteer): <strong>@supName</strong><br />
                    @cat.Subcategories.Count subcategor@(cat.Subcategories.Count == 1 ? "y" : "ies"), @taskCount task@(taskCount == 1 ? "" : "s")
                </div>
            </div>
            <div class="vs-body">

                <form method="post" asp-page-handler="SetLead" class="vs-form">
                    <input type="hidden" name="categoryId" value="@cat.Id" />
                    <select name="leadParticipantId">
                        <option value="">— pick a lead (organizer) —</option>
                        @foreach (var o in Model.OrganizerOptions)
                        {
                            if (cat.LeadParticipantId?.ToString() == o.Value)
                            { <option value="@o.Value" selected>@o.Text</option> }
                            else { <option value="@o.Value">@o.Text</option> }
                        }
                    </select>
                    <button type="submit">Set lead</button>
                </form>

                <form method="post" asp-page-handler="AppointSupervisor" class="vs-form">
                    <input type="hidden" name="categoryId" value="@cat.Id" />
                    <select name="supervisorParticipantId">
                        <option value="">— appoint a supervisor (volunteer) —</option>
                        @foreach (var v in Model.VolunteerOptions)
                        {
                            if (cat.SupervisorParticipantId?.ToString() == v.Value)
                            { <option value="@v.Value" selected>@v.Text</option> }
                            else { <option value="@v.Value">@v.Text</option> }
                        }
                    </select>
                    <button type="submit">Appoint supervisor</button>
                </form>

                @foreach (var sub in cat.Subcategories.OrderBy(s => s.Name))
                {
                    <div class="vs-sub">
                        <h4>@sub.Name
                            <form method="post" asp-page-handler="DeleteSubcategory" style="display:inline">
                                <input type="hidden" name="subcategoryId" value="@sub.Id" />
                                <button type="submit" class="danger" style="padding:2px 8px;font-size:11px;border:0;border-radius:5px;background:#c0392b;color:#fff;cursor:pointer;">remove</button>
                            </form>
                        </h4>

                        @foreach (var t in sub.Tasks.OrderBy(t => t.Title))
                        {
                            <div class="vs-task">
                                <input class="vstaskChk" type="checkbox" value="@t.Id"
                                       aria-label="Select task @t.Title" style="margin-right:6px;vertical-align:middle;" />
                                <strong>@t.Title</strong>
                                <span class="meta">
                                    &middot; @t.Status
                                    @if (t.DueDate is not null) { <text>&middot; due @t.DueDate.Value.ToString("dd-MM-yyyy")</text> }
                                    @if (!string.IsNullOrWhiteSpace(t.Shift)) { <text>&middot; @t.Shift</text> }
                                </span>
                                <div class="assignees">
                                    @foreach (var a in t.Assignments)
                                    {
                                        <span class="vs-pill">vol #@a.ParticipantId</span>
                                    }
                                </div>
                                <form method="post" asp-page-handler="Assign" class="vs-form">
                                    <input type="hidden" name="taskId" value="@t.Id" />
                                    <select name="volunteerParticipantId" required>
                                        <option value="">— assign volunteer —</option>
                                        @foreach (var v in Model.VolunteerOptions)
                                        { <option value="@v.Value">@v.Text</option> }
                                    </select>
                                    <button type="submit">Assign</button>
                                    <button type="submit" asp-page-handler="DeleteTask" name="taskId" value="@t.Id" formmethod="post" class="danger">Delete task</button>
                                </form>
                            </div>
                        }

                        <form method="post" asp-page-handler="CreateTask" class="vs-form">
                            <input type="hidden" name="subcategoryId" value="@sub.Id" />
                            <input type="text" name="title" placeholder="New task title" maxlength="300" required />
                            <input type="date" name="due" />
                            <input type="text" name="shift" placeholder="Shift (optional)" maxlength="200" />
                            <button type="submit">Add task</button>
                        </form>
                    </div>
                }

                <form method="post" asp-page-handler="CreateSubcategory" class="vs-form">
                    <input type="hidden" name="categoryId" value="@cat.Id" />
                    <input type="text" name="name" placeholder="New subcategory name" maxlength="200" required />
                    <button type="submit">Add subcategory</button>
                </form>

                <form method="post" asp-page-handler="DeleteCategory" class="vs-form" style="margin-top:10px;">
                    <input type="hidden" name="categoryId" value="@cat.Id" />
                    <button type="submit" class="danger" onclick="return confirm('Delete this category and everything under it?');">Delete category</button>
                </form>
            </div>
        </div>
    }

    <div class="card"><p><a asp-page="/Organizer/Index">Back to organizer area</a></p></div>

    @* Bulk-delete confirm modal: shows the live count, then submits the hidden form. *@
    <div id="vsBulkModal" class="modal-backdrop" role="dialog" aria-modal="true"
         aria-labelledby="vsBulkTitle" aria-describedby="vsBulkBody" hidden
         style="position:fixed;inset:0;background:rgba(0,0,0,.45);display:flex;
                align-items:center;justify-content:center;padding:16px;z-index:1000;">
        <div class="modal-card"
             style="background:#fff;border-radius:10px;max-width:440px;width:100%;
                    padding:20px;box-shadow:0 10px 30px rgba(0,0,0,.25);">
            <h3 id="vsBulkTitle" style="margin-top:0;">Delete the selected tasks?</h3>
            <p id="vsBulkBody"></p>
            <div style="display:flex;flex-wrap:wrap;gap:10px;justify-content:flex-end;margin-top:16px;">
                <button type="button" id="vsBulkCancel" class="secondary"
                        style="padding:8px 14px;border:1px solid #c4c8d4;border-radius:6px;background:#fff;cursor:pointer;">Cancel</button>
                <button type="button" id="vsBulkConfirm"
                        style="padding:8px 14px;border:none;border-radius:6px;background:#c0392b;color:#fff;cursor:pointer;">Delete tasks</button>
            </div>
        </div>
    </div>

    <script>
        (function () {
            var form = document.getElementById('vsBulkForm');
            var idsHost = document.getElementById('vsBulkIds');
            var statusField = document.getElementById('vsBulkStatusField');
            var statusSel = document.getElementById('vsBulkStatus');
            var statusBtn = document.getElementById('vsBulkStatusBtn');
            var delBtn = document.getElementById('vsBulkDeleteBtn');
            var countEl = document.getElementById('vsBulkCount');
            if (!form || !idsHost) return;
            var modal = document.getElementById('vsBulkModal');
            var bodyEl = document.getElementById('vsBulkBody');
            var cancelBtn = document.getElementById('vsBulkCancel');
            var confirmBtn = document.getElementById('vsBulkConfirm');
            var lastFocused = null;

            function checked() { return document.querySelectorAll('.vstaskChk:checked'); }
            function refreshCount() { if (countEl) countEl.textContent = checked().length + ' selected'; }
            document.querySelectorAll('.vstaskChk').forEach(function (c) {
                c.addEventListener('change', refreshCount);
            });
            refreshCount();

            function populateIds() {
                idsHost.innerHTML = '';
                checked().forEach(function (c) {
                    var h = document.createElement('input');
                    h.type = 'hidden'; h.name = 'SelectedTaskIds'; h.value = c.value;
                    idsHost.appendChild(h);
                });
            }
            function submitTo(handler) {
                populateIds();
                form.setAttribute('action', '?handler=' + encodeURIComponent(handler));
                form.submit();
            }

            if (statusBtn) {
                statusBtn.addEventListener('click', function () {
                    if (checked().length === 0) { alert('Pick at least one task first.'); return; }
                    if (statusField) statusField.value = statusSel.value;
                    submitTo('BulkStatus');
                });
            }
            if (delBtn) {
                delBtn.addEventListener('click', function () {
                    if (checked().length === 0) { alert('Pick at least one task first.'); return; }
                    bodyEl.textContent = 'This permanently removes ' + checked().length +
                        ' selected task(s) and their volunteer assignments. Tasks with help-request history are kept. This cannot be undone.';
                    modal.hidden = false;
                    lastFocused = document.activeElement;
                    confirmBtn.focus();
                });
            }
            function close() { modal.hidden = true; if (lastFocused && lastFocused.focus) lastFocused.focus(); }
            confirmBtn.addEventListener('click', function () { submitTo('BulkDeleteTasks'); });
            cancelBtn.addEventListener('click', close);
            modal.addEventListener('click', function (e) { if (e.target === modal) close(); });
            document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && !modal.hidden) close(); });
        })();
    </script>
}
