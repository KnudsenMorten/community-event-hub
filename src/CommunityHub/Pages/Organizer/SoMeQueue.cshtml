@page
@using CommunityHub.Core.Domain
@model CommunityHub.Pages.Organizer.SoMeQueueModel
@{
    ViewData["Title"] = "SoMe queue";
}

@if (Model.AccessDenied)
{
    <div class="card">
        <h2>SoMe queue</h2>
        <p class="error" role="alert">This page is for organizers.</p>
        <p><a asp-page="/Index">Back to hub</a></p>
    </div>
    return;
}

<style>
    .btn { background:#008BD2; color:#fff; border:0; border-radius:6px;
           padding:6px 12px; font-size:13px; cursor:pointer; text-decoration:none; }
    .btn:hover { background:#0079b8; }
    .btn-ghost { background:#eef2f7; color:#1f2937; }
    .som-post { margin:10px 0; }
    .som-meta { color:#4b5563; font-size:13px; }
    .som-badge { display:inline-block; padding:1px 8px; border-radius:10px; font-size:12px; }
    .som-on { background:#dcfce7; color:#166534; }
    .som-off { background:#fee2e2; color:#991b1b; }
    .som-status { background:#e0e7ff; color:#3730a3; }
    .som-grid { display:grid; grid-template-columns:1fr; gap:8px; max-width:640px; }
    .som-grid label { font-weight:600; }
    .som-grid input, .som-grid textarea { width:100%; box-sizing:border-box; }
    .som-tags { font-size:13px; color:#374151; }
    .som-inline { display:flex; flex-wrap:wrap; gap:8px; align-items:center; }
    .som-preview { border:1px solid #c7d2fe; background:#eef2ff; border-radius:8px; padding:10px; }
    details > summary { cursor:pointer; font-weight:600; }
</style>

@if (Model.Message is not null)
{
    <div class="card"><p role="status" style="color:#0a6;">@Model.Message</p></div>
}

<div class="card">
    <h2>Social-media calendar — LinkedIn company page</h2>
    <p>
        Scheduled posts for your event's LinkedIn company page. Posts publish at their
        scheduled time when they are <strong>Active</strong>. Use Preview to see exactly
        what will publish; the override text always wins over the auto text.
    </p>
    <p><a asp-page="/Organizer/SoMeSettings">SoMe settings &amp; connection</a></p>
</div>

@if (Model.Preview is not null && Model.PreviewPostId is not null)
{
    <div class="card">
        <h3>Preview — post #@Model.PreviewPostId</h3>
        <div class="som-preview">
            <p style="white-space:pre-wrap;">@Model.Preview.Text</p>
            @if (!string.IsNullOrWhiteSpace(Model.Preview.ImageRef))
            {
                <p class="som-meta">Image: <code>@Model.Preview.ImageRef</code></p>
            }
            else if (Model.Preview.AwaitingApprovedGraphic)
            {
                <p class="som-meta" role="status">Image: awaiting approved graphic (none released yet) — will publish text-only until then.</p>
            }
            @if (Model.Preview.Tags.Count > 0)
            {
                <p class="som-tags">Tags: @string.Join(", ", Model.Preview.Tags)</p>
            }
            <p class="som-meta">
                Scheduled: @Model.Preview.ScheduledAtUtc.ToString("u") —
                @(Model.Preview.WillPublish ? "will publish on schedule" : "will NOT publish (inactive or already sent)")
            </p>
        </div>
    </div>
}

<div class="card">
    <h3>Add an ad-hoc post</h3>
    <form method="post" asp-page-handler="AdHoc" class="som-grid">
        <label for="adhoc-text">Post text</label>
        <textarea id="adhoc-text" name="AdHocText" rows="3" required>@Model.AdHocText</textarea>

        <label for="adhoc-img">Image reference (URL / SharePoint path, optional)</label>
        <input id="adhoc-img" name="AdHocImageRef" type="text" value="@Model.AdHocImageRef" />

        <label for="adhoc-when">Scheduled date/time (UTC)</label>
        <input id="adhoc-when" name="AdHocScheduledAt" type="datetime-local" required />

        <div><button type="submit" class="btn">Add to queue</button></div>
    </form>
</div>

@if (Model.Posts.Count == 0)
{
    <div class="card"><p>No posts scheduled yet.</p></div>
}

@foreach (var p in Model.Posts)
{
    <div class="card som-post">
        <div class="som-inline">
            <strong>#@p.Id · @p.Type</strong>
            <span class="som-badge @(p.IsActive ? "som-on" : "som-off")">@(p.IsActive ? "Active" : "Inactive")</span>
            <span class="som-badge som-status">@p.Status</span>
            @if (p.AutoGenerated) { <span class="som-meta">auto</span> } else { <span class="som-meta">static</span> }
            @if (p.IsAwaitingApprovedGraphic) { <span class="som-badge som-off" role="status">awaiting approved graphic</span> }
        </div>
        <p class="som-meta">Scheduled: @p.ScheduledAtUtc.ToString("u")</p>
        @if (!string.IsNullOrWhiteSpace(p.LastError))
        {
            <p class="error" role="alert">Last error: @p.LastError</p>
        }
        <p style="white-space:pre-wrap;">@p.EffectiveText</p>
        @if (p.TagList.Count > 0)
        {
            <p class="som-tags">Tags: @string.Join(", ", p.TagList)</p>
        }

        <div class="som-inline">
            <form method="post" asp-page-handler="Preview">
                <input type="hidden" name="PostId" value="@p.Id" />
                <button type="submit" class="btn btn-ghost">Preview</button>
            </form>
            <form method="post" asp-page-handler="ToggleActive">
                <input type="hidden" name="PostId" value="@p.Id" />
                <input type="hidden" name="SetActive" value="@((!p.IsActive).ToString().ToLowerInvariant())" />
                <button type="submit" class="btn btn-ghost">@(p.IsActive ? "Deactivate" : "Activate")</button>
            </form>
        </div>

        <details>
            <summary>Fine-tune / reschedule</summary>
            <form method="post" asp-page-handler="Edit" class="som-grid" style="margin-top:8px;">
                <input type="hidden" name="PostId" value="@p.Id" />
                <label for="edit-text-@p.Id">Override text (blank = use auto text)</label>
                <textarea id="edit-text-@p.Id" name="EditText" rows="3">@p.ManualTextOverride</textarea>
                <label for="edit-img-@p.Id">Image reference</label>
                <input id="edit-img-@p.Id" name="EditImageRef" type="text" value="@p.ImageRef" />
                <div><button type="submit" class="btn">Save text/image</button></div>
            </form>
            <form method="post" asp-page-handler="Reschedule" class="som-grid" style="margin-top:8px;">
                <input type="hidden" name="PostId" value="@p.Id" />
                <label for="resch-@p.Id">Reschedule to (UTC)</label>
                <input id="resch-@p.Id" name="RescheduleAt" type="datetime-local" />
                <div><button type="submit" class="btn">Reschedule</button></div>
            </form>
        </details>
    </div>
}

<p><a asp-page="/Index">Back to hub</a></p>
