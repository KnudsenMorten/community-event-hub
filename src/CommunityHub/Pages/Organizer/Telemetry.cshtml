@page
@model CommunityHub.Pages.Organizer.TelemetryModel
@{
    ViewData["Title"] = "Attendee telemetry";
}

@* §55: in-area organizer telemetry. Reuses the SAME shared panel partial as the
   public /attendee-telemetry page and the sponsor page, so the ranked tables +
   segment + topic-filter dropdowns are identical everywhere. *@
<div class="card tl-wrap">
    <h1 id="telemetry">Who's coming to Experts Live Denmark</h1>

    @if (Model.AccessDenied)
    {
        <p class="error">This area is for organizers only.</p>
        <p><a asp-page="/Index">@Localizer["Common.BackToHub"]</a></p>
        return;
    }

    <p style="color:#4b5563;margin-top:0;">
        Aggregate attendee analytics — pick a segment and drill into the breakdown by
        job role, where attendees are from, ticket type and the registration custom-field
        topics. Same figures as the public sponsor telemetry page.
    </p>

    @* §69 — organizer surface: IsOrganizer:true unlocks the organizer-only "Top companies" table. *@
    <partial name="_AttendeeTelemetryPanel"
             model="new CommunityHub.Pages.Shared.AttendeeTelemetryPanelModel(Model.Data, Model.Segments, IsOrganizer: true)" />
</div>
