@page "/Agenda"
@using CommunityHub.Core.Domain
@model CommunityHub.Pages.AgendaModel
@{
    Layout = "_Layout";
    ViewData["Title"] = Model.View is null
        ? Localizer["Agenda.Title"].Value
        : $"{Localizer["Agenda.Title"].Value} — {Model.View.EventDisplayName}";
}

<style>
    /* Mobile-first: single column, readable at ~360px. */
    .ag-head {
        background: var(--el-darkblue, #1D3380); color: #fff;
        padding: 22px; border-radius: 10px 10px 0 0; margin: 0;
    }
    .ag-head h1 { margin: 0; font-size: 22px; font-weight: 700; line-height: 1.25; }
    .ag-head .meta { font-size: 13.5px; opacity: .92; margin-top: 6px; }
    .ag-body { padding: 18px 16px 22px; }

    .ag-count { font-size: 13px; color: #4a5160; margin: 0 0 6px; }
    .ag-note { font-size: 12.5px; color: #6a7280; margin: 0 0 16px; }
    .ag-toolbar { margin: 0 0 16px; }
    .ag-toolbar a.btn-list {
        display: inline-block; background: #e4e7ee; color: #24292f; text-decoration: none;
        padding: 9px 16px; border-radius: 7px; font-size: 13.5px; font-weight: 600;
    }
    .ag-toolbar a.btn-list:hover, .ag-toolbar a.btn-list:focus { background: #d6dae4; }

    .ag-day { margin: 0 0 22px; }
    .ag-day > h2 {
        position: sticky; top: 0; z-index: 1;
        background: #f6f7fa; border: 1px solid #e4e7ee; border-radius: 8px;
        margin: 0 0 10px; padding: 10px 13px; font-size: 15.5px; color: #1D3380;
    }

    .ag-slot {
        display: grid; grid-template-columns: 1fr; gap: 4px;
        border: 1px solid #e4e7ee; border-left: 4px solid var(--el-blue, #008BD2);
        border-radius: 9px; padding: 12px 14px; background: #fff; margin: 0 0 10px;
    }
    .ag-slot.type-mc { border-left-color: #4527a0; }
    .ag-slot.type-sponsor { border-left-color: #8a4b00; }
    .ag-slot .ag-time {
        font-size: 12.5px; font-weight: 700; color: #24292f; letter-spacing: .2px;
    }
    .ag-slot h3 { margin: 2px 0 0; font-size: 15.5px; line-height: 1.3; color: #1D3380; }
    .ag-slot h3 a { color: #1D3380; text-decoration: none; }
    .ag-slot h3 a:hover, .ag-slot h3 a:focus { text-decoration: underline; }
    .ag-tags { display: flex; flex-wrap: wrap; gap: 6px; margin: 6px 0 0; }
    .ag-tag {
        font-size: 11px; font-weight: 600; padding: 2px 8px; border-radius: 999px;
        background: #eef1f7; color: #344; white-space: nowrap;
    }
    .ag-tag.type-mc { background: #ece6fb; color: #4527a0; }
    .ag-tag.type-sponsor { background: #fdeede; color: #8a4b00; }
    .ag-slot .ag-speakers { font-size: 13px; color: #24292f; margin: 6px 0 0; }
    .ag-slot .ag-speakers .lbl { color: #6a7280; }

    .ag-empty { color: #555; font-style: italic; padding: 18px 4px; }

    .sr-only { position:absolute; width:1px; height:1px; padding:0; margin:-1px;
        overflow:hidden; clip:rect(0,0,0,0); white-space:nowrap; border:0; }

    @@media (min-width: 640px) {
        .ag-slot { grid-template-columns: 96px 1fr; column-gap: 16px; align-items: start; }
        .ag-slot .ag-time { padding-top: 2px; }
        .ag-slot h3, .ag-slot .ag-tags, .ag-slot .ag-speakers { grid-column: 2; }
        .ag-slot .ag-time { grid-row: 1 / span 3; }
    }
</style>

<div class="card" style="padding:0; overflow:hidden; max-width:880px; margin:0 auto;">
    <div class="ag-head">
        <h1>@Localizer["Agenda.Title"]</h1>
        @if (Model.View is not null)
        {
            <div class="meta">@Model.View.EventDisplayName</div>
        }
    </div>

    <div class="ag-body">
        @if (Model.NoActiveEvent || Model.View is null)
        {
            <p class="ag-empty">@Localizer["Public.NoLiveEvent"]</p>
        }
        else
        {
            var view = Model.View;

            <div class="ag-toolbar">
            <a class="btn-list" href="/Sessions">@Localizer["Agenda.ListView"] &rarr;</a>
        </div>

        if (view.IsEmpty)
        {
            <p class="ag-empty">@Localizer["Agenda.NothingScheduled"]</p>
        }
        else
        {
            <p class="ag-count" role="status" aria-live="polite">
                @string.Format(Localizer["Agenda.Summary"].Value, view.ScheduledCount, view.Days.Count)
            </p>
            @if (view.UnscheduledCount > 0)
            {
                <p class="ag-note">
                    @string.Format(Localizer["Agenda.UnscheduledNote"].Value, view.UnscheduledCount)
                </p>
            }

            @foreach (var day in view.Days)
            {
                var dayLabel = day.Date.ToDateTime(TimeOnly.MinValue).ToString("dddd dd MMMM");
                <section class="ag-day" aria-label="@dayLabel">
                    <h2>@dayLabel</h2>
                    @foreach (var s in day.Items)
                    {
                        var typeClass = s.Type == SessionType.MasterClass ? "type-mc"
                            : s.Type == SessionType.TechnicalSession ? "type-sponsor" : "";
                        var timeText = s.StartsAt.ToString("HH:mm")
                            + (s.EndsAt is not null ? $"–{s.EndsAt.Value.ToString("HH:mm")}" : "");
                        <article class="ag-slot @typeClass">
                            <div class="ag-time">
                                <span class="sr-only">@Localizer["Agenda.TimeLabel"]</span>@timeText
                            </div>
                            <h3><a href="/Sessions/@s.Id">@s.Title</a></h3>
                            <div class="ag-tags">
                                <span class="ag-tag @typeClass">@CommunityHub.Pages.AgendaModel.Display(s.Type)</span>
                                <span class="ag-tag">@CommunityHub.Pages.AgendaModel.Display(s.Length)</span>
                                @if (!string.IsNullOrWhiteSpace(s.Room))
                                {
                                    <span class="ag-tag">@Localizer["Agenda.RoomTag"] @s.Room</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(s.Track))
                                {
                                    <span class="ag-tag">@s.Track</span>
                                }
                            </div>
                            @if (!string.IsNullOrWhiteSpace(s.Speakers))
                            {
                                <div class="ag-speakers">
                                    <span class="lbl">@Localizer["Agenda.With"]</span> @s.Speakers
                                </div>
                            }
                        </article>
                    }
                </section>
            }
        }
        }
    </div>
</div>
