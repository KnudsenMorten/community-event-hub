@page
@model CommunityHub.Pages.WelcomeModel
@{
    ViewData["Title"] = Localizer["Welcome.Title"].Value;
}

<div class="card" style="padding:24px 18px;max-width:680px;margin:0 auto;">
    <div style="text-align:center;">
        <img src="~/img/logo.png" alt="@Localizer["Welcome.LogoAlt"].Value"
             style="height:96px;max-width:100%;margin:4px auto 20px;display:block;" />
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.WelcomeBodyHtml))
    {
        @* The per-role welcome content, rendered body-only (no email shell, no
           Subject line). It is already HTML and token values were HTML-encoded at
           the renderer seam, so it is safe to emit verbatim. *@
        <div class="welcome-body" style="font-size:16px;line-height:1.6;color:#1a1a2e;word-wrap:break-word;overflow-wrap:anywhere;">
            @Html.Raw(Model.WelcomeBodyHtml)
        </div>
    }
    else
    {
        @* Fallback when no welcome template is available — never a blank page. *@
        <h2 style="color:var(--el-darkblue);font-size:24px;margin:0 0 12px;text-align:center;">
            @Localizer["Welcome.Heading", Model.EventDisplayName, Model.FirstName]
        </h2>
        <p style="font-size:16px;color:#1a1a2e;text-align:center;margin:0 0 16px;">
            @Localizer["Welcome.RoleIntro", Model.RoleName]
        </p>
    }

    <form method="post" asp-page-handler="Continue" style="margin-top:24px;text-align:center;">
        <button type="submit" style="padding:12px 28px;font-size:16px;width:100%;max-width:320px;">
            @Localizer["Welcome.Continue"]
        </button>
    </form>

    <p style="font-size:12px;color:#8a8f9c;margin-top:14px;text-align:center;">
        @Localizer["Welcome.OnceNote"]
    </p>
</div>
