@page
@model CommunityHub.Pages.WelcomeModel
@{
    ViewData["Title"] = Localizer["Welcome.Title"].Value;
    var venue = string.IsNullOrWhiteSpace(Model.VenueName) ? Localizer["Welcome.DefaultVenue"].Value : Model.VenueName;
}

<div class="card" style="text-align:center;padding:28px 24px;">
    <img src="~/img/logo.png" alt="@Localizer["Welcome.LogoAlt"].Value"
         style="height:120px;margin:8px auto 24px;display:block;" />

    <h2 style="color:var(--el-darkblue);font-size:26px;margin:0 0 8px;">
        @Localizer["Welcome.Heading", Model.EventDisplayName, Model.FirstName]
    </h2>
    <p style="font-size:16px;color:#1a1a2e;margin:0 0 24px;">
        @Localizer["Welcome.RoleIntro", Model.RoleName]
        @if (Model.MainDay is not null)
        {
            <br />
            <text>@Localizer["Welcome.Countdown", Model.MainDay?.ToString("dddd, d MMMM yyyy") ?? "", venue]</text>
        }
    </p>

    <div style="text-align:left;max-width:640px;margin:0 auto;">
        <h3 style="color:var(--el-darkblue);margin:18px 0 8px;">@Localizer["Welcome.WhatHeading"]</h3>
        <p>@Localizer["Welcome.WhatBody", Model.EventCode]</p>

        <h3 style="color:var(--el-darkblue);margin:18px 0 8px;">@Localizer["Welcome.WhyHeading"]</h3>
        <p>@Localizer["Welcome.WhyBody", Model.EventCode]</p>

        <h3 style="color:var(--el-darkblue);margin:18px 0 8px;">@Localizer["Welcome.RightAwayHeading"]</h3>
        <ul style="line-height:1.8;">
            <li>&#9989; @Localizer["Welcome.RightAwayTasks"]</li>
            <li>&#127968; @Localizer["Welcome.RightAwayHotel"]</li>
            <li>&#127863; @Localizer["Welcome.RightAwayDinner"]</li>
            <li>&#128083; @Localizer["Welcome.RightAwayPolo"]</li>
        </ul>

        <p style="margin-top:18px;">
            @Localizer["Welcome.Questions"]
            <a href="mailto:info@expertslive.dk">info@expertslive.dk</a>.
        </p>

        <p style="font-size:14px;color:#6b7280;">
            @Localizer["Welcome.SignOff"]<br/>
            <strong>@Localizer["Welcome.Team"]</strong>
        </p>
    </div>

    <form method="post" asp-page-handler="Continue" style="margin-top:28px;">
        <button type="submit" style="padding:12px 28px;font-size:16px;">
            @Localizer["Welcome.Continue"]
        </button>
    </form>

    <p style="font-size:12px;color:#8a8f9c;margin-top:14px;">
        @Localizer["Welcome.OnceNote"]
    </p>
</div>
