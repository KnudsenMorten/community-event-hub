@page
@using CommunityHub.Core.Domain
@model CommunityHub.Pages.Attendee.MyPlanModel
@{
    ViewData["Title"] = Localizer["Plan.Title"].Value;
}

<style>
    /* Mobile-first: single-column cards, full-width at ~360px. */
    .mp-intro { color:#4a5160; font-size:14px; margin:0 0 16px; line-height:1.5; }
    .mp-sec-h { font-size:16px; color:#1D3380; margin:18px 0 10px; }
    .mp-card { border:1px solid #e4e7ee; border-radius:9px; padding:12px 14px; background:#fff; margin:0 0 10px; }
    .mp-card h3 { margin:0 0 6px; font-size:15.5px; line-height:1.3; color:#1D3380; }
    .mp-card h3 a { color:#1D3380; text-decoration:none; }
    .mp-card h3 a:hover, .mp-card h3 a:focus { text-decoration:underline; }
    .mp-tags { display:flex; flex-wrap:wrap; gap:6px; margin:0 0 6px; }
    .mp-tag { font-size:11.5px; font-weight:600; padding:3px 9px; border-radius:999px; background:#eef1f7; color:#344; white-space:nowrap; }
    .mp-tag.type-mc { background:#ece6fb; color:#4527a0; }
    .mp-tag.type-sponsor { background:#fdeede; color:#8a4b00; }
    .mp-when { font-size:12.5px; color:#5a6270; margin:0 0 4px; }
    .mp-tba { font-size:12.5px; color:#8a4b00; font-style:italic; margin:0 0 4px; }
    .mp-spk { font-size:13px; color:#24292f; margin:0 0 8px; }
    .mp-spk .lbl { color:#6a7280; }
    .mp-row-actions { display:flex; flex-wrap:wrap; gap:8px; align-items:center; }
    .mp-row-actions form { margin:0; }
    .mp-btn-save { background:var(--el-blue,#008BD2); color:#fff; border:0; padding:7px 14px; border-radius:7px; font-size:13px; font-weight:600; cursor:pointer; }
    .mp-btn-remove { background:#fbe9e7; color:#8a2a1f; border:1px solid #f3c4bd; padding:7px 14px; border-radius:7px; font-size:13px; font-weight:600; cursor:pointer; }
    .mp-saved-flag { font-size:12.5px; font-weight:700; color:#1e7a34; white-space:nowrap; }
    .mp-empty { color:#6e7681; font-size:13.5px; font-style:italic; margin:6px 0 14px; }
    .mp-count { font-size:13px; color:#4a5160; margin:0 0 8px; }
    .mp-detail-link { font-size:13px; font-weight:600; color:var(--el-blue,#008BD2); text-decoration:none; }
    .mp-detail-link:hover, .mp-detail-link:focus { text-decoration:underline; }
    .mp-cal { border:1px solid #cfe6f5; background:#f3fafe; border-radius:9px; padding:12px 14px; margin:8px 0 4px; }
    .mp-cal h3 { margin:0 0 6px; font-size:15px; color:#1D3380; }
    .mp-cal p { margin:0 0 10px; font-size:13px; color:#4a5160; line-height:1.5; }
    .mp-cal-btn { display:inline-block; background:var(--el-blue,#008BD2); color:#fff; padding:8px 16px; border-radius:7px; font-size:13.5px; font-weight:600; text-decoration:none; }
    .mp-cal-btn:hover, .mp-cal-btn:focus { text-decoration:underline; }
    .mp-cal-none { font-size:13px; color:#6e7681; font-style:italic; margin:0; }
</style>

@functions {
    static string TypeClass(SessionType t) => t == SessionType.MasterClass ? "type-mc"
        : t == SessionType.TechnicalSession ? "type-sponsor" : "";
    static string TypeLabel(SessionType t) => CommunityHub.Pages.Sessions.IndexModel.Display(t);
}

<div class="card">
    <h2>@Localizer["Plan.Title"]</h2>
    <p class="mp-intro">@Localizer["Plan.Intro"]</p>

    @* ---- The saved plan ---------------------------------------------------- *@
    <h3 class="mp-sec-h">@Localizer["Plan.MyPlanHeading"]</h3>
    @if (Model.Plan.IsEmpty)
    {
        <p class="mp-empty" role="status">@Localizer["Plan.Empty"]</p>
    }
    else
    {
        <p class="mp-count" role="status">@Localizer["Plan.SavedCount", Model.Plan.Sessions.Count]</p>
        @foreach (var s in Model.Plan.Sessions)
        {
            <div class="mp-card">
                <h3><a href="@s.DetailUrl">@s.Title</a></h3>
                <div class="mp-tags">
                    <span class="mp-tag @TypeClass(s.Type)">@TypeLabel(s.Type)</span>
                    @if (!string.IsNullOrWhiteSpace(s.Room))
                    {
                        <span class="mp-tag">@Localizer["Plan.RoomTag", s.Room!]</span>
                    }
                </div>
                @if (s.HasTime)
                {
                    <div class="mp-when">@s.StartsAt!.Value.ToLocalTime().ToString("ddd dd MMM, HH:mm")@(s.EndsAt is not null ? $"–{s.EndsAt.Value.ToLocalTime():HH:mm}" : "")</div>
                }
                else
                {
                    <div class="mp-tba">@Localizer["Plan.TimeTba"]</div>
                }
                @if (!string.IsNullOrWhiteSpace(s.Speakers))
                {
                    <div class="mp-spk"><span class="lbl">@Localizer["Plan.With"]</span> @s.Speakers</div>
                }
                <div class="mp-row-actions">
                    <a class="mp-detail-link" href="@s.DetailUrl">@Localizer["Plan.Details"]</a>
                    <form method="post" asp-page-handler="Remove" asp-route-sessionId="@s.SessionId">
                        <button type="submit" class="mp-btn-remove">@Localizer["Plan.Remove"]</button>
                    </form>
                </div>
            </div>
        }
    }

    @* ---- Add the whole plan to a calendar ---------------------------------- *@
    @if (!Model.Plan.IsEmpty)
    {
        <div class="mp-cal">
            <h3>@Localizer["Plan.IcsHeading"]</h3>
            <p>@Localizer["Plan.IcsHelp"]</p>
            @if (Model.HasScheduled)
            {
                <a class="mp-cal-btn" asp-page-handler="Ics"
                   aria-label="@Localizer["Plan.IcsDownloadAria"]">@Localizer["Plan.IcsDownload"]</a>
            }
            else
            {
                <p class="mp-cal-none" role="status">@Localizer["Plan.IcsNoneScheduled"]</p>
            }
        </div>
    }

    @* ---- Browse + add ------------------------------------------------------ *@
    <h3 class="mp-sec-h">@Localizer["Plan.BrowseHeading"]</h3>
    @if (Model.Browse is null || Model.Browse.Sessions.Count == 0)
    {
        <p class="mp-empty">@Localizer["Plan.NothingToBrowse"]</p>
    }
    else
    {
        <p class="mp-intro">@Localizer["Plan.BrowseHelp"]</p>
        @foreach (var s in Model.Browse.Sessions)
        {
            var isSaved = Model.SavedIds.Contains(s.Id);
            <div class="mp-card">
                <h3><a href="/Sessions/@s.Id">@s.Title</a></h3>
                <div class="mp-tags">
                    <span class="mp-tag @TypeClass(s.Type)">@TypeLabel(s.Type)</span>
                    @if (!string.IsNullOrWhiteSpace(s.Room))
                    {
                        <span class="mp-tag">@Localizer["Plan.RoomTag", s.Room!]</span>
                    }
                </div>
                @if (s.StartsAt is not null)
                {
                    <div class="mp-when">@s.StartsAt.Value.ToLocalTime().ToString("ddd dd MMM, HH:mm")</div>
                }
                <div class="mp-row-actions">
                    @if (isSaved)
                    {
                        <span class="mp-saved-flag" aria-hidden="true">@Localizer["Plan.SavedFlag"]</span>
                    }
                    <form method="post" asp-page-handler="Toggle" asp-route-sessionId="@s.Id">
                        @if (isSaved)
                        {
                            <button type="submit" class="mp-btn-remove"
                                    aria-label="@Localizer["Plan.RemoveAria", s.Title]">@Localizer["Plan.Remove"]</button>
                        }
                        else
                        {
                            <button type="submit" class="mp-btn-save"
                                    aria-label="@Localizer["Plan.SaveAria", s.Title]">@Localizer["Plan.Save"]</button>
                        }
                    </form>
                </div>
            </div>
        }
    }

    <p style="margin-top:16px;"><a asp-page="/Index">@Localizer["Common.BackToHub"]</a></p>
</div>
