@page
@using CommunityHub.Core.Domain
@model CommunityHub.Pages.Attendee.IndexModel
@{
    ViewData["Title"] = Localizer["Attendee.Title"].Value;
}

<div class="card">
    <h2>@Localizer["Attendee.Title"]</h2>

    @if (Model.Record is null)
    {
        <p>@Localizer["Attendee.NoRecord"]</p>
    }
    else
    {
        <p>@Localizer["Attendee.Ticket"] <strong>@Model.Record.TicketStatus</strong>
           @if (!string.IsNullOrEmpty(Model.Record.TicketClassName))
           {
               <span>(@Model.Record.TicketClassName)</span>
           }
        </p>

        @if (Model.Record.BookingStatus == MasterClassBookingStatus.Booked)
        {
            <p class="info">@Localizer["Attendee.Reserved", Model.Record.MasterClassName ?? ""]</p>
        }
        else if (Model.Record.BookingStatus == MasterClassBookingStatus.MultipleBookings)
        {
            <p class="error">@Localizer["Attendee.Multiple", Model.Record.MasterClassName ?? ""]</p>
        }
        else
        {
            <p class="error">@Localizer["Attendee.NotReserved"]</p>
        }

        <p><a href="@Model.BookingUrl" target="_blank" rel="noopener">
            @Localizer["Attendee.ManageBooking"]</a></p>
    }
    <p><a asp-page="/Index">@Localizer["Common.BackToHub"]</a></p>
</div>
