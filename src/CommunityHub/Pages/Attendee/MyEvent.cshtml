@page
@using CommunityHub.Core.Attendees
@model CommunityHub.Pages.Attendee.MyEventModel
@{
    ViewData["Title"] = Localizer["MyEvent.Title"].Value;
    var d = Model.Dashboard;
}

<style>
    /* Mobile-first: single column, full-width tap targets at ~360px. */
    .me-hero { background: linear-gradient(135deg, var(--el-blue, #0a3d62), #114b7a); color: #fff; }
    .me-hero h2 { margin: 0 0 4px; color: #fff; }
    .me-hero .sub { opacity: .9; font-size: 14px; }
    .me-count { display: flex; align-items: baseline; gap: 8px; margin-top: 12px; }
    .me-count .n { font-size: 40px; font-weight: 800; line-height: 1; }
    .me-count .l { font-size: 14px; opacity: .9; }
    .me-live { display: inline-block; background: #0a6; color: #fff; border-radius: 12px;
               padding: 2px 10px; font-size: 12px; font-weight: 700; margin-top: 10px; }
    .me-fact { display: flex; justify-content: space-between; gap: 12px; padding: 8px 0;
               border-bottom: 1px solid #eef0f4; font-size: 14px; }
    .me-fact:last-child { border-bottom: 0; }
    .me-fact .k { color: #6b7280; }
    .me-fact .v { font-weight: 600; text-align: right; }
    .me-status { padding: 10px 12px; border-radius: 8px; font-weight: 600; }
    .me-status.ok     { background: #e7f7ee; color: #0a6; }
    .me-status.action { background: #fdecea; color: #c0392b; }
    .me-status.info   { background: #eef2f7; color: #334; }
    .btn-checkin { display: block; width: 100%; box-sizing: border-box; text-align: center;
                   background: #0a6; color: #fff; border: 0; border-radius: 8px;
                   padding: 14px 16px; font-size: 17px; font-weight: 700; cursor: pointer; }
    .me-checkedin { display: flex; align-items: center; gap: 8px; background: #e7f7ee;
                    color: #0a6; border-radius: 8px; padding: 12px; font-weight: 700; }
    .me-muted { color: #6b7280; font-size: 13px; }
    .me-toast { background: #0a6; color: #fff; border-radius: 8px; padding: 10px 12px;
                font-weight: 600; margin-bottom: 12px; }

    /* Personal schedule / my sessions (§20 Attendee My-event). Mobile-first cards. */
    .me-ses { border: 1px solid #e5e7eb; border-radius: 8px; padding: 12px; margin-bottom: 10px; }
    .me-ses:last-child { margin-bottom: 0; }
    .me-ses.mine { border-color: #0a6; background: #f3fcf7; }
    .me-ses .t { font-weight: 700; font-size: 15px; }
    .me-ses .when { color: #334; font-size: 13px; margin-top: 2px; }
    .me-ses .meta { color: #6b7280; font-size: 13px; margin-top: 2px; }
    .me-ses .mine-tag { display: inline-block; background: #0a6; color: #fff; border-radius: 10px;
                        padding: 1px 8px; font-size: 11px; font-weight: 700; margin-left: 6px; vertical-align: middle; }
    .me-ses .links { margin-top: 8px; display: flex; flex-wrap: wrap; gap: 8px 14px; font-size: 14px; }
    .me-ses .links a { white-space: nowrap; }
    /* Disabled ask/evaluate affordance shown before the session's token is minted. */
    .me-ase-soon { white-space: nowrap; color: #9ca3af; font-style: italic; cursor: default; }
    .me-quick { display: flex; flex-wrap: wrap; gap: 8px; }
    .me-quick a { flex: 1 1 45%; box-sizing: border-box; text-align: center; text-decoration: none;
                  background: #eef2f7; color: #1f2937; border-radius: 8px; padding: 12px 10px; font-weight: 600; }
    .me-quick a:hover, .me-quick a:focus { background: #e0e7ef; }

    /* Desktop: keep the same single readable column; widen facts a touch. */
    @@media (min-width: 640px) {
        .me-count .n { font-size: 52px; }
        .me-quick a { flex: 1 1 30%; }
    }
</style>

@if (Model.JustCheckedIn)
{
    <div class="me-toast" role="status">&#10003; @Localizer["MyEvent.CheckedInToast"]</div>
}

<div class="card me-hero">
    <h2>@d.EventDisplayName</h2>
    <div class="sub">@d.CommunityName @(string.IsNullOrEmpty(d.VenueName) ? "" : "· " + d.VenueName)</div>

    @if (d.IsEventLive)
    {
        <div class="me-live">&#9679; @Localizer["MyEvent.HappeningNow"]</div>
    }
    else if (d.DaysUntilStart > 0)
    {
        <div class="me-count">
            <span class="n">@d.DaysUntilStart</span>
            <span class="l">day@(d.DaysUntilStart == 1 ? "" : "s") to go</span>
        </div>
    }
    else
    {
        <div class="me-count"><span class="l">@Localizer["MyEvent.SeeYouNextTime"]</span></div>
    }
</div>

<div class="card">
    <h2>@Localizer["MyEvent.YourMasterClass"]</h2>
    <div class="me-status @(d.AgendaTone == AgendaStatusTone.Ok ? "ok" : d.AgendaTone == AgendaStatusTone.Action ? "action" : "info")">
        @d.AgendaHeadline
    </div>
    @if (!string.IsNullOrEmpty(d.MasterClassName))
    {
        <p style="margin:10px 0 0;">@Localizer["MyEvent.Session"]: <strong>@d.MasterClassName</strong></p>
    }
    <p style="margin-top:12px;">
        <a href="@Model.BookingUrl" target="_blank" rel="noopener">@Localizer["MyEvent.ManageBooking"] &rarr;</a>
    </p>
</div>

@{
    var sched = Model.Schedule;
    Func<CommunityHub.Core.Attendees.MyEventSessionRow, Microsoft.AspNetCore.Html.IHtmlContent> sessionCard = row =>
    {
        var html = new System.Text.StringBuilder();
        html.Append($"<div class=\"me-ses{(row.IsMine ? " mine" : "")}\">");
        html.Append("<div class=\"t\">");
        html.Append(System.Net.WebUtility.HtmlEncode(row.Title));
        if (row.IsMine)
        {
            html.Append($"<span class=\"mine-tag\">{System.Net.WebUtility.HtmlEncode(Localizer["MyEvent.MineTag"].Value)}</span>");
        }
        html.Append("</div>");
        if (row.StartsAt is not null)
        {
            var when = row.StartsAt.Value.ToLocalTime().ToString("ddd dd MMM HH:mm");
            if (row.EndsAt is not null) { when += " – " + row.EndsAt.Value.ToLocalTime().ToString("HH:mm"); }
            html.Append($"<div class=\"when\">{System.Net.WebUtility.HtmlEncode(when)}</div>");
        }
        var meta = new List<string>();
        if (!string.IsNullOrWhiteSpace(row.Speakers)) { meta.Add(row.Speakers); }
        if (!string.IsNullOrWhiteSpace(row.Room)) { meta.Add(row.Room); }
        if (meta.Count > 0)
        {
            html.Append($"<div class=\"meta\">{System.Net.WebUtility.HtmlEncode(string.Join(" · ", meta))}</div>");
        }
        html.Append("<div class=\"links\">");
        html.Append($"<a href=\"{row.DetailUrl}\">{System.Net.WebUtility.HtmlEncode(Localizer["MyEvent.SessionDetails"].Value)} &rarr;</a>");
        if (row.AskEvaluateAvailable)
        {
            html.Append($"<a href=\"{row.AskUrl}\">{System.Net.WebUtility.HtmlEncode(Localizer["MyEvent.AskQuestion"].Value)}</a>");
            html.Append($"<a href=\"{row.EvaluateUrl}\">{System.Net.WebUtility.HtmlEncode(Localizer["MyEvent.Evaluate"].Value)}</a>");
        }
        else
        {
            // No ask/evaluate token yet (minted at the session). Show a disabled
            // affordance + hint instead of nothing, so the attendee knows the
            // ask/rate action will appear during the session (bug-fix §20).
            html.Append($"<span class=\"me-ase-soon\" aria-disabled=\"true\" title=\"{System.Net.WebUtility.HtmlEncode(Localizer["MyEvent.AskEvaluateNotOpenHint"].Value)}\">{System.Net.WebUtility.HtmlEncode(Localizer["MyEvent.AskEvaluateNotOpen"].Value)}</span>");
        }
        html.Append("</div></div>");
        return new Microsoft.AspNetCore.Html.HtmlString(html.ToString());
    };
}

<div class="card">
    <h2>@Localizer["MyEvent.MySessions"]</h2>
    @if (sched.HasNoMySessions)
    {
        <p class="me-muted" style="margin:0;">@Localizer["MyEvent.NoMySessions"]</p>
    }
    else
    {
        foreach (var row in sched.MySessions)
        {
            @sessionCard(row)
        }
    }
</div>

<div class="card">
    <h2>@Localizer["MyEvent.AskAndEvaluate"]</h2>
    <ul style="margin:0; padding-left:18px; font-size:14px;">
        <li>@Localizer["MyEvent.AskAndEvaluateHelp"]</li>
    </ul>
</div>

<div class="card">
    <h2>@Localizer["MyEvent.QuickLinks"]</h2>
    <nav class="me-quick" aria-label="@Localizer["MyEvent.QuickLinks"]">
        @* Attendee-relevant links first — always shown. *@
        <a asp-page="/Sessions">&#128197; @Localizer["MyEvent.FullAgenda"]</a>
        <a asp-page="/Attendee/MyPlan">&#11088; @Localizer["MyEvent.MyPlan"]</a>
        @* Crew-only self-service forms — render ONLY when the current role is
           actually eligible (attendees are not), so we never deep-link a role into
           a form it would be denied on (bug-fix §20 Attendee My-event). *@
        @if (Model.ShowHotelLink)
        {
            <a asp-page="/Forms/Hotel">&#127976; @Localizer["MyEvent.Hotel"]</a>
        }
        @if (Model.ShowSwagLink)
        {
            <a asp-page="/Forms/Swag">&#127873; @Localizer["MyEvent.Swag"]</a>
        }
        @if (Model.ShowLunchLink)
        {
            <a asp-page="/Forms/Lunch">&#127869; @Localizer["MyEvent.Lunch"]</a>
        }
    </nav>
    <p class="me-muted" style="margin:10px 0 0;">@Localizer["MyEvent.QuickLinksHelp"]</p>
</div>

<div class="card">
    <h2>@Localizer["MyEvent.Agenda"]</h2>
    @if (sched.AgendaIsEmpty)
    {
        <p class="me-muted" style="margin:0;">@Localizer["MyEvent.NoAgenda"]</p>
    }
    else
    {
        foreach (var row in sched.Agenda)
        {
            @sessionCard(row)
        }
    }
</div>

<div class="card">
    <h2>@Localizer["MyEvent.PracticalInfo"]</h2>
    @if (d.PreDayDate is not null)
    {
        <div class="me-fact"><span class="k">@Localizer["MyEvent.PreDay"]</span><span class="v">@d.PreDayDate.Value.ToString("ddd dd MMM yyyy")</span></div>
    }
    <div class="me-fact"><span class="k">@Localizer["MyEvent.Conference"]</span><span class="v">@d.StartDate.ToString("ddd dd MMM") &ndash; @d.EndDate.ToString("ddd dd MMM yyyy")</span></div>
    @if (!string.IsNullOrEmpty(d.VenueName))
    {
        <div class="me-fact">
            <span class="k">@Localizer["MyEvent.Venue"]</span>
            <span class="v">
                <a href="https://www.google.com/maps/search/?api=1&query=@(Uri.EscapeDataString(d.VenueName))" target="_blank" rel="noopener">@d.VenueName &#128205;</a>
            </span>
        </div>
    }
</div>

<div class="card">
    <h2>@Localizer["MyEvent.CheckIn"]</h2>
    @if (d.IsCheckedIn)
    {
        <div class="me-checkedin">
            <span>&#10003;</span>
            <span>You checked in@(d.CheckedInAt is not null ? " at " + d.CheckedInAt.Value.ToLocalTime().ToString("HH:mm") : "").</span>
        </div>
    }
    else if (d.CanCheckIn)
    {
        <p class="me-muted" style="margin-top:0;">@Localizer["MyEvent.TapWhenArrive"]</p>
        <form method="post" asp-page-handler="CheckIn">
            <button type="submit" class="btn-checkin">@Localizer["MyEvent.ImHere"] &#128075;</button>
        </form>
    }
    else
    {
        <p class="me-muted" style="margin:0;">@d.CheckInUnavailableReason</p>
    }
</div>

@* Unified "what's still needed" checklist (Top-8 #7) — same shared component as
   the Hub home + Tasks page, so My-event surfaces the one consistent view. *@
@await Html.PartialAsync("Shared/_ChecklistCard", Model.Checklist)

<div class="card">
    <p><a asp-page="/Index">&larr; @Localizer["Common.BackToHub"]</a></p>
</div>
