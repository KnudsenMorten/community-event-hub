@page
@model CommunityHub.Pages.ProfileModel
@{
    ViewData["Title"] = "My Hub Profile";
}

<div class="card">
    <h1>My Hub Profile</h1>

    @if (!string.IsNullOrEmpty(Model.Form.Message))
    {
        <p class="@(Model.Form.Saved ? "info" : "error")" role="@(Model.Form.Saved ? "status" : "alert")">@Model.Form.Message</p>
    }
    @if (!string.IsNullOrEmpty(Model.Form.SpeakerNotice))
    {
        <p class="info" role="status">@Model.Form.SpeakerNotice</p>
    }

    <p style="background:#eef6ff;padding:10px 14px;border-radius:6px;font-size:14px;">
        Update the basics other crew and the organizers see. Your
        <strong>email</strong> is your sign-in identity and your
        <strong>role</strong> is set by the organizers &mdash; contact them if
        either needs to change.
    </p>

    <form method="post">
        @* The profile fields are the SAME partial the inline wizard step renders. *@
        <partial name="_ProfileFields" model="Model.Form" />

        <button type="submit">Save</button>
    </form>

    <p><a asp-page="/Index">Back to hub</a></p>
</div>
