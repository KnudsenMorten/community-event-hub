@page
@model CommunityHub.Pages.Login.MagicModel
@{
    ViewData["Title"] = Localizer["Login.Title"].Value;
}

<div class="card">
    <h2>@Localizer["Login.Title"]</h2>
    @if (!string.IsNullOrEmpty(Model.Error))
    {
        <p class="error" role="alert">@Model.Error</p>
        <p><a asp-page="/Login">@Localizer["Login.GoToEmailPin"]</a></p>
    }
</div>
