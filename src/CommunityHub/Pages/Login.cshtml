@page
@model CommunityHub.Pages.LoginModel
@{
    ViewData["Title"] = Localizer["Login.Title"].Value;
    ViewData["HidePublicNav"] = true;   // bare sign-in page — no public event nav bar
}

<div class="card">
    <h2>@Localizer["Login.Title"]</h2>

    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <p class="@(Model.IsError ? "error" : "info")" role="@(Model.IsError ? "alert" : "status")">@Model.Message</p>
    }

    @if (Model.Step == "email")
    {
        <!-- Step 1: request a PIN by email (email may be prestaged from ?email=) -->
        <form method="post" asp-page-handler="RequestPin">
            @if (!string.IsNullOrEmpty(Model.ReturnUrl))
            {
                <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
            }
            <label for="Email">@Localizer["Login.YourEmail"]</label>
            <input type="email" id="Email" name="Email" value="@Model.Email"
                   required autocomplete="email" />
            <button type="submit">@Localizer["Login.SendCode"]</button>
        </form>
    }
    else
    {
        <!-- Step 2: enter the PIN -->
        <form method="post" asp-page-handler="VerifyPin" style="margin-bottom:14px;">
            <input type="hidden" name="Email" value="@Model.Email" />
            <input type="hidden" name="Step" value="pin" />
            @if (!string.IsNullOrEmpty(Model.ReturnUrl))
            {
                <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
            }
            <label for="Pin">@Localizer["Login.EnterCode"]</label>
            <input type="text" id="Pin" name="Pin" inputmode="numeric"
                   pattern="[0-9]{6}" maxlength="6" required autocomplete="one-time-code" />

            <label for="RememberFor" style="display:block;margin-top:12px;font-size:13px;color:#4a5160;">@Localizer["Login.StaySignedIn"]</label>
            <select id="RememberFor" name="RememberFor" aria-describedby="RememberForHelp" style="width:100%;padding:8px 10px;border:1px solid #c4c8d4;border-radius:6px;font-size:14px;margin-top:4px;">
                <option value="day">@Localizer["Login.RememberDay"]</option>
                <option value="week" selected>@Localizer["Login.RememberWeek"]</option>
                <option value="month">@Localizer["Login.RememberMonth"]</option>
                <option value="persistent">@Localizer["Login.RememberPersistent"]</option>
            </select>
            <p id="RememberForHelp" style="font-size:11.5px;color:#5a6170;margin:4px 0 12px 0;">
                @Localizer["Login.RememberHelp"]
            </p>

            <button type="submit">@Localizer["Login.SignInButton"]</button>
        </form>
        <form method="post" asp-page-handler="RequestPin" style="margin-top:14px;">
            <input type="hidden" name="Email" value="@Model.Email" />
            @if (!string.IsNullOrEmpty(Model.ReturnUrl))
            {
                <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
            }
            <button type="submit" class="secondary">@Localizer["Login.SendNewCode"]</button>
        </form>
    }
</div>
