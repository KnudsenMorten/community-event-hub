@page
@model CommunityHub.Pages.ResourcesModel
@{
    ViewData["Title"] = "Resources";
}

<div class="card">
    <h2>Resources</h2>

    @if (!string.IsNullOrWhiteSpace(Model.Resources.Intro))
    {
        <p style="font-size:15px;">@Model.Resources.Intro</p>
    }

    @if (Model.Resources.IsEmpty)
    {
        <p class="info" style="background:#eef6ff;padding:10px 14px;border-radius:6px;">
            There are no shared resources here yet. The organizers will add
            practical info, links and downloads closer to the event &mdash;
            check back soon.
        </p>
    }
    else
    {
        @foreach (var sec in Model.Resources.Sections)
        {
            <section style="margin:18px 0;">
                @if (!string.IsNullOrWhiteSpace(sec.Title))
                {
                    <h3 style="margin:0 0 4px;font-size:17px;color:var(--el-darkblue);">@sec.Title</h3>
                }
                @if (!string.IsNullOrWhiteSpace(sec.Description))
                {
                    <p style="margin:0 0 8px;font-size:14px;color:#4b5563;">@sec.Description</p>
                }
                @if (sec.Links.Count > 0)
                {
                    <ul style="list-style:none;padding:0;margin:0;">
                        @foreach (var link in sec.Links)
                        {
                            <li style="margin:6px 0;">
                                <a class="task-link-btn" href="@link.Url" target="_blank" rel="noopener">
                                    @(link.IsDownload ? "⬇ " : "")@link.Label
                                </a>
                                @if (!string.IsNullOrWhiteSpace(link.Note))
                                {
                                    <span style="display:block;font-size:13px;color:#6b7280;margin:2px 0 0;">@link.Note</span>
                                }
                            </li>
                        }
                    </ul>
                }
            </section>
        }
    }

    <p><a asp-page="/Index">Back to hub</a></p>
</div>
