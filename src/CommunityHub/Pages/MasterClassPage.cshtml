@page "/MasterClassPage/{sessionId:int}"
@model CommunityHub.Pages.MasterClassPageModel
@{
    ViewData["Title"] = Model.View?.Title ?? "Master Class";
    string Stamp(DateTimeOffset at) => at.UtcDateTime.ToString("d MMM yyyy HH:mm 'UTC'");
}

<div style="max-width:760px;margin:0 auto;padding:16px;">
    @if (Model.NotFoundState)
    {
        <h1>Master Class not found</h1>
        <p>This Master Class page is not available. The link may be out of date.</p>
    }
    else if (Model.AccessDenied)
    {
        <h1>Master Class</h1>
        <p role="status">
            This Master Class page is only available to attendees with a confirmed seat,
            and to the Master Class speakers. If you have a confirmed seat, please open the
            page from the link in your confirmation email.
        </p>
    }
    else if (Model.View is not null)
    {
        <h1 style="margin:0 0 4px;">@Model.View.Title</h1>
        @if (Model.View.Speakers.Count > 0)
        {
            <p style="color:#555;margin:0 0 4px;">Presented by @string.Join(", ", Model.View.Speakers)</p>
        }
        @if (!string.IsNullOrWhiteSpace(Model.View.Room))
        {
            <p style="color:#555;margin:0 0 12px;">Room: @Model.View.Room</p>
        }

        @if (!string.IsNullOrEmpty(Model.Message))
        {
            <p role="status" style="background:#e6f4ea;border:1px solid #1c6b35;border-radius:6px;padding:10px 12px;">@Model.Message</p>
        }
        @if (!string.IsNullOrEmpty(Model.Error))
        {
            <p role="alert" style="background:#fdecea;border:1px solid #b3261e;border-radius:6px;padding:10px 12px;">@Model.Error</p>
        }

        <!-- ============ Orientation: what is a Master Class (standard copy) ============ -->
        @* Consolidated here (operator 2026-06-24): the "Master Class info & what to bring"
           details now live ON this Q&A page so attendees find everything in one place. *@
        <section aria-labelledby="mc-about-h" style="margin:18px 0;">
            <h2 id="mc-about-h" style="font-size:1.25rem;">What is an Experts Live Master Class?</h2>
            <p>An Experts Live Master Class is a full-day, in-person learning event where people with a shared interest in a topic come together to learn from experienced professionals—mainly Microsoft MVPs and sometimes Microsoft itself.</p>
            <p>There isn't a strict definition of what makes up a master class. Our main goal is to create a room of peers and provide honest, practical insight — the "no filter" version of what works and what doesn't.</p>
            <p><strong>Key points:</strong></p>
            <ul style="margin:0 0 10px 18px;line-height:1.6;">
                <li>Open dialogue is encouraged — you can ask questions and challenge features.</li>
                <li>Speakers choose their own format.</li>
                <li>Some sessions include hands-on labs; others mix presentations and discussions.</li>
                <li>It's not meant to feel like traditional school despite the word "class."</li>
                <li>Asking questions is strongly encouraged, since much of the value comes from interaction.</li>
            </ul>
            <h3 style="font-size:1.05rem;margin:14px 0 4px;">Do I need to bring my laptop?</h3>
            <p>Many attendees bring a laptop to take notes and follow along. Your master class may require you to bring your laptop as outlined in the "Before you arrive" notes below.</p>
            <h3 style="font-size:1.05rem;margin:14px 0 4px;">Can I charge my laptop during the master class?</h3>
            <p>Due to Danish fire safety regulations, we cannot run charging cables along the classroom table rows. Each room has a charging table (up to 15 devices at once) for laptops or phones. For the best start, please arrive with your laptop fully charged.</p>
        </section>

        <!-- ============ Before you arrive / what to bring (speaker logistics) ============ -->
        <section aria-labelledby="mc-bring-h" style="margin:18px 0;">
            <h2 id="mc-bring-h" style="font-size:1.25rem;">Before you arrive — what to bring</h2>
            @if (string.IsNullOrWhiteSpace(Model.View.LogisticsText))
            {
                <p style="color:#666;">The speakers haven't posted specifics for this class yet — check back soon.</p>
            }
            else
            {
                <div style="white-space:pre-wrap;line-height:1.55;">@Model.View.LogisticsText</div>
                @if (Model.View.LogisticsUpdatedAt is { } lu)
                {
                    <p style="color:#888;font-size:.85rem;margin-top:8px;">Last updated @Stamp(lu)</p>
                }
            }
        </section>

        <!-- ============ Prep content ============ -->
        <section aria-labelledby="prep-h" style="margin:18px 0;">
            <h2 id="prep-h" style="font-size:1.25rem;">How to prepare</h2>
            @if (string.IsNullOrWhiteSpace(Model.View.PrepContent))
            {
                <p style="color:#666;">The speakers have not posted preparation notes yet — check back soon.</p>
            }
            else
            {
                <div style="white-space:pre-wrap;line-height:1.55;">@Model.View.PrepContent</div>
                @if (Model.View.PrepUpdatedAt is { } pu)
                {
                    <p style="color:#888;font-size:.85rem;margin-top:8px;">Last updated @Stamp(pu)</p>
                }
            }
        </section>

        <!-- ============ 1:1 private questions (attendee only) ============ -->
        @if (Model.IsAttendeeViewer)
        {
            <section aria-labelledby="ask-h" style="margin:18px 0;">
                <h2 id="ask-h" style="font-size:1.25rem;">Ask the speakers (private)</h2>
                <p style="color:#666;margin:0 0 8px;">Only the Master Class speakers see this — other attendees do not.</p>
                <form method="post" asp-page-handler="Ask" asp-route-sessionId="@Model.SessionId" asp-route-t="@Model.Token">
                    <label for="qtext" style="display:block;font-weight:600;margin-bottom:4px;">Your question</label>
                    <textarea id="qtext" name="QuestionText" rows="3" required maxlength="2000"
                              style="width:100%;box-sizing:border-box;padding:8px;border:1px solid #ccc;border-radius:6px;"></textarea>
                    <button type="submit" style="margin-top:8px;background:#1c6b35;color:#fff;border:0;border-radius:6px;padding:10px 18px;font-weight:600;">Send question</button>
                </form>

                @if (Model.MyQuestions.Count > 0)
                {
                    <h3 style="font-size:1.05rem;margin:16px 0 6px;">Your questions</h3>
                    <ul style="list-style:none;padding:0;margin:0;">
                        @foreach (var q in Model.MyQuestions)
                        {
                            <li style="border:1px solid #e3e3e3;border-radius:8px;padding:10px 12px;margin-bottom:8px;">
                                <div style="white-space:pre-wrap;">@q.QuestionText</div>
                                @if (!string.IsNullOrWhiteSpace(q.ResponseText))
                                {
                                    <div style="margin-top:8px;padding-top:8px;border-top:1px dashed #ccc;">
                                        <strong>Speaker reply:</strong>
                                        <div style="white-space:pre-wrap;">@q.ResponseText</div>
                                    </div>
                                }
                                else
                                {
                                    <div style="margin-top:6px;color:#888;font-size:.85rem;">Awaiting a reply.</div>
                                }
                            </li>
                        }
                    </ul>
                }
            </section>
        }

        <!-- ============ Q&A comments (public within the MC) ============ -->
        <section aria-labelledby="qa-h" style="margin:18px 0;">
            <h2 id="qa-h" style="font-size:1.25rem;">Group Q&amp;A</h2>
            <p style="color:#666;margin:0 0 8px;">Visible to everyone in this Master Class.</p>

            <form method="post" asp-page-handler="Comment" asp-route-sessionId="@Model.SessionId" asp-route-t="@Model.Token">
                <label for="cbody" style="display:block;font-weight:600;margin-bottom:4px;">Add a comment</label>
                <textarea id="cbody" name="CommentBody" rows="2" required maxlength="2000"
                          style="width:100%;box-sizing:border-box;padding:8px;border:1px solid #ccc;border-radius:6px;"></textarea>
                <button type="submit" style="margin-top:8px;background:#34507a;color:#fff;border:0;border-radius:6px;padding:10px 18px;font-weight:600;">Post comment</button>
            </form>

            @if (Model.Comments.Count == 0)
            {
                <p style="color:#666;margin-top:12px;">No comments yet — start the conversation.</p>
            }
            else
            {
                <ul style="list-style:none;padding:0;margin:14px 0 0;">
                    @foreach (var c in Model.Comments)
                    {
                        <li style="border:1px solid #e3e3e3;border-radius:8px;padding:10px 12px;margin-bottom:8px;@(c.ParentCommentId is null ? "" : "margin-left:20px;")">
                            <div style="font-weight:600;">@c.AuthorDisplayName</div>
                            <div style="white-space:pre-wrap;">@c.Body</div>
                            <div style="color:#888;font-size:.8rem;margin-top:4px;">@Stamp(c.CreatedAt)</div>
                        </li>
                    }
                </ul>
            }
        </section>
    }
</div>
