@page
@model CommunityHub.Pages.Sponsor.ContactModel
@{
    ViewData["Title"] = "Contact";
    var mailto = $"mailto:{Model.LeadEmail}?subject=" + Uri.EscapeDataString($"[{Model.EditionCode}] Sponsor question");
}

@if (Model.AccessDenied)
{
    <div class="card">
        <h2>Contact the sponsor team</h2>
        <p class="error">This page is for sponsors only.</p>
        <p><a asp-page="/Index">Back to hub</a></p>
    </div>
    return;
}

<div class="card">
    <h2>Contact the sponsor team</h2>
    <p>Reach out for anything sponsor-related — booth setup, deliverables, billing, schedule, attendee bag content, anything that does not have its own task.</p>

    <h3 style="margin-top:18px;">Sponsor lead</h3>
    <p><strong>@Model.LeadName</strong> &mdash; <a href="@mailto" class="task-link-btn">Send email to @Model.LeadEmail</a></p>

    @if (!string.IsNullOrEmpty(Model.BookingsUrl))
    {
        <h3 style="margin-top:18px;">Request a Teams meeting</h3>
        <p>Pick a time that works for you. The slot is held automatically once you confirm.</p>
        <p><a href="@Model.BookingsUrl" target="_blank" rel="noopener noreferrer" class="task-link-btn" style="background:#5b5fc7;">Book a Teams meeting with @Model.LeadName</a></p>
    }
    else
    {
        <h3 style="margin-top:18px;">Request a Teams meeting</h3>
        <p>Email @Model.LeadEmail with two or three time slots that suit you — a Teams invite will come back the same day.</p>
    }
</div>
