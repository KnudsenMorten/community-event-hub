@page
@model CommunityHub.Pages.Sponsor.LeadsModel
@{
    ViewData["Title"] = "Your leads API";
}

<div class="card">
    <h2>Your leads API</h2>
    @if (Model.AccessDenied)
    {
        <p class="error">This area is for sponsor contacts (and organizers).</p>
        <p><a asp-page="/Index">Back to hub</a></p>
    }
    else if (Model.NoCompanyLink)
    {
        <p class="error">Your sponsor account is not yet linked to a company,
           so we cannot wire up your leads API. Please contact the organizers.</p>
        <p><a asp-page="/Index">Back to hub</a></p>
    }
    else
    {
        <p>Leads, inquiries, and booth-meeting requests captured at the
           event are exposed to you via a JSON / CSV API and via a
           pre-generated CSV drop. Both paths require your per-company
           API key.</p>
        <p><a asp-page="/Sponsor/Index">&larr; Back to Sponsor Engagement</a></p>
    }
</div>

@if (!Model.AccessDenied && !Model.NoCompanyLink)
{
    <div class="card" style="background:#f0fdf4;border-left:4px solid #16a34a;">
        <h2>Your access token (deterministic)</h2>
        @if (Model.DeterministicToken is null)
        {
            <p class="error">The deterministic-token global secret hasn't been configured for this environment yet. Ask the organizers to finish setup.</p>
        }
        else
        {
            <p>This token authenticates you to the leads endpoints. It's
               derived from your sponsor id + a global secret + a version
               counter, so it never disappears: if you misplace it, just
               revisit this page and copy it again. If it leaks, ask the
               organizers to <strong>bump the version</strong> &mdash; the
               old token immediately stops working and the new one shows
               up here.</p>
            <p style="margin-top:8px;">Current version: <strong>v@Model.TokenVersion</strong></p>
            <pre style="background:#fff;border:1px solid #c4c8d4;border-radius:6px;padding:10px 12px;overflow-x:auto;user-select:all;">@Model.DeterministicToken</pre>
            <p style="font-size:12.5px;color:#5a6170;margin:6px 0 0 0;">
                Use this as the <code>Authorization: Bearer ...</code> header in your scripts (samples further down).
            </p>
        }
    </div>

    <div class="card">
        <h2>Legacy issued API key</h2>
        <table style="width:100%;border-collapse:collapse;max-width:680px;">
            <tr style="border-bottom:1px solid #eee;"><td>Sponsor company id</td><td><code>@Model.SponsorCompanyId</code></td></tr>
            <tr style="border-bottom:1px solid #eee;"><td>Current key</td><td>@(Model.KeyPrefix is null ? "(not issued yet)" : Model.KeyPrefix + "...")</td></tr>
            <tr style="border-bottom:1px solid #eee;"><td>Issued</td><td>@(Model.IssuedAt?.ToString("u") ?? "-")</td></tr>
            <tr><td>Issued by</td><td>@(Model.IssuedByEmail ?? "-")</td></tr>
        </table>

        @if (Model.KeyPrefix is null)
        {
            <p style="margin-top:14px;background:#fff8e1;border-left:3px solid #f4b400;padding:10px 12px;border-radius:4px;">
                <strong>No API key has been issued for your company yet.</strong>
                Ask the organizer team to issue one &mdash; they hand it to
                you in person / over a secure channel. After that, paste it
                into the samples below.
            </p>
        }
        else
        {
            <p style="margin-top:14px;font-size:12.5px;color:#5a6170;">
                The hub stores only the SHA256 hash of your key &mdash; not
                even the organizer can retrieve the raw value. If you've
                lost your key, ask the organizer to <strong>regenerate</strong>
                (which revokes the previous one and hands you a fresh
                value).
            </p>
        }
    </div>

    <div class="card" style="background:#eef6ff;border-left:4px solid var(--el-darkblue);">
        <h2>Also available directly in Zoho Backstage</h2>
        <p>The hub's API serves the leads the organizer team has pulled in
           and screened (junk filtered out). You can always cross-check the
           raw capture directly in Zoho Backstage:</p>
        <p style="display:flex;gap:10px;flex-wrap:wrap;">
            <a class="task-link-btn" href="https://eldk27.expertslive.dk/#/exhibitor-dashboard/leads?lang=en" target="_blank" rel="noopener noreferrer">Open Zoho Backstage &mdash; Leads</a>
            <a class="task-link-btn" href="https://eldk27.expertslive.dk/#/exhibitor-dashboard/inquiries?lang=en" target="_blank" rel="noopener noreferrer">Open Zoho Backstage &mdash; Inquiries</a>
            <a class="task-link-btn" href="https://eldk27.expertslive.dk/#/exhibitor-dashboard/meetings?lang=en" target="_blank" rel="noopener noreferrer">Open Zoho Backstage &mdash; Meetings</a>
        </p>
    </div>

    <div class="card">
        <h2>Endpoints</h2>
        <p>All three accept your key in any of these forms (in priority order):</p>
        <ul style="margin-top:6px;">
            <li><strong><code>Authorization: Bearer &lt;key&gt;</code></strong> request header &mdash; the standard, works with curl / Postman / PowerShell out of the box.</li>
            <li><code>X-Sponsor-Api-Key: &lt;key&gt;</code> custom header &mdash; legacy.</li>
            <li><code>?key=&lt;key&gt;</code> query parameter &mdash; only for the browser direct-download URL; avoid in automation.</li>
        </ul>

        <table style="width:100%;border-collapse:collapse;margin-top:10px;">
            <tr style="text-align:left;border-bottom:2px solid #ddd;"><th>Use case</th><th>URL</th></tr>
            <tr style="border-bottom:1px solid #eee;">
                <td><strong>Webhook / GET API</strong><br/><span style="font-size:12px;color:#5a6170;">JSON, machine-readable</span></td>
                <td><code>GET @(Model.BaseUrl)/api/v1/sponsors/@Model.SponsorCompanyId/leads.json</code></td>
            </tr>
            <tr style="border-bottom:1px solid #eee;">
                <td><strong>CSV download</strong><br/><span style="font-size:12px;color:#5a6170;">browser-click or Invoke-WebRequest</span></td>
                <td><code>GET @(Model.BaseUrl)/api/v1/sponsors/@Model.SponsorCompanyId/leads.csv</code></td>
            </tr>
            <tr>
                <td><strong>CSV with custom filename</strong><br/><span style="font-size:12px;color:#5a6170;">filename controls the saved name when your tool uses URL path</span></td>
                <td><code>GET @(Model.BaseUrl)/api/v1/sponsors/@Model.SponsorCompanyId/leads/leads-@(Model.SponsorCompanyId)-@(DateTimeOffset.UtcNow.ToString("yyyy-MM-dd")).csv</code></td>
            </tr>
        </table>
    </div>

    <div class="card">
        <h2>Download samples (PowerShell)</h2>

        <h3>A. Download CSV to file</h3>
<pre style="background:#0d1117;color:#c9d1d9;padding:12px 14px;border-radius:6px;overflow-x:auto;">
$key     = 'PASTE-YOUR-SPONSOR-API-KEY-HERE'
$outFile = "$env:USERPROFILE\Downloads\leads-@Model.SponsorCompanyId-$(Get-Date -Format yyyy-MM-dd).csv"

Invoke-WebRequest -Uri "@(Model.BaseUrl)/api/v1/sponsors/@Model.SponsorCompanyId/leads.csv" `
                  -Headers @@{ 'X-Sponsor-Api-Key' = $key } `
                  -OutFile $outFile
Write-Host "Saved $outFile"
</pre>

        <h3>B. Fetch JSON, pipe into your own pipeline</h3>
<pre style="background:#0d1117;color:#c9d1d9;padding:12px 14px;border-radius:6px;overflow-x:auto;">
$key = 'PASTE-YOUR-SPONSOR-API-KEY-HERE'

$resp = Invoke-RestMethod -Uri "@(Model.BaseUrl)/api/v1/sponsors/@Model.SponsorCompanyId/leads.json" `
                          -Headers @@{ 'X-Sponsor-Api-Key' = $key }

"$($resp.count) leads for @Model.SponsorCompanyId"
$resp.leads | Where-Object { $_.LeadKind -eq 'Meeting' } |
              Select-Object FullName, Company, Email, CapturedAt
</pre>

        <h3>C. Scheduled task (daily, 06:30 local)</h3>
<pre style="background:#0d1117;color:#c9d1d9;padding:12px 14px;border-radius:6px;overflow-x:auto;">
# Save as Download-Leads.ps1, then register the scheduled task.
$key     = $env:SPONSOR_API_KEY      # set once in scheduled-task env
$outDir  = "$env:USERPROFILE\Downloads\sponsor-leads"
$null    = New-Item -ItemType Directory -Force -Path $outDir
$outFile = Join-Path $outDir "leads-@Model.SponsorCompanyId-$(Get-Date -Format yyyy-MM-dd).csv"

Invoke-WebRequest -Uri "@(Model.BaseUrl)/api/v1/sponsors/@Model.SponsorCompanyId/leads.csv" `
                  -Headers @@{ 'X-Sponsor-Api-Key' = $key } `
                  -OutFile $outFile

# Register the task (one-shot, run from an elevated PowerShell):
#   schtasks /create /tn "Download sponsor leads" /sc daily /st 06:30 /rl LIMITED `
#            /tr "powershell -NoProfile -File C:\path\Download-Leads.ps1"
</pre>

        <h3>D. Browser direct download (no PowerShell)</h3>
        <p>Paste this URL into your browser address bar. The CSV lands
           in your Downloads folder. Avoid bookmarking the URL with the
           key in it &mdash; it ends up in browser history.</p>
<pre style="background:#0d1117;color:#c9d1d9;padding:12px 14px;border-radius:6px;overflow-x:auto;">@(Model.BaseUrl)/api/v1/sponsors/@Model.SponsorCompanyId/leads.csv?key=PASTE-API-KEY-HERE</pre>
    </div>
}
