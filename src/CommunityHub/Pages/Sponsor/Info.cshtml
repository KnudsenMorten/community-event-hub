@page
@model CommunityHub.Pages.Sponsor.InfoModel
@{
    ViewData["Title"] = "Sponsor info";
}

<div class="card">
    <h2>Sponsor info upload</h2>

    @if (Model.AccessDenied)
    {
        <p class="error">
            This area is for sponsor contacts only. If you should have a sponsor role,
            contact the organizer team at <a href="mailto:info@expertslive.dk">info@expertslive.dk</a>.
        </p>
    }
    else
    {
        <p style="font-size:13px;color:#6b7280;">
            Company id: <code>@Model.CompanyId</code> &mdash; everyone in your company shares this form,
            so the last save wins.
        </p>
        <p style="background:#eef6ff;padding:10px 14px;border-radius:6px;font-size:13px;">
            Upload your logos + write the company descriptions here.
            <strong>You don't need to email them.</strong> The matching tasks on your hub will be
            marked Done automatically when you save.
        </p>

        if (!string.IsNullOrEmpty(Model.Error))   { <p class="error">@Model.Error</p> }
        if (!string.IsNullOrEmpty(Model.Message)) { <p class="info">@Model.Message</p> }

        <form method="post" enctype="multipart/form-data">

            <h3 style="color:var(--el-darkblue);margin-top:16px;">Logos</h3>

            <label for="LogoVectorUpload">Logo in vector format (.eps / .ai / .svg / .pdf) &mdash; for banners, rollups, walls</label>
            <input type="file" name="LogoVectorUpload" id="LogoVectorUpload" accept=".eps,.ai,.svg,.pdf" />
            @if (!string.IsNullOrEmpty(Model.CurrentLogoVectorUrl))
            {
                <p style="font-size:12px;color:#6b7280;margin-top:-8px;">
                    Current: <a href="@Model.CurrentLogoVectorUrl" target="_blank">@Model.CurrentLogoVectorFile</a>
                </p>
            }

            <label for="LogoRasterUpload">Logo in JPG / PNG (JPG preferred) &mdash; for social media</label>
            <input type="file" name="LogoRasterUpload" id="LogoRasterUpload" accept=".jpg,.jpeg,.png" />
            @if (!string.IsNullOrEmpty(Model.CurrentLogoRasterUrl))
            {
                <p style="font-size:12px;color:#6b7280;margin-top:-8px;">
                    Current: <a href="@Model.CurrentLogoRasterUrl" target="_blank">@Model.CurrentLogoRasterFile</a>
                </p>
            }

            <h3 style="color:var(--el-darkblue);margin-top:16px;">Company text</h3>

            <label for="CompanyDescription">Company description (max @CommunityHub.Pages.Sponsor.InfoModel.MaxDesc chars)</label>
            <textarea asp-for="CompanyDescription" rows="6"
                      maxlength="@CommunityHub.Pages.Sponsor.InfoModel.MaxDesc"
                      data-counter="CompanyDescriptionCount"></textarea>
            <p style="font-size:12px;color:#6b7280;margin-top:-8px;">
                <span id="CompanyDescriptionCount">0</span> / @CommunityHub.Pages.Sponsor.InfoModel.MaxDesc
            </p>

            <label for="CompanyDescriptionShort">Short description (max @CommunityHub.Pages.Sponsor.InfoModel.MaxShort chars)</label>
            <textarea asp-for="CompanyDescriptionShort" rows="2"
                      maxlength="@CommunityHub.Pages.Sponsor.InfoModel.MaxShort"
                      data-counter="CompanyDescriptionShortCount"></textarea>
            <p style="font-size:12px;color:#6b7280;margin-top:-8px;">
                <span id="CompanyDescriptionShortCount">0</span> / @CommunityHub.Pages.Sponsor.InfoModel.MaxShort
            </p>

            <label for="SocialMediaIntro">Social-media company intro (max @CommunityHub.Pages.Sponsor.InfoModel.MaxSocial chars &mdash; bullets fine)</label>
            <textarea asp-for="SocialMediaIntro" rows="4"
                      maxlength="@CommunityHub.Pages.Sponsor.InfoModel.MaxSocial"
                      data-counter="SocialMediaIntroCount"></textarea>
            <p style="font-size:12px;color:#6b7280;margin-top:-8px;">
                <span id="SocialMediaIntroCount">0</span> / @CommunityHub.Pages.Sponsor.InfoModel.MaxSocial
            </p>

            <button type="submit">Save sponsor info</button>
        </form>

        <p style="margin-top:14px;font-size:12px;color:#6b7280;">
            Saving will mark the logo + description tasks Done on your hub and email a
            notification to <a href="mailto:info@expertslive.dk">info@expertslive.dk</a>.
        </p>

        <script>
            (function () {
                ['CompanyDescription','CompanyDescriptionShort','SocialMediaIntro'].forEach(function (id) {
                    var el = document.getElementById(id);
                    var counter = document.getElementById(id + 'Count');
                    if (!el || !counter) return;
                    function tick() { counter.textContent = (el.value || '').length; }
                    el.addEventListener('input', tick);
                    tick();
                });
            })();
        </script>

        <p><a asp-page="/Sponsor/Index">Back to sponsor area</a></p>
    }
</div>
