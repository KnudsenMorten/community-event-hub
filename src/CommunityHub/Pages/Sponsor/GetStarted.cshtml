@page
@model CommunityHub.Pages.Sponsor.GetStartedModel
@using CommunityHub.Forms
@{
    ViewData["Title"] = Localizer["SponsorWiz.Title"].Value;
    string StepTitle(string key) => Localizer["SponsorWiz.Step." + key].Value;
    string StepDesc(string key) => Localizer["SponsorWiz.Step." + key + ".Desc"].Value;
    // Each sponsor step deep-links into a SECTION of the single Company Details page.
    string StepUrl(string anchor) => Url.Page("/Sponsor/CompanyDetails") + "#" + anchor;
}

@if (Model.AccessDenied)
{
    <div class="card">
        <h1>@Localizer["SponsorWiz.Title"]</h1>
        <p class="error">This page is for sponsors only.</p>
        <p><a asp-page="/Index">@Localizer["Common.BackToHub"]</a></p>
    </div>
}
else if (Model.NoCompanyLink || Model.View is null)
{
    <div class="card">
        <h1>@Localizer["SponsorWiz.Title"]</h1>
        <p class="info">Your sponsor account is not yet linked to a company, so we can't show your steps. Please contact the organizers.</p>
        <p><a asp-page="/Index">@Localizer["Common.BackToHub"]</a></p>
    </div>
}
else
{
    var v = Model.View;
    @* Map the sponsor view onto the shared stepper view-model (§161): every step a card,
       Edit/Open into the matching Company Details section, "Continue" to the next pending one. *@
    var cards = new List<WizardStepperCard>();
    var n = 0;
    foreach (var step in v.Steps)
    {
        n++;
        cards.Add(new WizardStepperCard(n, StepTitle(step.Key), StepDesc(step.Key), step.Done, StepUrl(step.Anchor)));
    }
    string? continueUrl = null, continueLabel = null;
    if (!v.AllDone && v.NextStep is not null)
    {
        continueUrl = StepUrl(v.NextStep.Anchor);
        continueLabel = $"Continue — step {v.NextStepNumber} of {v.TotalSteps}: {StepTitle(v.NextStep.Key)}";
    }
    var vm = new WizardStepperVm(
        Heading: Localizer["SponsorWiz.Title"].Value,
        Intro: "Welcome! Complete the steps below to get your company ready for the event. You can stop and come back any time — your progress is saved.",
        Cards: cards,
        ContinueUrl: continueUrl,
        ContinueLabel: continueLabel,
        AllDoneMessage: "🎉 All set — you can edit any step below any time.",
        EditLabel: "Edit",
        OpenLabel: "Open");
    <partial name="_WizardStepper" model="vm" />
}
