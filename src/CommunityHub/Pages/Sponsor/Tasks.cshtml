@page
@using CommunityHub.Core.Domain
@model CommunityHub.Pages.Sponsor.TasksModel
@{
    ViewData["Title"] = Localizer["SponsorTasks.Title"].Value;
}

@* §135 (operator 2026-06-27): the deliverables rollup, surfaced at the TOP of My Tasks now
   that the standalone /Sponsor/Deliverables nav item is removed. Mobile-first: score + bar +
   the still-to-do list (overdue highlighted), each missing item deep-linking to where it's
   fixed. Built read-only via SponsorDeliverablesService; omitted when null. *@
@if (!Model.NoCompanyLink && Model.Deliverables is { } d)
{
    <style>
        /* Mobile-first: cards + items stack and stay readable at ~360px. */
        .dl-score { display:flex; flex-wrap:wrap; align-items:baseline; gap:6px 12px; }
        .dl-score .dl-pct { font-size:34px; font-weight:800; color:var(--el-darkblue); line-height:1; }
        .dl-score .dl-of  { font-size:15px; color:#4b5563; }
        .dl-progress-wrap { background:#eef0f4; border-radius:999px; height:14px; overflow:hidden; margin:12px 0 4px; }
        .dl-progress-bar  { height:100%; border-radius:999px; transition:width .3s ease; background:#0a6; }
        .dl-complete { background:#0a6; color:#fff; border-radius:999px; padding:2px 12px; font-size:13px; font-weight:700; white-space:nowrap; }
        .dl-atrisk { background:#fdeceb; color:#9b261a; border:1px solid #f1c4bf; border-radius:999px; padding:2px 12px; font-size:13px; font-weight:700; white-space:nowrap; }
        .dl-list { list-style:none; padding:0; margin:8px 0 0; }
        .dl-item {
            border:1px solid #e5e7eb; border-radius:10px;
            padding:12px 14px; margin:10px 0;
            display:flex; flex-wrap:wrap; gap:8px 14px; align-items:center;
        }
        .dl-item.missing { background:#fdf8f0; border-color:#f0dcb8; }
        .dl-item.overdue { background:#fdeceb; border-color:#f1c4bf; }
        .dl-ico { font-size:18px; flex:0 0 auto; }
        .dl-label { flex:1 1 180px; min-width:0; font-weight:600; color:var(--el-darkblue); overflow-wrap:anywhere; }
        .dl-due { font-size:12.5px; color:#6b7280; }
        .dl-due.overdue { color:#9b261a; font-weight:700; }
        .dl-fix { flex:0 0 auto; }
        .dl-fix a { margin:0; }
        @@media (max-width: 460px) {
            .dl-fix { flex-basis:100%; }
            .dl-fix .task-link-btn { display:block; text-align:center; }
        }
    </style>
    <div class="card">
        <h2 style="margin-top:0;">&#128203; Your deliverables</h2>
        <div class="dl-score">
            <span class="dl-pct">@d.Percent%</span>
            <span class="dl-of">&middot; @d.Summary</span>
            @if (d.IsComplete)
            {
                <span class="dl-complete">All done &#127881;</span>
            }
            else if (d.AtRisk)
            {
                <span class="dl-atrisk">@d.OverdueCount overdue</span>
            }
        </div>
        <div class="dl-progress-wrap" role="progressbar"
             aria-valuenow="@d.Percent" aria-valuemin="0" aria-valuemax="100"
             aria-label="Deliverables @d.Percent percent complete">
            <div class="dl-progress-bar" style="width:@(d.Percent)%;"></div>
        </div>
        @if (d.MissingStages.Count > 0)
        {
            <h3 style="font-size:16px;margin:16px 0 4px;color:var(--el-darkblue);">Still to do (@d.MissingStages.Count)</h3>
            <ul class="dl-list">
                @foreach (var s in d.MissingStages)
                {
                    <li class="dl-item @(s.Overdue ? "overdue" : "missing")">
                        @if (s.Overdue)
                        {
                            <span class="dl-ico" aria-hidden="true">&#9888;</span>
                        }
                        else
                        {
                            <span class="dl-ico" aria-hidden="true">&#9633;</span>
                        }
                        <span class="dl-label">
                            @s.Label
                            @if (s.Deadline is not null)
                            {
                                <span class="dl-due @(s.Overdue ? "overdue" : "")">
                                    &middot; due @s.Deadline.Value.ToString("dd MMM yyyy")@(s.Overdue ? " (overdue)" : "")
                                </span>
                            }
                        </span>
                        @if (!string.IsNullOrEmpty(s.FixLink))
                        {
                            <span class="dl-fix"><a class="task-link-btn" href="@s.FixLink">Fix this</a></span>
                        }
                    </li>
                }
            </ul>
        }
        else
        {
            <p style="color:#1f6d3a;margin:12px 0 0;">Everything we need from your company is done. 🎉</p>
        }
        <p style="margin:12px 0 0;font-size:13.5px;"><a asp-page="/Sponsor/Deliverables">See full deliverables checklist &rarr;</a></p>
    </div>
}

<div class="card">
    <h1>@Localizer["SponsorTasks.Title"]</h1>

    @if (!Model.NoCompanyLink)
    {
        @await Html.PartialAsync("Shared/_SecondaryEmailBanner")
    }

    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <p class="info">@Model.Message</p>
    }

    @if (Model.NoCompanyLink)
    {
        <p class="error">@Localizer["SponsorTasks.NoCompany"]</p>
    }
    else if (Model.SponsorTasks.Count == 0)
    {
        <p>@Localizer["SponsorTasks.NoTasks"]</p>
    }
    else
    {
        <div style="margin:6px 0 14px;padding:12px 14px;background:#f8fafc;border:1px solid #cbd5e0;border-left:4px solid var(--el-blue);border-radius:6px;color:#444;font-size:14px;line-height:1.5;">
            <p style="margin:0 0 10px;"><strong>Instructions:</strong></p>
            <p style="margin:0 0 10px;">Below are the tasks for your company. To ensure your booth, company listing, and event materials are ready on time, please complete each task by its stated due date.</p>
            <p style="margin:0 0 10px;">Delivering information by the deadlines gives us enough time to handle the necessary logistics and preparations, while also helping maximize your company's visibility and exposure to attendees before and during the event.</p>
            <p style="margin:0 0 10px;">Tasks that are not marked as <em>Optional</em> are mandatory and must be completed for your company to be fully represented at the event.</p>
            <p style="margin:0 0 10px;">A red badge indicates that a task is overdue, while a yellow badge indicates an upcoming deadline. Mark the task as completed once finished.</p>
            <p style="margin:0;">If you are unable to meet a deadline, please contact the organizers as soon as possible so we can discuss possible solutions.</p>
        </div>
        @if (Model.LinkedContacts.Count > 0)
        {
            <p style="margin:6px 0 14px;color:#555;font-size:14px;">
                @Localizer["SponsorTasks.ManagedBy"]
                @for (var i = 0; i < Model.LinkedContacts.Count; i++)
                {
                    var c = Model.LinkedContacts[i];
                    <strong>@c.FullName</strong>
                    <span style="color:#888;">(@c.Email)</span>
                    @if (i < Model.LinkedContacts.Count - 1)
                    {
                        <span>, </span>
                    }
                }
            </p>
        }
        @* §147: the unified task list (completion % header → pending at the top →
           completed collapsed at the bottom), the SAME shared _TaskListPanel the /Tasks
           and /Speaker/Tasks pages use. The "Task checklist" % here is ParticipantTask
           completion — deliberately distinct from the "Your deliverables" rollup card
           above (which aggregates richer per-stage booth/upload signals). The sponsor
           row keeps its Optional badge + .ics link. *@
        @await Html.PartialAsync("Shared/_TaskListPanel",
            new CommunityHub.Pages.Shared.TaskListPanelView { Tasks = Model.SponsorTasks, RowPartialName = "_SponsorTaskRow" })
    }
    <p style="margin-top:14px;">
        <a asp-page="/Sponsor/Index">@Localizer["SponsorTasks.BackEngagement"]</a> &middot;
        <a asp-page="/Index">@Localizer["Common.BackToHub"]</a>
    </p>
</div>
