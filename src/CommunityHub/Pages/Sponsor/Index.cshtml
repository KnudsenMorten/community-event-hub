@page
@using CommunityHub.Core.Domain
@model CommunityHub.Pages.Sponsor.IndexModel
@{
    ViewData["Title"] = "Sponsor Webshop";
}

@if (Model.AccessDenied)
{
    <div class="card">
        <h1>Sponsor Webshop</h1>
        <p class="error">This page is for sponsors only.</p>
        <p><a asp-page="/Index">Back to hub</a></p>
    </div>
}
else if (Model.NoCompanyLink)
{
    <div class="card">
        <h1>Sponsor Webshop</h1>
        <p class="error">Your sponsor account is not yet linked to a company,
           so we cannot show your details. Please contact the organizers.</p>
        <p><a asp-page="/Index">Back to hub</a></p>
    </div>
}
else
{
    <div class="card">
        <h1>Webshop orders</h1>
        <p style="margin:0 0 10px;color:#555;font-size:14px;">
            Completed orders we have on file for your company in the current sales window.
            If something is missing, log in to the sponsor configurator and check the order status there.
        </p>
        @if (Model.SponsorOrders.Count == 0)
        {
            <p style="color:#888;font-style:italic;">No completed orders in scope yet.</p>
        }
        else
        {
            <table style="border-collapse:collapse;font-size:15px;width:100%;">
                <thead>
                    <tr>
                        <th style="text-align:left;padding:4px 14px 4px 0;border-bottom:2px solid var(--el-blue);">Order</th>
                        <th style="text-align:left;padding:4px 14px 4px 0;border-bottom:2px solid var(--el-blue);">Date</th>
                        <th style="text-align:left;padding:4px 0;border-bottom:2px solid var(--el-blue);">Products</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in Model.SponsorOrders)
                    {
                        <tr>
                            <td style="padding:6px 14px 6px 0;vertical-align:top;white-space:nowrap;">#@o.OrderId</td>
                            <td style="padding:6px 14px 6px 0;vertical-align:top;white-space:nowrap;">
                                @(o.CreatedAt?.ToString("dd/MM/yyyy") ?? "—")
                            </td>
                            <td style="padding:6px 0;vertical-align:top;">
                                @if (o.LineItems.Count == 0)
                                {
                                    <span style="color:#888;">(no line items)</span>
                                }
                                else
                                {
                                    <ul style="margin:0;padding-left:18px;">
                                        @foreach (var li in o.LineItems)
                                        {
                                            <li>@li.ProductName</li>
                                        }
                                    </ul>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        @* Company profile + facts now live on Company Details (no longer duplicated here).
           Booth info moved to the Event logistics nav section. Linked contacts removed
           (the contacts list lives on Company Details). (§35) *@
        <p style="margin-top:18px;">
            <a asp-page="/Sponsor/CompanyDetails">Company details &rarr;</a> &middot;
            <a asp-page="/Sponsor/Tasks">Sponsor Tasks &rarr;</a> &middot;
            <a asp-page="/Index">Back to hub</a>
        </p>
    </div>
}
