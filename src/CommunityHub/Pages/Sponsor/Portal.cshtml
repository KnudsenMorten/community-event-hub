@page
@using CommunityHub.Core.Domain
@using CommunityHub.Core.Integrations
@using CommunityHub.Core.Integrations.Sponsors
@model CommunityHub.Pages.Sponsor.PortalModel
@{
    ViewData["Title"] = Localizer["SponsorPortal.Title"].Value;
}

@*
    Sponsor portal (REQUIREMENTS §20 Sponsor) — the single self-service home.
    Mobile-first (~360px): every section is a stacked .card; the grids wrap.
    Pure render over PortalModel.View (built by SponsorPortalService). No writes;
    deep edits/actions live on the existing /Sponsor/* pages, linked from here.
*@

<style>
    .sp-portal .sp-head { display:flex; gap:14px; align-items:center; flex-wrap:wrap; }
    .sp-portal .sp-logo, .sp-portal .sp-mono {
        width:64px; height:64px; flex:0 0 64px; border-radius:10px;
        object-fit:contain; background:#fff; border:1px solid #e5e7eb;
    }
    .sp-portal .sp-mono {
        display:flex; align-items:center; justify-content:center;
        font-weight:700; font-size:22px; color:var(--el-darkblue); background:#eef2f7;
    }
    .sp-portal .sp-tier {
        display:inline-block; font-size:12px; font-weight:700; letter-spacing:.04em;
        text-transform:uppercase; color:#fff; background:var(--el-darkblue);
        border-radius:999px; padding:3px 10px;
    }
    .sp-portal .sp-tier.sp-tier-none { background:#6b7280; }
    .sp-portal .sp-quick { display:flex; gap:10px; flex-wrap:wrap; }
    .sp-portal table { width:100%; border-collapse:collapse; font-size:15px; }
    .sp-portal th, .sp-portal td { text-align:left; padding:8px 10px 8px 0; overflow-wrap:anywhere; }
    .sp-portal th { color:#6b7280; font-size:12px; border-bottom:1px solid #e5e7eb; }
    .sp-portal td { border-bottom:1px solid #f3f4f6; vertical-align:top; }
    .sp-portal .sp-muted { color:#888; font-style:italic; }
    .sp-portal .sp-pill {
        display:inline-block; font-size:12px; padding:2px 8px; border-radius:999px;
        background:#eef2f7; color:#374151;
    }
    .sp-portal .sp-pill-ok { background:#dcfce7; color:#166534; }
    .sp-portal .sp-pill-pending { background:#fef3c7; color:#92400e; }
    @@media (max-width: 480px) {
        .sp-portal th, .sp-portal td { padding-right:6px; }
        .sp-portal .sp-hide-narrow { display:none; }
    }
</style>

<div class="sp-portal">

@if (Model.AccessDenied)
{
    <div class="card">
        <h1>@Localizer["SponsorPortal.Title"]</h1>
        <p class="error">@Localizer["SponsorPortal.AccessDenied"]</p>
        <p><a asp-page="/Index">@Localizer["Common.BackToHub"]</a></p>
    </div>
}
else if (Model.NoCompanyLink)
{
    <div class="card">
        <h1>@Localizer["SponsorPortal.Title"]</h1>
        <p class="error">@Localizer["SponsorPortal.NoCompany"]</p>
        <p><a asp-page="/Index">@Localizer["Common.BackToHub"]</a></p>
    </div>
}
else if (Model.View is not null)
{
    var v = Model.View;

    @* ---- Company profile + logo + tier ---------------------------------- *@
    <div class="card">
        <div class="sp-head">
            @if (!string.IsNullOrEmpty(v.LogoPath))
            {
                <img class="sp-logo" src="@v.LogoPath" alt="@Localizer["SponsorPortal.LogoAlt", v.CompanyName]" />
            }
            else
            {
                <span class="sp-mono" aria-hidden="true">@v.Initials</span>
            }
            <div>
                <h1 style="margin:0 0 4px;">@v.CompanyName</h1>
                <span class="sp-tier @(v.Tier == BoothTier.None ? "sp-tier-none" : "")">@v.TierDisplay</span>
            </div>
        </div>
        <p style="margin:12px 0 0;color:#555;">@Localizer["SponsorPortal.Intro", Model.FirstName]</p>
        @if (!string.IsNullOrEmpty(v.WebsiteUrl))
        {
            <p style="margin:10px 0 0;">
                <a class="task-link-btn" href="@v.WebsiteUrl" target="_blank" rel="noopener noreferrer">
                    @Localizer["SponsorPortal.VisitWebsite"]<span class="visually-hidden">@Localizer["Common.OpensNewTab"]</span>
                </a>
            </p>
        }
        <p style="margin:12px 0 0;">
            <a asp-page="/Sponsor/Index">@Localizer["SponsorPortal.OpenEngagement"] &rarr;</a>
        </p>
    </div>

    @* ---- Booth & logistics --------------------------------------------- *@
    <div class="card">
        <h2>@Localizer["SponsorPortal.BoothLogistics"]</h2>
        <p style="margin:0 0 10px;color:#555;">@Localizer["SponsorPortal.BoothIntro"]</p>
        <div class="sp-quick">
            @if (!string.IsNullOrEmpty(Model.VenueFloorPlanUrl))
            {
                <a class="task-link-btn" href="@Model.VenueFloorPlanUrl" target="_blank" rel="noopener noreferrer">
                    @Localizer["SponsorPortal.VenuePlan"]<span class="visually-hidden">@Localizer["Common.OpensNewTab"]</span>
                </a>
            }
            @if (!string.IsNullOrEmpty(Model.ExhibitorGuideUrl))
            {
                <a class="task-link-btn" href="@Model.ExhibitorGuideUrl" target="_blank" rel="noopener noreferrer">
                    @Localizer["SponsorPortal.ExhibitorGuide"]<span class="visually-hidden">@Localizer["Common.OpensNewTab"]</span>
                </a>
            }
            <a class="task-link-btn" asp-page="/Sponsor/Logistics">@Localizer["SponsorPortal.AllLogistics"]</a>
        </div>
    </div>

    @* ---- Deliverables checklist (shared component) ---------------------- *@
    <h2 style="margin:22px 0 6px;">@Localizer["SponsorPortal.Deliverables"]</h2>
    <p style="margin:0 0 8px;color:#555;">@Localizer["SponsorPortal.DeliverablesIntro"]</p>
    @await Html.PartialAsync("Shared/_ChecklistCard", v.Checklist)
    <div class="card">
        <p style="margin:0;"><a asp-page="/Sponsor/Tasks">@Localizer["SponsorPortal.ManageTasks"] &rarr;</a></p>
    </div>

    @* ---- Leads (read) -------------------------------------------------- *@
    <div class="card">
        <h2>@Localizer["SponsorPortal.Leads", v.LeadCount]</h2>
        @if (v.RecentLeads.Count == 0)
        {
            <p class="sp-muted">@Localizer["SponsorPortal.NoLeads"]</p>
        }
        else
        {
            <table>
                <thead>
                    <tr>
                        <th>@Localizer["SponsorPortal.LeadName"]</th>
                        <th>@Localizer["SponsorPortal.LeadCompany"]</th>
                        <th class="sp-hide-narrow">@Localizer["SponsorPortal.LeadWhen"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var lead in v.RecentLeads)
                    {
                        <tr>
                            <td>@(string.IsNullOrWhiteSpace(lead.FullName) ? "—" : lead.FullName)</td>
                            <td>@(string.IsNullOrWhiteSpace(lead.Company) ? "—" : lead.Company)</td>
                            <td class="sp-hide-narrow">@lead.CapturedAt.ToString("dd/MM/yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        <p style="margin:12px 0 0;">
            <a asp-page="/Sponsor/CaptureLead">@Localizer["SponsorPortal.CaptureLead"]</a> &middot;
            <a asp-page="/Sponsor/Leads">@Localizer["SponsorPortal.LeadsApi"] &rarr;</a>
        </p>
    </div>

    @* ---- Order / invoice status (ERP link entities) -------------------- *@
    <div class="card">
        <h2>@Localizer["SponsorPortal.OrderStatus"]</h2>
        <p style="margin:0 0 8px;color:#555;">
            @Localizer["SponsorPortal.OrderIntro"]
            @if (v.ErpCustomerLinked)
            {
                <span class="sp-pill sp-pill-ok">@Localizer["SponsorPortal.ErpLinked"]</span>
            }
            else
            {
                <span class="sp-pill sp-pill-pending">@Localizer["SponsorPortal.ErpNotConfigured"]</span>
            }
        </p>
        @if (v.Orders.Count == 0)
        {
            <p class="sp-muted">@Localizer["SponsorPortal.NoOrders"]</p>
        }
        else
        {
            <table>
                <thead>
                    <tr>
                        <th>@Localizer["SponsorPortal.OrderRef"]</th>
                        <th class="sp-hide-narrow">@Localizer["SponsorPortal.OrderCurrency"]</th>
                        <th>@Localizer["SponsorPortal.OrderInvoice"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in v.Orders)
                    {
                        <tr>
                            <td>#@o.WebshopOrderId</td>
                            <td class="sp-hide-narrow">@(string.IsNullOrWhiteSpace(o.Currency) ? "—" : o.Currency)</td>
                            <td>
                                @if (o.InErp)
                                {
                                    <span class="sp-pill sp-pill-ok">@Localizer["SponsorPortal.InvoiceNo", o.ErpOrderNumber]</span>
                                }
                                else
                                {
                                    <span class="sp-pill sp-pill-pending">@Localizer["SponsorPortal.InvoicePending"]</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    @* ---- Linked contacts ----------------------------------------------- *@
    <div class="card">
        <h2>@Localizer["SponsorPortal.Contacts"]</h2>
        @if (v.Contacts.Count == 0)
        {
            <p class="sp-muted">@Localizer["SponsorPortal.NoContacts"]</p>
        }
        else
        {
            <table>
                <thead>
                    <tr>
                        <th>@Localizer["SponsorPortal.ContactName"]</th>
                        <th>@Localizer["SponsorPortal.ContactEmail"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in v.Contacts)
                    {
                        <tr>
                            <td>@c.FullName</td>
                            <td><a href="mailto:@c.Email">@c.Email</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        <p style="margin:12px 0 0;"><a asp-page="/Sponsor/Contact">@Localizer["SponsorPortal.ContactOrganizers"] &rarr;</a></p>
    </div>

    <p style="margin:6px 0 20px;"><a asp-page="/Index">@Localizer["Common.BackToHub"]</a></p>
}
</div>
