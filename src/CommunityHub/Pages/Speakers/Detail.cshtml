@page "/Speakers/{id:int}"
@model CommunityHub.Pages.Speakers.DetailModel
@{
    Layout = "_Layout";
    ViewData["Title"] = Model.Speaker is null
        ? Localizer["Speakers.Title"].Value
        : Model.Speaker.Name;
}

<style>
    /* Mobile-first: single column, readable at ~360px. */
    .spd-head {
        background: var(--el-darkblue, #1D3380); color: #fff;
        padding: 22px; border-radius: 10px 10px 0 0; margin: 0;
    }
    .spd-head h1 { margin: 0; font-size: 22px; font-weight: 700; line-height: 1.3; }
    .spd-head .meta { font-size: 13.5px; opacity: .92; margin-top: 6px; }
    .spd-body { padding: 18px 16px 24px; }

    .spd-back { display: inline-block; font-size: 13px; font-weight: 600;
        color: var(--el-blue, #008BD2); text-decoration: none; margin: 0 0 14px; }
    .spd-back:hover, .spd-back:focus { text-decoration: underline; }

    .spd-top { display: flex; gap: 16px; align-items: flex-start; margin: 0 0 16px; }
    .spd-photo, .spd-mono {
        width: 96px; height: 96px; border-radius: 50%; flex: 0 0 96px;
        object-fit: cover; background: var(--el-grey, #E3E3E3);
    }
    .spd-mono {
        display: flex; align-items: center; justify-content: center;
        background: var(--el-blue, #008BD2); color: #fff;
        font-weight: 700; font-size: 32px; letter-spacing: .5px;
    }
    .spd-name { min-width: 0; }
    .spd-name h2 { display: none; }
    .spd-tagline { font-size: 14.5px; color: #4a5160; line-height: 1.5; margin: 6px 0 0; }

    .spd-section { margin: 0 0 18px; }
    .spd-section h2 { font-size: 14px; color: #1D3380; margin: 0 0 8px; }
    .spd-bio { font-size: 14px; color: #2c333f; line-height: 1.6; margin: 0; white-space: pre-wrap; }

    .spd-sessions { list-style: none; margin: 0; padding: 0; display: grid; gap: 8px; }
    .spd-sessions li a { font-size: 14px; color: var(--el-blue, #008BD2); text-decoration: none; font-weight: 600; }
    .spd-sessions li a:hover, .spd-sessions li a:focus { text-decoration: underline; }

    .spd-empty { color: #555; font-style: italic; padding: 18px 4px; }
</style>

<div class="card" style="padding:0; overflow:hidden; max-width:760px; margin:0 auto;">
    @if (Model.Speaker is null)
    {
        <div class="spd-head"><h1>@Localizer["Speakers.Title"]</h1></div>
        <div class="spd-body"><p class="spd-empty">@Localizer["Public.NoLiveEvent"]</p></div>
        return;
    }
    @{ var sp = Model.Speaker; }

    <div class="spd-head">
        <h1>@sp.Name</h1>
        <div class="meta">@sp.EventDisplayName</div>
    </div>

    <div class="spd-body">
        <a class="spd-back" href="/Speakers">&larr; @Localizer["SpeakerDetail.BackToSpeakers"]</a>

        <div class="spd-top">
            @if (!string.IsNullOrWhiteSpace(sp.PhotoUrl))
            {
                <img class="spd-photo" src="@sp.PhotoUrl"
                     alt="@Localizer["Speakers.PhotoAlt", sp.Name]"
                     loading="lazy" width="96" height="96" />
            }
            else
            {
                <span class="spd-mono" aria-hidden="true">@sp.Initials</span>
            }
            <div class="spd-name">
                @if (!string.IsNullOrWhiteSpace(sp.Tagline))
                {
                    <p class="spd-tagline">@sp.Tagline</p>
                }
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(sp.Bio))
        {
            <div class="spd-section">
                <h2>@Localizer["SpeakerDetail.BioHeading"]</h2>
                <p class="spd-bio">@sp.Bio</p>
            </div>
        }

        @if (sp.Sessions.Count > 0)
        {
            <div class="spd-section">
                <h2>@Localizer["SpeakerDetail.SessionsHeading"]</h2>
                <ul class="spd-sessions">
                    @foreach (var t in sp.Sessions)
                    {
                        <li><a href="/Sessions/@t.SessionId">@t.Title</a></li>
                    }
                </ul>
            </div>
        }
    </div>
</div>
